@using Microsoft.EntityFrameworkCore
@using VKFoodTour.Infrastructure.Data
@implements IAsyncDisposable
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<style>
    .adw-card {
        background: linear-gradient(135deg, #0d1117 0%, #161b22 100%);
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 18px;
    }
    .adw-counter {
        font-size: 3.5rem;
        font-weight: 900;
        line-height: 1;
        background: linear-gradient(135deg, #E8A020, #f83b3b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .adw-pulse {
        display: inline-block;
        width: 10px; height: 10px;
        border-radius: 50%;
        background: #4ade80;
        box-shadow: 0 0 0 0 rgba(74,222,128,0.6);
        animation: adw-pulse-anim 1.8s infinite;
    }
    .adw-pulse.offline { background: #4a5568; box-shadow: none; animation: none; }
    @@keyframes adw-pulse-anim {
        0%   { box-shadow: 0 0 0 0 rgba(74,222,128,0.6); }
        70%  { box-shadow: 0 0 0 9px rgba(74,222,128,0); }
        100% { box-shadow: 0 0 0 0 rgba(74,222,128,0); }
    }
    .adw-device-row {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 10px;
        transition: background 0.15s;
    }
    .adw-device-row:hover { background: rgba(255,255,255,0.06); }
    .adw-badge {
        font-size: 10px; letter-spacing: 0.8px; font-weight: 600;
        padding: 3px 9px; border-radius: 20px;
    }
    .adw-event-dot {
        width: 7px; height: 7px; border-radius: 50%; display: inline-block;
    }
</style>

<div class="adw-card p-4">
    @* ── Header ── *@
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div class="d-flex align-items-center gap-3">
            <span class="adw-pulse @(OnlineCount == 0 ? "offline" : "")"></span>
            <div>
                <div style="font-size:11px;letter-spacing:1.5px;color:#8A8078;font-weight:600;">
                    THIẾT BỊ ĐANG DÙNG APP
                </div>
                <div style="font-size:12px;color:#4a5568;margin-top:1px;">
                    Cửa sổ: @windowSeconds giây gần nhất · Cập nhật mỗi @RefreshSeconds giây
                </div>
            </div>
        </div>
        <div class="d-flex align-items-center gap-3">
            @if (lastError is not null)
            {
                <span class="adw-badge" style="background:rgba(248,113,113,0.12);color:#f87171;border:1px solid rgba(248,113,113,0.2);">
                    <i class="bi bi-exclamation-circle me-1"></i>Lỗi DB
                </span>
            }
            <span class="text-muted" style="font-size:11px;">
                <i class="bi bi-clock me-1"></i>@(lastRefreshed?.ToString("HH:mm:ss") ?? "--")
            </span>
            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3"
                    style="font-size:12px;border-color:rgba(255,255,255,0.12);"
                    @onclick="RefreshAsync">
                <i class="bi bi-arrow-clockwise @(isLoading ? "spin-icon" : "")"></i>
            </button>
        </div>
    </div>

    @* ── Counter row ── *@
    <div class="row mb-2">
        <div class="col-12 text-center">
            <div class="adw-counter">@OnlineCount</div>
            <div style="color:#8A8078;font-size:12px;margin-top:4px;">thiết bị online trực tuyến</div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int WindowSeconds { get; set; } = 45;
    [Parameter] public int? WindowMinutes { get; set; }
    [Parameter] public int RefreshSeconds { get; set; } = 3;

    private int OnlineCount;
    private DateTime? lastRefreshed;
    private string? lastError;
    private bool isLoading;
    private Timer? _timer;
    private int windowSeconds = 45;

    protected override async Task OnInitializedAsync()
    {
        windowSeconds = WindowMinutes.HasValue
            ? Math.Clamp(WindowMinutes.Value * 60, 15, 300)
            : Math.Clamp(WindowSeconds, 15, 300);

        await RefreshAsync();
        _timer = new Timer(async _ =>
        {
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(RefreshSeconds), TimeSpan.FromSeconds(RefreshSeconds));
    }

    private async Task RefreshAsync()
    {
        isLoading = true;
        lastError = null;
        try
        {
            var threshold = DateTime.Now.AddSeconds(-windowSeconds);
            await using var db = await DbFactory.CreateDbContextAsync();

            var logs = await db.TrackingLogs
                .AsNoTracking()
                .Where(t => t.CreatedAt >= threshold)
                .Select(t => new
                {
                    t.DeviceId,
                    t.EventType,
                    t.CreatedAt,
                    t.PoiId
                })
                .OrderByDescending(t => t.CreatedAt)
                .Take(2000)
                .ToListAsync();

            // Đếm các thiết bị mà sự kiện gần nhất KHÔNG phải là 'exit'
            OnlineCount = logs
                .GroupBy(t => t.DeviceId)
                .Select(g => g.OrderByDescending(x => x.CreatedAt).First().EventType)
                .Count(latestEvent => latestEvent != "exit");

            lastRefreshed = DateTime.Now;
        }
        catch (Exception ex)
        {
            lastError = ex.Message;
            System.Diagnostics.Debug.WriteLine($"[ActiveDevicesWidget] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _timer?.Dispose();
    }
}
