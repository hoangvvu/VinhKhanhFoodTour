@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Dashboard - Vĩnh Khánh</PageTitle>

<div class="page-content p-4" style="background-color: #262121; min-height: 100vh;">
    
    @* ════════════════════════════════════════════════════════════
       GIAO DIỆN DÀNH CHO ADMIN
       ════════════════════════════════════════════════════════════ *@
    <AuthorizeView Roles="Admin">
        <Authorized>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="mb-0 fw-bold" style="color: #F0EBE3;">TỔNG QUAN HỆ THỐNG</h3>
                <span class="badge bg-danger p-2 px-3">Quyền: Quản trị viên</span>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card bg-dark-card border-0 p-4 shadow-sm h-100" style="border-radius: 16px;">
                        <h5 class="text-warning fw-bold mb-4"><i class="bi bi-geo-alt-fill me-2"></i>TOP 10 NƠI ĐẾN NHIỀU NHẤT</h5>
                        <ul class="list-group list-group-flush bg-transparent">
                            <li class="list-group-item bg-transparent text-white border-secondary px-0 d-flex justify-content-between align-items-center">
                                <span><span class="badge bg-secondary me-2">1</span> Ốc Oanh</span>
                                <span class="text-warning fw-bold">1,245 lượt</span>
                            </li>
                            <li class="list-group-item bg-transparent text-white border-secondary px-0 d-flex justify-content-between align-items-center">
                                <span><span class="badge bg-secondary me-2">2</span> Sushi Viên VK</span>
                                <span class="text-warning fw-bold">980 lượt</span>
                            </li>
                            <li class="list-group-item bg-transparent text-white border-secondary px-0 d-flex justify-content-between align-items-center">
                                <span><span class="badge bg-secondary me-2">3</span> Lãng Quán</span>
                                <span class="text-warning fw-bold">850 lượt</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card bg-dark-card border-0 p-4 shadow-sm h-100" style="border-radius: 16px;">
                        <h5 class="text-info fw-bold mb-4"><i class="bi bi-headphones me-2"></i>TOP 10 AUDIO NGHE NHIỀU NHẤT</h5>
                        <ul class="list-group list-group-flush bg-transparent">
                            <li class="list-group-item bg-transparent text-white border-secondary px-0 d-flex justify-content-between align-items-center">
                                <span><span class="badge bg-secondary me-2">1</span> Sự tích Ốc Oanh (VI)</span>
                                <span class="text-info fw-bold">3,400 phút</span>
                            </li>
                            <li class="list-group-item bg-transparent text-white border-secondary px-0 d-flex justify-content-between align-items-center">
                                <span><span class="badge bg-secondary me-2">2</span> Vĩnh Khánh History (EN)</span>
                                <span class="text-info fw-bold">2,100 phút</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>


    @* ════════════════════════════════════════════════════════════
       GIAO DIỆN DÀNH CHO VENDOR (CHỦ QUÁN)
       ════════════════════════════════════════════════════════════ *@
    <AuthorizeView Roles="Vendor">
        <Authorized>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="mb-0 fw-bold" style="color: #F0EBE3;">XIN CHÀO CHỦ QUÁN!</h3>
                <span class="badge bg-info text-dark p-2 px-3">Quyền: Đối tác (Vendor)</span>
            </div>

            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <div class="card bg-dark-card border-0 p-4 shadow-sm" style="border-radius: 16px;">
                        <div class="text-muted small fw-bold mb-2">DOANH THU THÁNG NÀY</div>
                        <h2 class="text-success fw-bold">12,500,000 đ</h2>
                        <div class="text-success small"><i class="bi bi-arrow-up-right me-1"></i>+15% so với tháng trước</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark-card border-0 p-4 shadow-sm" style="border-radius: 16px;">
                        <div class="text-muted small fw-bold mb-2">ĐÁNH GIÁ MỚI (REVIEWS)</div>
                        <h2 class="text-warning fw-bold">4.8 <i class="bi bi-star-fill fs-5"></i></h2>
                        <div class="text-muted small">Từ 120 khách hàng quét QR</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-dark-card border-0 p-4 shadow-sm" style="border-radius: 16px;">
                        <div class="text-muted small fw-bold mb-2">LƯỢT NGHE THUYẾT MINH</div>
                        <h2 class="text-info fw-bold">450 lượt</h2>
                        <div class="text-muted small">Giọng nữ miền Nam được yêu thích nhất</div>
                    </div>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

</div>