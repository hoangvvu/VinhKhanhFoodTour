@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using VKFoodTour.Infrastructure.Data
@using VKFoodTour.Infrastructure.Entities
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext Db
@inject PoiService PoiService

<PageTitle>Dashboard - Vĩnh Khánh</PageTitle>

<style>
    .dash-bg { background-color: #0f0f13; min-height: 100vh; }

    .stat-card {
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.06);
        background: #1a1a24;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.4) !important; }

    .section-label {
        font-size: 11px;
        letter-spacing: 2px;
        font-weight: 700;
        color: #4a4a5a;
        text-transform: uppercase;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        margin-bottom: 16px;
    }

    .rank-row { transition: background 0.15s; border-radius: 10px; }
    .rank-row:hover { background: rgba(255,255,255,0.04); }

    .progress-thin { height: 6px; border-radius: 3px; background: #2a2a38; }

    .pulse-dot { animation: pulse 2s infinite; }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    .online-card {
        border-radius: 20px;
        background: linear-gradient(135deg, #0d2818 0%, #0a3d1f 100%);
        border: 1px solid rgba(34,197,94,0.25);
        position: relative;
        overflow: hidden;
    }
    .online-card::before {
        content: '';
        position: absolute;
        top: -30px; right: -30px;
        width: 120px; height: 120px;
        background: rgba(34,197,94,0.08);
        border-radius: 50%;
    }

    .vendor-stat-card {
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.07);
        background: #1a1a24;
    }
</style>

<div class="dash-bg p-4">

    @if (isLoading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
            <div class="spinner-border text-danger mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
            <span style="color: #4a4a5a; font-size: 13px; letter-spacing: 1px;">ĐANG TẢI DỮ LIỆU…</span>
        </div>
    }
    else
    {
        @* ══════════════════════════════════════════════════════════
           ADMIN DASHBOARD
           ══════════════════════════════════════════════════════════ *@
        <AuthorizeView Roles="Admin">
            <Authorized>

                @* ── Header ── *@
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="fw-bold mb-1" style="color: #F0EBE3; letter-spacing: -0.5px;">Tổng quan hệ thống</h2>
                        <span style="color: #4a4a5a; font-size: 13px;">
                            <i class="bi bi-clock me-1"></i>Cập nhật lúc @DateTime.Now.ToString("HH:mm, dd/MM/yyyy")
                        </span>
                    </div>
                    <span class="badge px-3 py-2" style="background: rgba(200,55,45,0.15); color: #f87171; border: 1px solid rgba(200,55,45,0.3); border-radius: 20px; font-size: 12px;">
                        <i class="bi bi-shield-fill me-1"></i>Quản trị viên
                    </span>
                </div>

                @* ── REALTIME ROW ── *@
                <div class="section-label"><i class="bi bi-wifi me-2"></i>REALTIME — THIẾT BỊ ĐANG DÙNG APP</div>
                <div class="row g-4 mb-5">
                    <div class="col-12">
                        <ActiveDevicesWidget WindowMinutes="2" RefreshSeconds="10" />
                    </div>
                </div>

                @* ── THỐNG KÊ HỆ THỐNG ── *@
                <div class="section-label"><i class="bi bi-grid-1x2 me-2"></i>THỐNG KÊ HỆ THỐNG</div>
                <div class="row g-3 mb-5">
                    <div class="col-6 col-md-3">
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div style="background: rgba(232,160,32,0.12); border-radius: 10px; padding: 10px;">
                                    <i class="bi bi-shop" style="color: #E8A020; font-size: 1.3rem;"></i>
                                </div>
                                <span class="badge" style="background: rgba(232,160,32,0.1); color: #E8A020; font-size: 10px;">@activePois hoạt động</span>
                            </div>
                            <h3 class="text-white fw-bold mb-1">@totalPois</h3>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">TỔNG GIAN HÀNG</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div style="background: rgba(13,202,240,0.12); border-radius: 10px; padding: 10px;">
                                    <i class="bi bi-mic-fill" style="color: #0dcaf0; font-size: 1.3rem;"></i>
                                </div>
                                <span class="badge" style="background: rgba(13,202,240,0.1); color: #0dcaf0; font-size: 10px;">@totalLanguages ngôn ngữ</span>
                            </div>
                            <h3 class="text-white fw-bold mb-1">@totalNarrations</h3>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">THUYẾT MINH</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div style="background: rgba(200,55,45,0.12); border-radius: 10px; padding: 10px;">
                                    <i class="bi bi-people-fill" style="color: #f87171; font-size: 1.3rem;"></i>
                                </div>
                                <span class="badge" style="background: rgba(200,55,45,0.1); color: #f87171; font-size: 10px;">@totalVendors vendor</span>
                            </div>
                            <h3 class="text-white fw-bold mb-1">@totalUsers</h3>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">NGƯỜI DÙNG</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div style="background: rgba(25,135,84,0.12); border-radius: 10px; padding: 10px;">
                                    <i class="bi bi-qr-code-scan" style="color: #4ade80; font-size: 1.3rem;"></i>
                                </div>
                                <span class="badge" style="background: rgba(25,135,84,0.1); color: #4ade80; font-size: 10px;">hôm nay</span>
                            </div>
                            <h3 class="text-white fw-bold mb-1">@todayQrScans</h3>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">LƯỢT QUÉT QR</div>
                        </div>
                    </div>
                </div>

                @* ── THỐNG KÊ HÀNH VI ── *@
                <div class="section-label"><i class="bi bi-activity me-2"></i>HÀNH VI NGƯỜI DÙNG</div>
                <div class="row g-3 mb-5">
                    <div class="col-6 col-md-4">
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div style="background: rgba(232,160,32,0.12); border-radius: 10px; padding: 10px;">
                                    <i class="bi bi-cursor-fill" style="color: #E8A020; font-size: 1.3rem;"></i>
                                </div>
                            </div>
                            <h3 class="text-white fw-bold mb-1">@totalEvents</h3>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">TỔNG LƯỢT TƯƠNG TÁC</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div style="background: rgba(13,202,240,0.12); border-radius: 10px; padding: 10px;">
                                    <i class="bi bi-headphones" style="color: #0dcaf0; font-size: 1.3rem;"></i>
                                </div>
                                <span class="badge" style="background: rgba(13,202,240,0.1); color: #0dcaf0; font-size: 10px;">giây/lần</span>
                            </div>
                            <h3 class="text-white fw-bold mb-1">@avgListenSec</h3>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">THỜI GIAN NGHE TB</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="stat-card p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div style="background: rgba(250,204,21,0.12); border-radius: 10px; padding: 10px;">
                                    <i class="bi bi-star-fill" style="color: #facc15; font-size: 1.3rem;"></i>
                                </div>
                            </div>
                            <h3 class="text-white fw-bold mb-1">@totalReviews</h3>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">TỔNG ĐÁNH GIÁ</div>
                        </div>
                    </div>
                </div>

                @* ── XẾP HẠNG ── *@
                <div class="section-label"><i class="bi bi-trophy me-2"></i>XẾP HẠNG NỔI BẬT</div>
                <div class="row g-4 mb-5">
                    @* Top POI *@
                    <div class="col-md-6">
                        <div class="stat-card p-4 h-100">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <div style="background: rgba(232,160,32,0.12); border-radius: 10px; padding: 8px 10px;">
                                    <i class="bi bi-geo-alt-fill" style="color: #E8A020;"></i>
                                </div>
                                <span class="fw-bold" style="color: #E8A020; letter-spacing: 0.5px; font-size: 13px;">TOP GIAN HÀNG ĐƯỢC QUAN TÂM</span>
                            </div>
                            @if (topPois.Any())
                            {
                                @foreach (var (poi, i) in topPois.Select((p, i) => (p, i)))
                                {
                                    <div class="rank-row d-flex justify-content-between align-items-center px-2 py-2 mb-1">
                                        <div class="d-flex align-items-center gap-3">
                                            <span class="fw-bold" style="min-width: 22px; color: @(i == 0 ? "#E8A020" : i == 1 ? "#9ca3af" : i == 2 ? "#cd7f32" : "#4a4a5a"); font-size: 14px;">@(i + 1)</span>
                                            <span style="color: #d1d5db; font-size: 14px;">@poi.PoiName</span>
                                        </div>
                                        <span class="fw-bold" style="color: #E8A020; font-size: 13px;">@poi.EventCount <span style="color: #4a4a5a; font-weight: 400;">lượt</span></span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4" style="color: #4a4a5a;">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>Chưa có dữ liệu
                                </div>
                            }
                        </div>
                    </div>

                    @* Top Audio *@
                    <div class="col-md-6">
                        <div class="stat-card p-4 h-100">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <div style="background: rgba(13,202,240,0.12); border-radius: 10px; padding: 8px 10px;">
                                    <i class="bi bi-headphones" style="color: #0dcaf0;"></i>
                                </div>
                                <span class="fw-bold" style="color: #0dcaf0; letter-spacing: 0.5px; font-size: 13px;">TOP THUYẾT MINH ĐƯỢC NGHE</span>
                            </div>
                            @if (topAudio.Any())
                            {
                                @foreach (var (item, i) in topAudio.Select((a, i) => (a, i)))
                                {
                                    <div class="rank-row d-flex justify-content-between align-items-center px-2 py-2 mb-1">
                                        <div class="d-flex align-items-center gap-3">
                                            <span class="fw-bold" style="min-width: 22px; color: @(i == 0 ? "#0dcaf0" : i == 1 ? "#9ca3af" : i == 2 ? "#cd7f32" : "#4a4a5a"); font-size: 14px;">@(i + 1)</span>
                                            <span style="color: #d1d5db; font-size: 14px;">@item.PoiName</span>
                                        </div>
                                        <span class="fw-bold" style="color: #0dcaf0; font-size: 13px;">@item.TotalMinutes <span style="color: #4a4a5a; font-weight: 400;">phút</span></span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4" style="color: #4a4a5a;">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>Chưa có dữ liệu
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @* ── PHÂN TÍCH ── *@
                <div class="section-label"><i class="bi bi-bar-chart-line me-2"></i>PHÂN TÍCH</div>
                <div class="row g-4">
                    @* Ngôn ngữ *@
                    <div class="col-md-6">
                        <div class="stat-card p-4 h-100">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <div style="background: rgba(13,202,240,0.12); border-radius: 10px; padding: 8px 10px;">
                                    <i class="bi bi-translate" style="color: #0dcaf0;"></i>
                                </div>
                                <span class="fw-bold" style="color: #d1d5db; letter-spacing: 0.5px; font-size: 13px;">NGÔN NGỮ SỬ DỤNG</span>
                            </div>
                            @if (languageStats.Any())
                            {
                                @foreach (var lang in languageStats)
                                {
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span style="color: #9ca3af; font-size: 13px;">@lang.Name <span style="color: #4a4a5a;">(@lang.Code.ToUpper())</span></span>
                                            <span class="fw-bold" style="color: #0dcaf0; font-size: 13px;">@lang.Percent%</span>
                                        </div>
                                        <div class="progress-thin">
                                            <div class="progress-bar" style="background: linear-gradient(90deg, #0dcaf0, #0284c7); width: @lang.Percent%; height: 100%; border-radius: 3px;"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4" style="color: #4a4a5a;">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>Chưa có dữ liệu
                                </div>
                            }
                        </div>
                    </div>

                    @* Phân bổ đánh giá *@
                    <div class="col-md-6">
                        <div class="stat-card p-4 h-100">
                            <div class="d-flex align-items-center gap-2 mb-4">
                                <div style="background: rgba(250,204,21,0.12); border-radius: 10px; padding: 8px 10px;">
                                    <i class="bi bi-star-fill" style="color: #facc15;"></i>
                                </div>
                                <span class="fw-bold" style="color: #d1d5db; letter-spacing: 0.5px; font-size: 13px;">PHÂN BỔ ĐÁNH GIÁ</span>
                            </div>
                            @for (int star = 5; star >= 1; star--)
                            {
                                var count = ratingDistribution.GetValueOrDefault(star, 0);
                                var percent = totalReviews > 0 ? (count * 100 / totalReviews) : 0;
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="d-flex align-items-center gap-1" style="min-width: 50px;">
                                        <span style="color: #facc15; font-size: 13px; font-weight: 600;">@star</span>
                                        <i class="bi bi-star-fill" style="color: #facc15; font-size: 10px;"></i>
                                    </div>
                                    <div class="flex-grow-1 progress-thin">
                                        <div style="background: linear-gradient(90deg, #facc15, #f59e0b); width: @percent%; height: 100%; border-radius: 3px;"></div>
                                    </div>
                                    <span style="color: #6b7280; font-size: 12px; min-width: 30px; text-align: right;">@count</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </Authorized>
        </AuthorizeView>

        @* ══════════════════════════════════════════════════════════
           VENDOR DASHBOARD
           ══════════════════════════════════════════════════════════ *@
        <AuthorizeView Roles="Vendor">
            <Authorized>
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div>
                        <h2 class="fw-bold mb-1" style="color: #F0EBE3;">Xin chào, @vendorPoiName!</h2>
                        <span style="color: #4a4a5a; font-size: 13px;">
                            <i class="bi bi-clock me-1"></i>@DateTime.Now.ToString("HH:mm, dd/MM/yyyy")
                        </span>
                    </div>
                    <span class="badge px-3 py-2" style="background: rgba(13,202,240,0.12); color: #0dcaf0; border: 1px solid rgba(13,202,240,0.25); border-radius: 20px; font-size: 12px;">
                        <i class="bi bi-person-badge me-1"></i>Đối tác (Vendor)
                    </span>
                </div>

                <div class="section-label"><i class="bi bi-grid me-2"></i>TỔNG QUAN QUÁN</div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="vendor-stat-card p-4" style="border-left: 4px solid #E8A020;">
                            <div style="background: rgba(232,160,32,0.12); border-radius: 10px; padding: 10px; width: fit-content; margin-bottom: 16px;">
                                <i class="bi bi-qr-code-scan" style="color: #E8A020; font-size: 1.4rem;"></i>
                            </div>
                            <h2 class="text-white fw-bold mb-1">@vendorQrScans</h2>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">LƯỢT QUÉT QR HÔM NAY</div>
                            <div style="color: #6b7280; font-size: 12px; margin-top: 4px;">Tại quán của bạn</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="vendor-stat-card p-4" style="border-left: 4px solid #facc15;">
                            <div style="background: rgba(250,204,21,0.12); border-radius: 10px; padding: 10px; width: fit-content; margin-bottom: 16px;">
                                <i class="bi bi-star-fill" style="color: #facc15; font-size: 1.4rem;"></i>
                            </div>
                            @if (vendorAvgRating > 0)
                            {
                                <h2 class="text-white fw-bold mb-1">
                                    @vendorAvgRating.ToString("0.0")
                                    <i class="bi bi-star-fill text-warning" style="font-size: 1rem;"></i>
                                </h2>
                                <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">ĐÁNH GIÁ TRUNG BÌNH</div>
                                <div style="color: #6b7280; font-size: 12px; margin-top: 4px;">Từ @vendorReviewCount đánh giá</div>
                            }
                            else
                            {
                                <h4 style="color: #4a4a5a;" class="fw-bold mb-1">Chưa có</h4>
                                <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">ĐÁNH GIÁ TRUNG BÌNH</div>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="vendor-stat-card p-4" style="border-left: 4px solid #0dcaf0;">
                            <div style="background: rgba(13,202,240,0.12); border-radius: 10px; padding: 10px; width: fit-content; margin-bottom: 16px;">
                                <i class="bi bi-card-list" style="color: #0dcaf0; font-size: 1.4rem;"></i>
                            </div>
                            <h2 class="text-white fw-bold mb-1">@vendorMenuCount</h2>
                            <div style="color: #4a4a5a; font-size: 12px; letter-spacing: 0.5px;">MÓN ĂN TRONG THỰC ĐƠN</div>
                            <div style="color: #6b7280; font-size: 12px; margin-top: 4px;">Đang hiển thị trên app</div>
                        </div>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    }
</div>

@code {
    private bool isLoading = true;

    // ── Admin stats – hệ thống ───────────────
    private int totalPois, activePois, totalNarrations, totalLanguages;
    private int todayQrScans, totalUsers, totalVendors;
    private List<TopPoiItem> topPois = new();
    private List<TopAudioItem> topAudio = new();

    // ── Admin stats – hành vi ────────────────
    private int totalEvents, avgListenSec, totalReviews;
    private List<LangStat> languageStats = new();
    private Dictionary<int, int> ratingDistribution = new();

    // ── Vendor stats ─────────────────────────
    private string vendorPoiName = "Chủ quán";
    private int vendorQrScans, vendorReviewCount, vendorMenuCount;
    private double vendorAvgRating;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var role = user.FindFirst(ClaimTypes.Role)?.Value;

            if (role == "Admin")
                await LoadAdminStats();
            else if (role == "Vendor")
                await LoadVendorStats(user);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[HOME] Load error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadAdminStats()
    {
        var today = DateTime.Today;

        totalPois     = await Db.Pois.CountAsync();
        activePois    = await Db.Pois.CountAsync(p => p.IsActive);
        totalNarrations = await Db.Narrations.CountAsync();
        totalLanguages  = await Db.Languages.CountAsync(l => l.IsActive);
        totalUsers    = await Db.Users.CountAsync();
        totalVendors  = await Db.Users.CountAsync(u => u.Role == "Vendor");
        todayQrScans  = await Db.TrackingLogs
            .CountAsync(t => t.EventType == "qr_scan" && t.CreatedAt >= today);

        totalEvents = await Db.TrackingLogs.CountAsync();

        var listenLogs = Db.TrackingLogs.Where(t => t.EventType == "listen_end" && t.ListenedDurationSec != null);
        if (await listenLogs.AnyAsync())
            avgListenSec = (int)await listenLogs.AverageAsync(t => t.ListenedDurationSec!.Value);

        // Top POIs
        topPois = await Db.TrackingLogs
            .Where(t => t.PoiId != null && (t.EventType == "enter" || t.EventType == "qr_scan"))
            .GroupBy(t => t.PoiId)
            .Select(g => new TopPoiItem { PoiId = g.Key!.Value, EventCount = g.Count() })
            .OrderByDescending(x => x.EventCount)
            .Take(5)
            .ToListAsync();

        var poiIds = topPois.Select(x => x.PoiId).ToList();
        var poiNames = await Db.Pois
            .Where(p => poiIds.Contains(p.PoiId))
            .ToDictionaryAsync(p => p.PoiId, p => p.Name);

        foreach (var item in topPois)
            item.PoiName = poiNames.GetValueOrDefault(item.PoiId, "N/A");

        // Top Audio
        topAudio = await Db.TrackingLogs
            .Where(t => t.PoiId != null && t.EventType == "listen_end" && t.ListenedDurationSec != null)
            .GroupBy(t => t.PoiId)
            .Select(g => new TopAudioItem
            {
                PoiId = g.Key!.Value,
                TotalMinutes = (int)(g.Sum(t => t.ListenedDurationSec!.Value) / 60.0)
            })
            .OrderByDescending(x => x.TotalMinutes)
            .Take(5)
            .ToListAsync();

        foreach (var item in topAudio)
            item.PoiName = poiNames.GetValueOrDefault(item.PoiId, "N/A");

        // Ngôn ngữ
        var langCounts = await Db.TrackingLogs
            .Where(t => t.LanguageCode != null)
            .GroupBy(t => t.LanguageCode)
            .Select(g => new { Code = g.Key!, Count = g.Count() })
            .ToListAsync();

        var total = langCounts.Sum(l => l.Count);
        var langNames = await Db.Languages.ToDictionaryAsync(l => l.Code, l => l.Name);

        languageStats = langCounts
            .OrderByDescending(l => l.Count)
            .Select(l => new LangStat
            {
                Code = l.Code,
                Name = langNames.GetValueOrDefault(l.Code, l.Code),
                Percent = total > 0 ? (int)(l.Count * 100.0 / total) : 0
            })
            .ToList();

        // Reviews
        totalReviews = await Db.Reviews.CountAsync();
        ratingDistribution = await Db.Reviews
            .GroupBy(r => (int)r.Rating)
            .ToDictionaryAsync(g => g.Key, g => g.Count());
    }

    private async Task LoadVendorStats(ClaimsPrincipal user)
    {
        var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(userIdStr, out int userId)) return;

        var poi = await PoiService.GetPoiByOwnerIdAsync(userId);
        if (poi == null) return;

        vendorPoiName = poi.Name;
        var today = DateTime.Today;

        vendorQrScans = await Db.TrackingLogs
            .CountAsync(t => t.PoiId == poi.PoiId && t.EventType == "qr_scan" && t.CreatedAt >= today);

        var reviews = Db.Reviews.Where(r => r.PoiId == poi.PoiId);
        vendorReviewCount = await reviews.CountAsync();
        if (vendorReviewCount > 0)
            vendorAvgRating = await reviews.AverageAsync(r => (double)r.Rating);

        vendorMenuCount = await Db.Foods.CountAsync(f => f.PoiId == poi.PoiId && f.IsAvailable);
    }

    private class TopPoiItem
    {
        public int PoiId { get; set; }
        public string PoiName { get; set; } = "N/A";
        public int EventCount { get; set; }
    }

    private class TopAudioItem
    {
        public int PoiId { get; set; }
        public string PoiName { get; set; } = "N/A";
        public int TotalMinutes { get; set; }
    }

    private class LangStat { public string Code = ""; public string Name = ""; public int Percent; }
}
