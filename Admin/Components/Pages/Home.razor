@page "/"
@rendermode InteractiveServer

<PageTitle>Dashboard - Vĩnh Khánh Admin</PageTitle>

<div class="page-content p-4" style="background-color: #262121; min-height: 100vh;">
    @* --- TOP HEADER --- *@
    <div class="d-flex justify-content-between align-items-center mb-5 border-bottom pb-3">
        <h3 class="mb-0" style="color: #F0EBE3;">Tổng quan Portal</h3>
        <div class="d-flex align-items-center gap-3">
            <div class="position-relative">
                <input type="text" class="form-control rounded-pill border-0 shadow-sm ps-4" placeholder="Tìm kiếm..." style="background-color: #1A1818; color: #F0EBE3;">
                <span class="bi bi-search position-absolute text-muted" style="top: 10px; right: 15px;"></span>
            </div>
            <button class="btn btn-link text-muted position-relative">
                <span class="bi bi-bell fs-5"></span>
                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
            </button>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-danger rounded-circle p-3 fs-6">A</span>
                <div class="small">
                    <strong>Admin</strong><br>
                    <small class="text-muted">Quản trị viên</small>
                </div>
            </div>
        </div>
    </div>

    @* --- STATISTICS CARDS --- *@
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="stats-card d-flex align-items-center p-4">
                <span class="bi bi-shop fs-1 me-3 p-3 bg-light-danger rounded-3"></span>
                <div>
                    <div class="small text-muted mb-1">Tổng Gian hàng</div>
                    <div class="fs-2 fw-bold" style="color: #E8A020;">6<small class="text-muted fs-6"> / 25</small></div>
                    <div class="text-muted" style="font-size: 11px;">(Đã gán: 100%)</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card d-flex align-items-center p-4">
                <span class="bi bi-headset fs-1 me-3 p-3 bg-light-amber rounded-3"></span>
                <div>
                    <div class="small text-muted mb-1">Bài thuyết minh</div>
                    <div class="fs-2 fw-bold text-success">15+</div>
                    <div class="text-muted" style="font-size: 11px;">(3 ngôn ngữ dịch)</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card d-flex align-items-center p-4">
                <span class="bi bi-qr-code fs-1 me-3 p-3 bg-light-secondary rounded-3"></span>
                <div>
                    <div class="small text-muted mb-1">Mã QR hoạt động</div>
                    <div class="fs-2 fw-bold text-info">25+</div>
                    <div class="text-muted" style="font-size: 11px;">(Đã quét: 120+)</div>
                </div>
            </div>
        </div>
    </div>

    @* --- LOWER SECTION (Map and Activity) --- *@
    <div class="row g-3">
        <div class="col-md-8">
            <div class="content-card p-4">
                <h5 class="mb-3 border-bottom pb-2">Vị trí điểm Gian hàng (Overview)</h5>
                @* Simplified Map view like mobile app but plain, as we don't need real time here *@
                <div class="map-placeholder d-flex justify-content-center align-items-center" style="height: 250px;">
                    <span class="bi bi-geo-alt fs-1 text-muted me-2"></span>
                    <span class="text-muted fs-6">Bản đồ đang tải...</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="content-card p-4">
                <h5 class="mb-3 border-bottom pb-2">Hỗ trợ Ngôn ngữ</h5>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2 fs-6">VI <small class="text-muted">(Tiếng Việt)</small></span>
                    <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-2 fs-6">EN <small class="text-muted">(English)</small></span>
                    <span class="badge bg-light text-muted rounded-pill px-3 py-2 fs-6">ZH <small>(中文)</small></span>
                    <span class="badge bg-light text-muted rounded-pill px-3 py-2 fs-6">KR <small>(한국어)</small></span>
                    <span class="badge bg-light text-muted rounded-pill px-3 py-2 fs-6">JA <small>(日本語)</small></span>
                </div>
            </div>
        </div>
    </div>
</div>