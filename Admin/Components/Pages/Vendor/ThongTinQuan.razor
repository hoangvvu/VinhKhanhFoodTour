@page "/vendor/thong-tin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Data
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject AuthenticationStateProvider AuthStateProvider
@inject PoiService PoiService
@implements IDisposable

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">THÔNG TIN QUÁN & HÌNH ẢNH</h3>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="SaveChanges" disabled="@isSaving">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            <i class="bi bi-floppy me-2"></i>Lưu thay đổi
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
            <i class="@(isError ? "bi bi-exclamation-triangle-fill" : "bi bi-check-circle-fill") me-2"></i>
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card bg-dark-card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                <div class="card-body p-4">
                    <h5 class="text-white mb-4"><i class="bi bi-info-circle me-2 text-danger"></i>Thông tin chung</h5>
                    
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">TÊN GIAN HÀNG</label>
                        <input type="text" class="form-control bg-dark border-secondary text-white p-3"
                               @bind="poiName" placeholder="VD: Ốc Oanh Vĩnh Khánh...">
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">MÔ TẢ NGẮN</label>
                            <textarea class="form-control bg-dark border-secondary text-white p-3" rows="4"
                                      @bind="poiDescription" placeholder="Giới thiệu về quán của bạn..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">ĐỊA CHỈ CHI TIẾT</label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-geo-alt"></i></span>
                                <input type="text" class="form-control bg-dark border-secondary text-white p-3"
                                       @bind="poiAddress" placeholder="Số nhà, tên đường...">
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label text-muted small fw-bold">VĨ ĐỘ (LATITUDE)</label>
                                    <input type="text" class="form-control bg-dark border-secondary text-white" @bind="latitude" readonly>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label text-muted small fw-bold">KINH ĐỘ (LONGITUDE)</label>
                                        <input type="text" class="form-control bg-dark border-secondary text-white" @bind="longitude" readonly>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card bg-dark-card border-0 shadow-sm" style="border-radius: 16px;">
                                <div class="card-body p-0" style="height: 400px; border-radius: 16px; overflow: hidden;">
                                    <div id="map" style="height: 400px; width: 100%; min-height: 400px; background-color: #1a1a1a; border-radius: 12px;"></div>
                                </div>
                                <div class="card-footer bg-transparent border-0 text-center pb-3">
                                    <small class="text-muted"><i class="bi bi-mouse me-1"></i>Kéo thả dấu ghim để cập nhật vị trí chính xác của quán</small>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div class="card bg-dark-card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                                <div class="card-body p-4 text-center">
                                    <h5 class="text-white mb-4 text-start"><i class="bi bi-image me-2 text-danger"></i>Ảnh đại diện quán</h5>
                    
                                    <div class="image-preview-container mb-3 position-relative mx-auto"
                                         style="width: 100%; height: 250px; background: #1a1a1a; border-radius: 12px; overflow: hidden; border: 2px dashed #444;">
                                        @if (!string.IsNullOrEmpty(mainImageUrl))
                                        {
                                            <img src="@mainImageUrl" style="width: 100%; height: 100%; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                                                <i class="bi bi-cloud-arrow-up fs-1"></i>
                                                <span>Chưa có ảnh</span>
                                            </div>
                                        }
                                    </div>

                                    <div class="mb-3">
                                        <InputFile OnChange="HandleImageUpload" class="form-control bg-dark border-secondary text-white" accept="image/*" />
                                        <div class="form-text text-muted mt-2">Dung lượng tối đa 10MB (.jpg, .png, .webp)</div>
                                    </div>
                                </div>
                            </div>

                            <div class="card bg-dark-card border-0 shadow-sm" style="border-radius: 16px;">
                                <div class="card-body p-4">
                                    <h5 class="text-white mb-3"><i class="bi bi-qr-code me-2 text-danger"></i>Mã định danh (QR Token)</h5>
                                    <div class="p-3 bg-dark rounded border border-secondary text-center">
                                        <span class="text-danger fw-bold fs-5">@qrCode</span>
                                    </div>
                                    <p class="text-muted small mt-2 mb-0">Mã này dùng để hệ thống nhận diện khi khách quét QR tại quán của bạn.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

@code {
    private string poiName = "";
    private string poiDescription = "";
    private string poiAddress = "";
    private double latitude = 10.7578; // Mặc định Vĩnh Khánh
    private double longitude = 106.7095;
    private string qrCode = "N/A";
    private string mainImageUrl = "";
    
    private int currentPoiId;
    private bool isSaving = false;
    private bool isError = false;
    private string? statusMessage;
    private DotNetObjectReference<ThongTinQuan>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDataAsync();
            dotNetRef = DotNetObjectReference.Create(this);
            
            // ĐÃ SỬA: Bọc try-catch chống sập giao diện
            try
            {
                await JS.InvokeVoidAsync("initMapPicker", "map", latitude, longitude, dotNetRef);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[CẢNH BÁO MAP]: Google Maps chưa sẵn sàng. Lỗi: {ex.Message}");
            }
        }
    }

    private async Task LoadDataAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userIdStr, out int userId))
        {
            var poi = await PoiService.GetPoiByOwnerIdAsync(userId);
            if (poi != null)
            {
                currentPoiId = poi.PoiId;
                poiName = poi.Name;
                poiDescription = poi.Description;
                poiAddress = poi.Address;
                latitude = (double)poi.Latitude;   // Ép kiểu ngược lại sang double cho Google Maps
                longitude = (double)poi.Longitude; // Ép kiểu ngược lại sang double
                
                // Lấy mã QR đầu tiên của quán (nếu có)
                qrCode = poi.QrCodes.FirstOrDefault()?.QrToken ?? "Chưa tạo mã QR";
                
                mainImageUrl = poi.ImageUrl;
                StateHasChanged();
            }
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        try
        {
            // Bảo vệ: Nếu thoát cửa sổ chọn ảnh mà không chọn gì
            if (e.FileCount == 0) return;

            var file = e.File;
            isSaving = true;
            statusMessage = "Đang tải ảnh...";
            isError = false;
            StateHasChanged();

            var ext = Path.GetExtension(file.Name).ToLower();
            var fileName = $"stall_{currentPoiId}_{Guid.NewGuid()}{ext}";
            
            // Đường dẫn tuyệt đối an toàn
            var folder = Path.GetFullPath(Path.Combine(Env.ContentRootPath, "..", "UploadsData", "poi"));
            if (!Directory.Exists(folder)) Directory.CreateDirectory(folder);

            var path = Path.Combine(folder, fileName);

            // Ghi file trực tiếp (Streaming) để không tốn RAM
            await using FileStream fs = new(path, FileMode.Create);
            await file.OpenReadStream(maxAllowedSize: 15 * 1024 * 1024).CopyToAsync(fs);

            mainImageUrl = $"/uploads/poi/{fileName}";
            statusMessage = "Tải ảnh lên thành công!";
        }
        catch (Exception ex)
        {
            statusMessage = $"Lỗi upload: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task SaveChanges()
    {
        if (string.IsNullOrWhiteSpace(poiName))
        {
            statusMessage = "Tên quán không được để trống.";
            isError = true;
            return;
        }

        isSaving = true;
        statusMessage = null;

        try
        {
            // Gọi Service để cập nhật dữ liệu vào SQL Server
            var result = await PoiService.UpdateStallInfoAsync(currentPoiId, poiName, poiDescription, poiAddress, latitude, longitude, mainImageUrl);
            
            if (result)
            {
                statusMessage = "Đã cập nhật thông tin quán thành công!";
                isError = false;
            }
            else
            {
                statusMessage = "Có lỗi xảy ra khi lưu vào cơ sở dữ liệu.";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Lỗi hệ thống: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    [JSInvokable]
    public void OnMapLocationChanged(double lat, double lng)
    {
        latitude = lat;
        longitude = lng;
        StateHasChanged();
    }

    public void Dispose()
    {
        dotNetRef?.Dispose();
    }
}