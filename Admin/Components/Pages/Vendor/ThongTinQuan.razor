@page "/vendor/thong-tin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Entities
@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject AuthenticationStateProvider AuthStateProvider
@inject PoiService PoiService
@inject TtsService TtsService
@implements IDisposable

<div class="dash-page p-4">
    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">THÔNG TIN GIAN HÀNG</h2>
            <div class="d-flex align-items-center gap-2">
                @if (poiStatus == "Approved")
                {
                    <span style="color: #4ade80; font-size: 13px;"><i class="bi bi-patch-check-fill me-1"></i>Đối tác chính thức (Đã duyệt)</span>
                }
                else if (poiStatus == "Rejected")
                {
                    <span style="color: #f87171; font-size: 13px;"><i class="bi bi-x-circle-fill me-1"></i>Bị từ chối - Cần cập nhật</span>
                }
                else
                {
                    <span style="color: #fbbf24; font-size: 13px;"><i class="bi bi-hourglass-split me-1"></i>Đang chờ phê duyệt</span>
                }
                <span class="text-muted" style="font-size: 13px;">•</span>
                <span style="color: #4a4a5a; font-size: 13px;">Mã QR: <strong style="color:#F0EBE3;">@qrCode</strong></span>
                @if (isLocked)
                {
                    <span class="ms-2 badge bg-danger rounded-pill" style="font-size: 11px; padding: 5px 12px;"><i class="bi bi-lock-fill me-1"></i>ĐÃ BỊ ADMIN KHÓA</span>
                }
            </div>
        </div>
        <div class="d-flex gap-3">
            <button class="btn btn-outline-light rounded-pill px-4" @onclick="LoadDataAsync">
                <i class="bi bi-arrow-clockwise me-2"></i>Làm mới
            </button>
            
            @if (poiStatus != "Approved")
            {
                <button class="btn btn-warning rounded-pill px-4 shadow text-dark fw-bold" @onclick="RequestApproval" disabled="@(isSaving || string.IsNullOrWhiteSpace(poiAddress) || isLocked)">
                    <i class="bi bi-send-check me-2"></i>Gửi yêu cầu duyệt
                </button>
            }

            <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="SaveChanges" disabled="@(isSaving || isLocked)">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="bi bi-floppy me-2"></i>Lưu thông tin
            </button>
        </div>
    </div>

    @if (isLocked)
    {
        <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4 p-4" style="background: rgba(220, 38, 38, 0.15); border-left: 5px solid #dc2626 !important;">
            <div class="d-flex align-items-center">
                <i class="bi bi-lock-fill me-3 fs-3 text-danger"></i>
                <div>
                    <h5 class="fw-bold text-white mb-1">GIAN HÀNG ĐANG BỊ KHÓA</h5>
                    <p class="mb-0 text-white-50">Gian hàng của bạn hiện đang bị Admin tạm khóa. Bạn không thể thực hiện thay đổi thông tin hay gửi yêu cầu duyệt vào lúc này.</p>
                </div>
            </div>
        </div>
    }

    @if (poiStatus == "Rejected" && !string.IsNullOrEmpty(rejectionNote))
    {
        <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4 p-4" style="background: rgba(220, 38, 38, 0.1);">
            <div class="d-flex align-items-start">
                <i class="bi bi-exclamation-octagon-fill me-3 fs-4" style="color: #f87171;"></i>
                <div>
                    <h6 class="fw-bold text-white mb-1">Ghi chú từ Quản trị viên:</h6>
                    <p class="mb-0" style="color: #fca5a5;">@rejectionNote</p>
                    <small class="d-block mt-2" style="opacity: 0.7; color: #fff;">Vui lòng chỉnh sửa lại thông tin theo yêu cầu và gửi duyệt lại.</small>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show border-0 rounded-4 shadow-sm mb-4" role="alert" 
             style="background: @(isError ? "rgba(200,55,45,0.1)" : "rgba(34,197,94,0.1)"); color: @(isError ? "#f87171" : "#4ade80");">
            <i class="bi @(isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="row g-4 @(poiStatus == "Approved" && !isSaving ? "" : "")">
        <!-- CỘT TRÁI: THÔNG TIN CƠ BẢN -->
        <div class="col-lg-7">
            <!-- THÔNG TIN CHUNG -->
            <div class="dash-card p-4 mb-4">
                <div class="dash-label mb-4 d-flex align-items-center">
                    <div class="icon-box me-3"><i class="bi bi-shop"></i></div>
                    NỘI DUNG GỐC (TIẾNG VIỆT)
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold mb-2">TÊN GIAN HÀNG</label>
                    <input type="text" class="form-control dash-input p-3"
                           @bind="poiName" @bind:event="oninput" placeholder="VD: Ốc Oanh Vĩnh Khánh..." disabled="@(poiStatus == "Approved" || isLocked)">
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold mb-2">GIỚI THIỆU QUÁN (MÔ TẢ)</label>
                    <textarea class="form-control dash-input p-3" rows="6"
                               @bind="poiDescription" @bind:event="oninput"
                               placeholder="Hãy viết mô tả hấp dẫn về món ăn và dịch vụ tại quán của bạn..." disabled="@(poiStatus == "Approved" || isLocked)"></textarea>
                    <div class="form-text text-muted mt-2">Nội dung này sẽ được Admin sử dụng để tự động dịch và tạo giọng đọc AI.</div>
                </div>

                <div class="mb-0">
                    <label class="form-label text-muted small fw-bold mb-2">ĐỊA CHỈ</label>
                    <div class="input-group">
                        <span class="input-group-text dash-input border-end-0" style="background:#0f0f13; border-radius: 12px 0 0 12px;"><i class="bi bi-geo-alt"></i></span>
                        <input type="text" class="form-control dash-input p-3"
                               @bind="poiAddress" placeholder="Số nhà, tên đường Vĩnh Khánh..." disabled="@(poiStatus == "Approved" || isLocked)">
                    </div>
                </div>
            </div>

            <div class="dash-card p-4">
                <div class="dash-label mb-4 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="icon-box me-3"><i class="bi bi-map"></i></div>
                        VỊ TRÍ TRÊN BẢN ĐỒ
                    </div>
                    <div class="flex-grow-1 ms-4 position-relative">
                        <div class="alert alert-info border-0 rounded-3 mb-3 p-2" style="background: rgba(59, 130, 246, 0.1); color: #60a5fa; font-size: 11px;">
                            <i class="bi bi-info-circle me-1"></i>
                            Mẹo: <a href="https://www.google.com/maps" target="_blank" class="text-white text-decoration-underline fw-bold mx-1">Mở Google Maps</a> tìm quán, <strong>Copy link</strong> rồi <strong>Paste</strong> vào ô dưới để định vị nhanh nhất.
                        </div>
                        <div class="input-group shadow-sm">
                            <span class="input-group-text bg-black border-secondary border-end-0 text-muted" style="border-radius: 12px 0 0 12px;"><i class="bi bi-search"></i></span>
                            <input type="text" id="map-search-input" class="form-control bg-black border-secondary text-white p-2 border-end-0" 
                                   placeholder="Gõ địa chỉ để tìm kiếm..." style="border-radius: 0; font-size: 13px;" autocomplete="off"
                                   @bind="mapSearchQuery" @bind:event="oninput" @onkeyup="HandleSearchKeyUp" disabled="@(poiStatus == "Approved" || isLocked)">
                            <button class="btn btn-danger px-3" type="button" id="map-search-btn" style="border-radius: 0 12px 12px 0;"
                                    @onclick="HandleSearchClick" disabled="@(poiStatus == "Approved" || isLocked)">
                                <i class="bi bi-geo-alt-fill me-1"></i> Tìm
                            </button>
                        </div>
                        <!-- Container gợi ý địa chỉ -->
                        <ul id="map-suggestions" class="suggestion-list"></ul>
                    </div>
                </div>
                <div style="height: 400px; border-radius: 20px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05);">
                    <div id="map" style="height: 100%; width: 100%; background-color: #1a1a1a;"></div>
                </div>
                <div class="text-center mt-3 d-flex align-items-center justify-content-center gap-3">
                    <small style="color:#4a4a5a;"><i class="bi bi-info-circle me-1"></i>Kéo thả điểm ghim hoặc tìm địa chỉ để cập nhật vị trí</small>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: MULTIMEDIA & AUTOMATION -->
        <div class="col-lg-5">
            <!-- ẢNH BÌA -->
            <div class="dash-card p-4 mb-4">
                <div class="dash-label mb-4 d-flex align-items-center">
                    <div class="icon-box me-3"><i class="bi bi-images"></i></div>
                    ẢNH BÌA GIAN HÀNG
                </div>
                
                <div class="position-relative mb-3 rounded-4 overflow-hidden shadow-sm" style="height: 200px; background:#0f0f13; border: 1px solid rgba(255,255,255,0.05);">
                    @if (!string.IsNullOrEmpty(mainImageUrl))
                    {
                        <img src="@mainImageUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="Cover" />
                    }
                    else
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                            <i class="bi bi-image fs-1 opacity-25"></i>
                            <span class="small mt-2">Chưa có ảnh bìa</span>
                        </div>
                    }
                </div>
                <InputFile OnChange="HandleCoverUpload" class="form-control dash-input rounded-pill" accept="image/*" disabled="@(poiStatus == "Approved" || isLocked)" />
            </div>

            <!-- THƯ VIỆN ẢNH -->
            <div class="dash-card p-4">
                <div class="dash-label mb-4 d-flex align-items-center">
                    <div class="icon-box me-3"><i class="bi bi-grid-3x3-gap"></i></div>
                    THƯ VIỆN ẢNH
                </div>
                <InputFile OnChange="HandleGalleryUpload" class="form-control dash-input rounded-pill mb-3" accept="image/*" multiple disabled="@(poiStatus == "Approved" || isLocked)" />
                <div class="row g-2">
                    @foreach (var g in galleryImages)
                    {
                        <div class="col-4">
                            <div class="position-relative rounded-3 overflow-hidden shadow-sm" style="aspect-ratio: 1; border: 1px solid rgba(255,255,255,0.05);">
                                <img src="@g.ImageUrl" class="w-100 h-100 object-fit-cover" alt="" />
                                @if (poiStatus != "Approved" && !isLocked)
                                {
                                    <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 p-0 d-flex align-items-center justify-content-center"
                                            style="width: 20px; height: 20px; border-radius: 5px;"
                                            @onclick="() => RemoveGalleryAsync(g.ImageId)">
                                        <i class="bi bi-x" style="font-size: 14px;"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- TRẠNG THÁI AUDIO ĐA NGÔN NGỮ -->
            <div class="dash-card p-4 mt-4">
                <div class="dash-label mb-3 d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="icon-box me-3"><i class="bi bi-translate"></i></div>
                        AUDIO ĐA NGÔN NGỮ (QR)
                    </div>
                    @if (poiStatus != "Approved" && !isLocked)
                    {
                        <button class="btn btn-sm btn-outline-warning rounded-pill" @onclick="SyncAudioAsync" disabled="@isSaving">
                            <i class="bi bi-arrow-repeat me-1"></i> Làm mới
                        </button>
                    }
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var lang in activeLanguages)
                    {
                        var nar = galleryImages.FirstOrDefault()?.Poi?.Narrations?.FirstOrDefault(n => n.LanguageId == lang.LanguageId && n.IsActive);
                        // Do galleryImages.FirstOrDefault()?.Poi có thể null nếu view_file chưa load đủ, ta dùng currentPoiNarrations
                        var hasAudio = currentPoiNarrations.Any(n => n.LanguageId == lang.LanguageId && (!string.IsNullOrEmpty(n.AudioUrlQr) || !string.IsNullOrEmpty(n.AudioUrlAuto)));
                        
                        <div class="d-flex align-items-center bg-black border border-secondary rounded-pill px-3 py-1" style="font-size: 12px;">
                            <i class="bi @(hasAudio ? "bi-check-circle-fill text-success" : "bi-clock text-muted") me-2"></i>
                            <span class="text-white me-2">@lang.Code.ToUpper()</span>
                            <span class="text-muted small">@lang.Name</span>
                        </div>
                    }
                </div>
                <div class="mt-3 small text-muted">
                    <i class="bi bi-info-circle me-1"></i> Audio được tự động tạo từ mô tả quán sau khi Admin duyệt hoặc khi bạn nhấn "Làm mới".
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .icon-box {
        width: 32px;
        height: 32px;
        background: rgba(200, 55, 45, 0.1);
        color: #C8372D;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
    }
    .dash-input {
        background: #0f0f13 !important;
        border: 1px solid rgba(255,255,255,0.08) !important;
        color: #F0EBE3 !important;
    }
    .suggestion-list {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #1a1a1b;
        border: 1px solid #C8372D;
        border-radius: 12px;
        margin-top: 8px;
        padding: 0;
        list-style: none;
        z-index: 2000;
        box-shadow: 0 10px 40px rgba(0,0,0,0.8);
        display: none;
        max-height: 350px;
        overflow-y: auto;
    }
    .suggestion-item {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        cursor: pointer;
        border-bottom: 1px solid #2d2d2d;
    }
    .suggestion-item:hover { background: #2d2d2d; }
</style>

@code {
    private string poiName = "";
    private string poiDescription = "";
    private string poiAddress = "";
    private string poiStatus = "Pending";
    private string? rejectionNote;
    private List<Narration> currentPoiNarrations = new();
    private List<Language> activeLanguages = new();
    private double latitude = 10.7578;
    private double longitude = 106.7095;
    private string qrCode = "N/A";
    private string mainImageUrl = "";
    private List<Image> galleryImages = new();
    private List<LangStatusItem> langStatuses = new();
    private int currentPoiId;
    private int currentUserId;
    private bool isSaving;
    private bool isLocked;
    private bool isError;
    private string? statusMessage;
    private DotNetObjectReference<ThongTinQuan>? dotNetRef;
    private string? mapSearchQuery;

    private async Task HandleSearchClick()
    {
        if (string.IsNullOrWhiteSpace(mapSearchQuery)) return;
        await JS.InvokeVoidAsync("triggerMapSearch", mapSearchQuery, "map-suggestions");
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleSearchClick();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadDataAsync();
        dotNetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("initMapPicker", "map", latitude, longitude, "map-search-input", "map-search-btn", "map-suggestions", dotNetRef);
        }
        catch (Exception ex) { Console.WriteLine($"[MAP]: {ex.Message}"); }
    }

    private async Task LoadDataAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(userIdStr, out var userId)) return;
        currentUserId = userId;

        var poi = await PoiService.GetPoiByOwnerIdAsync(userId);
        if (poi is null)
        {
            poi = await PoiService.EnsureVendorPoiAsync(userId, authState.User.Identity?.Name ?? "Quán mới");
        }

        currentPoiId = poi.PoiId;
        poiName = poi.Name;
        poiDescription = poi.Description ?? "";
        poiAddress = poi.Address ?? "";
        poiStatus = poi.Status ?? "Pending";
        isLocked = !poi.IsActive && poiStatus == "Approved";
        rejectionNote = poi.RejectionNote;
        latitude = (double)poi.Latitude;
        longitude = (double)poi.Longitude;

        currentPoiNarrations = poi.Narrations?.ToList() ?? new();
        activeLanguages = await PoiService.GetActiveLanguagesAsync();

        var firstQr = poi.QrCodes.OrderByDescending(q => q.IsActive).FirstOrDefault();
        qrCode = firstQr?.QrToken ?? "Chờ cấp";
        mainImageUrl = poi.ImageUrl ?? "";
        galleryImages = poi.Images?.ToList() ?? new();

        StateHasChanged();
    }

    private async Task SyncAudioAsync()
    {
        if (currentPoiId == 0) return;
        isSaving = true;
        StateHasChanged();
        try
        {
            // forceRefresh = true để ghi đè audio khi người dùng nhấn "Làm mới"
            await PoiService.UpdateMultilingualNarrationsAsync(currentPoiId, forceRefresh: true);
            statusMessage = "Đã làm mới dữ liệu Audio.";
            isError = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { statusMessage = ex.Message; isError = true; }
        finally { isSaving = false; StateHasChanged(); }
    }

    private async Task SaveChanges()
    {
        if (string.IsNullOrWhiteSpace(poiName))
        {
            statusMessage = "Tên quán không được để trống.";
            isError = true;
            return;
        }
        isSaving = true;
        try
        {
            var ok = await PoiService.UpdateStallInfoAsync(currentPoiId, poiName, poiDescription, poiAddress, latitude, longitude, mainImageUrl);
            if (!ok) { statusMessage = "Lưu thất bại."; isError = true; }
            else { 
                statusMessage = "Đã lưu thay đổi thành công!"; 
                isError = false;
                _ = Task.Run(() => PoiService.UpdateMultilingualNarrationsAsync(currentPoiId));
                await LoadDataAsync();
            }
        }
        catch (Exception ex) { statusMessage = ex.Message; isError = true; }
        finally { isSaving = false; }
    }

    private async Task RequestApproval()
    {
        if (string.IsNullOrWhiteSpace(poiAddress) || latitude == 0)
        {
            statusMessage = "Vui lòng nhập địa chỉ và chọn vị trí trên bản đồ trước khi gửi duyệt.";
            isError = true;
            return;
        }
        isSaving = true;
        try
        {
            await PoiService.UpdateStallInfoAsync(currentPoiId, poiName, poiDescription, poiAddress, latitude, longitude, mainImageUrl);
            
            var ok = await PoiService.RequestApprovalAsync(currentPoiId);
            if (ok)
            {
                statusMessage = "Đã gửi yêu cầu phê duyệt thành công. Vui lòng chờ Admin xử lý.";
                isError = false;
                await LoadDataAsync();
            }
            else
            {
                statusMessage = "Không thể gửi yêu cầu lúc này.";
                isError = true;
            }
        }
        catch (Exception ex) { statusMessage = ex.Message; isError = true; }
        finally { isSaving = false; }
    }

    private async Task HandleCoverUpload(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || currentPoiId == 0) return;
        try
        {
            isSaving = true;
            var file = e.File;
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            var fileName = $"stall_cover_{currentPoiId}_{Guid.NewGuid():N}{ext}";
            var folder = Path.GetFullPath(Path.Combine(Env.ContentRootPath, "..", "UploadsData", "poi"));
            Directory.CreateDirectory(folder);
            await using var fs = new FileStream(Path.Combine(folder, fileName), FileMode.Create);
            await file.OpenReadStream(15 * 1024 * 1024).CopyToAsync(fs);
            mainImageUrl = $"/uploads/poi/{fileName}";
            StateHasChanged();
        }
        catch (Exception ex) { statusMessage = $"Lỗi upload: {ex.Message}"; isError = true; }
        finally { isSaving = false; }
    }

    private async Task HandleGalleryUpload(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || currentPoiId == 0) return;
        try
        {
            isSaving = true;
            foreach (var file in e.GetMultipleFiles(20))
            {
                var ext = Path.GetExtension(file.Name).ToLowerInvariant();
                var fileName = $"stall_gal_{currentPoiId}_{Guid.NewGuid():N}{ext}";
                var folder = Path.GetFullPath(Path.Combine(Env.ContentRootPath, "..", "UploadsData", "poi"));
                Directory.CreateDirectory(folder);
                var path = Path.Combine(folder, fileName);
                await using var fs = new FileStream(path, FileMode.Create);
                await file.OpenReadStream(15 * 1024 * 1024).CopyToAsync(fs);
                var url = $"/uploads/poi/{fileName}";
                await PoiService.AddStallGalleryImageAsync(currentPoiId, currentUserId, url);
            }
            galleryImages = await PoiService.GetStallGalleryAsync(currentPoiId, currentUserId);
            statusMessage = "Đã lưu thay đổi thành công!";
            isError = false;
            _ = Task.Run(() => PoiService.UpdateMultilingualNarrationsAsync(currentPoiId));
            await LoadDataAsync();
        }
        catch (Exception ex) { statusMessage = ex.Message; isError = true; }
        finally { isSaving = false; }
    }

    private async Task RemoveGalleryAsync(int id)
    {
        await PoiService.RemoveStallGalleryImageAsync(id, currentUserId);
        galleryImages = await PoiService.GetStallGalleryAsync(currentPoiId, currentUserId);
    }

    [JSInvokable] public void OnMapLocationChanged(double lat, double lng) { latitude = lat; longitude = lng; StateHasChanged(); }
    
    [JSInvokable] public void OnAddressSearchSelected(string formattedAddress) { poiAddress = formattedAddress; StateHasChanged(); }

    public void Dispose() => dotNetRef?.Dispose();

    private class LangStatusItem {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public bool IsReady { get; set; }
    }
}
