@page "/vendor/thong-tin"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@implements IDisposable

@* ══════════════════════════════════════════════════════════
   THÔNG TIN QUÁN & HÌNH ẢNH
   - Google Maps picker để chọn vị trí
   - Upload ảnh lưu vào wwwroot/uploads/poi
   ══════════════════════════════════════════════════════════ *@

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">THÔNG TIN QUÁN & HÌNH ẢNH</h3>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="SaveChanges" disabled="@isSaving">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            <i class="bi bi-floppy me-2"></i>Lưu thay đổi
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show"
             style="border-radius: 12px;">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = string.Empty"></button>
        </div>
    }

    <div class="row g-4">
        @* ══════════════ CỘT TRÁI: THÔNG TIN + BẢN ĐỒ ══════════════ *@
        <div class="col-lg-6">
            @* ── Thông tin cơ bản ── *@
            <div class="card bg-dark-card border-0 p-4 shadow-sm mb-4" style="border-radius: 16px;">
                <h6 class="text-warning fw-bold mb-4 border-bottom border-secondary pb-2">
                    THÔNG TIN CƠ BẢN
                </h6>

                <div class="mb-3">
                    <label class="text-muted small fw-bold">Tên quán ăn</label>
                    <input type="text" class="form-control bg-black border-secondary text-white"
                           @bind="poiName" />
                </div>
                <div class="mb-3">
                    <label class="text-muted small fw-bold">Số điện thoại</label>
                    <input type="text" class="form-control bg-black border-secondary text-white"
                           @bind="poiPhone" placeholder="VD: 0901234567" />
                </div>
                <div class="mb-3">
                    <label class="text-muted small fw-bold">Địa chỉ chi tiết</label>
                    <input type="text" class="form-control bg-black border-secondary text-white"
                           @bind="poiAddress" />
                </div>
                <div class="mb-3">
                    <label class="text-muted small fw-bold">Giới thiệu ngắn (hiển thị trên App)</label>
                    <textarea class="form-control bg-black border-secondary text-white" rows="3"
                              @bind="poiDescription"></textarea>
                </div>
            </div>

            @* ── Bản đồ chọn vị trí ── *@
            <div class="card bg-dark-card border-0 p-4 shadow-sm" style="border-radius: 16px;">
                <h6 class="text-info fw-bold mb-3 border-bottom border-secondary pb-2">
                    <i class="bi bi-geo-alt me-2"></i>VỊ TRÍ TRÊN BẢN ĐỒ
                </h6>
                <p class="text-muted small mb-3">
                    Bấm vào bản đồ hoặc kéo thả ghim đỏ để xác định vị trí quán.
                </p>

                @* Container cho Google Maps *@
                <div id="mapPicker"
                     style="width: 100%; height: 300px; border-radius: 12px; overflow: hidden; border: 1px solid #2E2A2A;">
                </div>

                @* Hiển thị tọa độ realtime *@
                <div class="row mt-3 g-2">
                    <div class="col-6">
                        <label class="text-muted small">Vĩ độ (Latitude)</label>
                        <input type="text" class="form-control form-control-sm bg-black border-secondary text-info"
                               value="@poiLatitude.ToString("F8")" readonly />
                    </div>
                    <div class="col-6">
                        <label class="text-muted small">Kinh độ (Longitude)</label>
                        <input type="text" class="form-control form-control-sm bg-black border-secondary text-info"
                               value="@poiLongitude.ToString("F8")" readonly />
                    </div>
                </div>
            </div>
        </div>

        @* ══════════════ CỘT PHẢI: THƯ VIỆN HÌNH ẢNH ══════════════ *@
        <div class="col-lg-6">
            <div class="card bg-dark-card border-0 p-4 shadow-sm h-100" style="border-radius: 16px;">
                <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-2">
                    <h6 class="text-info fw-bold mb-0">
                        <i class="bi bi-images me-2"></i>THƯ VIỆN HÌNH ẢNH
                    </h6>
                    <label class="btn btn-sm btn-outline-light rounded-pill mb-0"
                           style="cursor: pointer;">
                        <i class="bi bi-cloud-upload me-1"></i> Tải ảnh lên
                        <InputFile OnChange="HandleImageUpload" accept="image/*"
                                   multiple
                                   style="display: none;" />
                    </label>
                </div>

                @if (isUploadingImage)
                {
                    <div class="d-flex align-items-center mb-3">
                        <span class="spinner-border spinner-border-sm text-info me-2"></span>
                        <span class="text-info small">Đang tải ảnh lên...</span>
                    </div>
                }

                @if (!string.IsNullOrEmpty(uploadError))
                {
                    <div class="alert alert-danger py-2 small" style="border-radius: 8px;">
                        @uploadError
                    </div>
                }

                @* ── Grid ảnh ── *@
                <div class="row g-2">
                    @if (imageList.Any())
                    {
                        @foreach (var img in imageList)
                        {
                            <div class="col-4">
                                <div class="position-relative" style="height: 140px;">
                                    <img src="@img.Url"
                                         class="rounded-3 w-100 h-100"
                                         style="object-fit: cover; border: 1px solid #2E2A2A;" />

                                    @* Badge ảnh bìa *@
                                    @if (img.IsCover)
                                    {
                                        <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-1"
                                              style="font-size: 10px;">
                                            Ảnh bìa
                                        </span>
                                    }

                                    @* Nút hành động *@
                                    <div class="position-absolute bottom-0 end-0 m-1 d-flex gap-1">
                                        @if (!img.IsCover)
                                        {
                                            <button class="btn btn-sm btn-warning"
                                                    style="padding: 0.1rem 0.3rem; font-size: 10px;"
                                                    @onclick="() => SetCover(img)"
                                                    title="Đặt làm ảnh bìa">
                                                <i class="bi bi-star"></i>
                                            </button>
                                        }
                                        <button class="btn btn-sm btn-danger"
                                                style="padding: 0.1rem 0.3rem; font-size: 10px;"
                                                @onclick="() => RemoveImage(img)"
                                                title="Xóa ảnh">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    @* Placeholder khi chưa có ảnh *@
                    @if (!imageList.Any() && !isUploadingImage)
                    {
                        <div class="col-12 text-center py-5">
                            <i class="bi bi-cloud-upload" style="font-size: 48px; color: #2E2A2A;"></i>
                            <p class="text-muted mt-2">Chưa có hình ảnh. Bấm "Tải ảnh lên" để bắt đầu.</p>
                        </div>
                    }
                </div>

                <div class="mt-3 text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    Tối đa 5MB/ảnh. Hỗ trợ JPG, PNG, WebP. Ảnh đầu tiên sẽ là ảnh bìa mặc định.
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // ── State: Thông tin POI ────────────────────────
    private string poiName = "Ốc Oanh";
    private string poiPhone = "0901234567";
    private string poiAddress = "534 Vĩnh Khánh, Quận 4, TP.HCM";
    private string poiDescription = "";
    private double poiLatitude = 10.76012345;
    private double poiLongitude = 106.70298765;

    // ── State: Hình ảnh ─────────────────────────────
    private List<ImageItem> imageList = new();
    private bool isUploadingImage = false;
    private string uploadError = string.Empty;

    // ── State: Chung ────────────────────────────────
    private bool isSaving = false;
    private string statusMessage = string.Empty;
    private bool isError = false;

    // ── DotNetRef cho JS callback ───────────────────
    private DotNetObjectReference<ThongTinQuan>? dotNetRef;

    // ═════════════════════════════════════════════════
    //  LIFECYCLE
    // ═════════════════════════════════════════════════

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Tạo reference để JS gọi ngược về C#
            dotNetRef = DotNetObjectReference.Create(this);

            // Khởi tạo Google Maps sau khi DOM đã render
            await JS.InvokeVoidAsync(
                "initMapPicker",
                "mapPicker",
                poiLatitude,
                poiLongitude,
                dotNetRef
            );
        }
    }

    // ═════════════════════════════════════════════════
    //  GOOGLE MAPS — Callback từ JavaScript
    // ═════════════════════════════════════════════════

    /// <summary>
    /// Được gọi từ JS khi user kéo marker hoặc click vào bản đồ.
    /// [JSInvokable] cho phép JavaScript gọi method C# này.
    /// </summary>
    [JSInvokable]
    public void OnMapLocationChanged(double lat, double lng)
    {
        poiLatitude = lat;
        poiLongitude = lng;

        // Cập nhật UI (vì được gọi từ JS, cần InvokeAsync)
        InvokeAsync(StateHasChanged);
    }

    // ═════════════════════════════════════════════════
    //  UPLOAD HÌNH ẢNH — Fix lỗi sập web
    // ═════════════════════════════════════════════════

    /// <summary>
    /// Xử lý upload ảnh.
    ///
    /// NGUYÊN NHÂN LỖI SẬP WEB CŨ:
    /// Blazor Server truyền file qua SignalR WebSocket.
    /// Mặc định SignalR giới hạn ~32KB/message.
    /// Ảnh 5MB = ~5000KB → vượt giới hạn → circuit ngắt → sập.
    ///
    /// CÁCH FIX:
    /// 1. Trong Program.cs, tăng MaximumReceiveMessageSize (đã thêm bên dưới)
    /// 2. Dùng OpenReadStream() với maxAllowedSize rõ ràng
    /// 3. Đọc file theo stream (chunk), không load hết vào RAM
    /// </summary>
    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        isUploadingImage = true;
        uploadError = string.Empty;
        StateHasChanged();

        try
        {
            // Hỗ trợ upload nhiều ảnh cùng lúc (multiple)
            var files = e.GetMultipleFiles(10);

            foreach (var file in files)
            {
                // ── Validate ────────────────────────
                long maxSize = 5 * 1024 * 1024; // 5MB

                if (file.Size > maxSize)
                {
                    uploadError = $"Ảnh \"{file.Name}\" vượt quá 5MB.";
                    continue;
                }

                if (!file.ContentType.StartsWith("image/"))
                {
                    uploadError = $"\"{file.Name}\" không phải file ảnh.";
                    continue;
                }

                // ── Tạo tên file an toàn ────────────
                var extension = Path.GetExtension(file.Name).ToLower();
                var safeName = $"{Guid.NewGuid()}{extension}";

                // ── Tạo thư mục nếu chưa có ────────
                var uploadsDir = Path.Combine(Env.WebRootPath, "uploads", "poi");
                if (!Directory.Exists(uploadsDir))
                    Directory.CreateDirectory(uploadsDir);

                var filePath = Path.Combine(uploadsDir, safeName);

                // ── Ghi file ra ổ cứng (stream) ─────
                // QUAN TRỌNG: Truyền maxAllowedSize vào OpenReadStream
                // Nếu không truyền, mặc định chỉ cho 512KB → lỗi
                await using var readStream = file.OpenReadStream(maxAllowedSize: maxSize);
                await using var writeStream = new FileStream(filePath, FileMode.Create);
                await readStream.CopyToAsync(writeStream);

                // ── Thêm vào danh sách hiển thị ─────
                var imageItem = new ImageItem
                {
                    Url = $"/uploads/poi/{safeName}",
                    FileName = safeName,
                    IsCover = !imageList.Any() // Ảnh đầu tiên = ảnh bìa
                };
                imageList.Add(imageItem);

                StateHasChanged(); // Cập nhật UI sau mỗi ảnh
            }
        }
        catch (Exception ex)
        {
            uploadError = $"Lỗi upload: {ex.Message}";
            Console.WriteLine($"Upload error: {ex}");
        }
        finally
        {
            isUploadingImage = false;
            StateHasChanged();
        }
    }

    // ═════════════════════════════════════════════════
    //  QUẢN LÝ ẢNH
    // ═════════════════════════════════════════════════

    private void SetCover(ImageItem img)
    {
        // Bỏ ảnh bìa cũ
        foreach (var i in imageList)
            i.IsCover = false;

        // Đặt ảnh bìa mới
        img.IsCover = true;
    }

    private void RemoveImage(ImageItem img)
    {
        imageList.Remove(img);

        // Nếu xóa ảnh bìa → đặt ảnh đầu tiên còn lại làm bìa
        if (img.IsCover && imageList.Any())
            imageList.First().IsCover = true;

        // TODO: Xóa file vật lý trên server nếu cần
    }

    // ═════════════════════════════════════════════════
    //  LƯU THAY ĐỔI
    // ═════════════════════════════════════════════════

    private async Task SaveChanges()
    {
        if (string.IsNullOrWhiteSpace(poiName))
        {
            statusMessage = "Tên quán không được để trống.";
            isError = true;
            return;
        }

        isSaving = true;
        statusMessage = string.Empty;

        try
        {
            // TODO: Gọi PoiService.UpdateAsync() với tọa độ mới
            // TODO: Lưu imageList vào bảng IMAGES

            await Task.Delay(500); // Giả lập

            statusMessage = "Đã lưu thay đổi thành công!";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Lỗi: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    // ═════════════════════════════════════════════════
    //  CLEANUP
    // ═════════════════════════════════════════════════

    public void Dispose()
    {
        dotNetRef?.Dispose();
    }

    // ═════════════════════════════════════════════════
    //  MODEL NỘI BỘ
    // ═════════════════════════════════════════════════

    private class ImageItem
    {
        public string Url { get; set; } = string.Empty;
        public string FileName { get; set; } = string.Empty;
        public bool IsCover { get; set; }
    }
}
