@page "/vendor/thong-tin"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Entities
@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject AuthenticationStateProvider AuthStateProvider
@inject PoiService PoiService
@inject TtsService TtsService
@implements IDisposable

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">THÔNG TIN QUÁN & HÌNH ẢNH</h2>
            <span style="color: #4a4a5a; font-size: 13px;"><i class="bi bi-shop me-1"></i>Quản lý thông tin gian hàng của bạn</span>
        </div>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="SaveChanges" disabled="@isSaving">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            <i class="bi bi-floppy me-2"></i>Lưu thay đổi
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div style="@(isError ? "background:rgba(200,55,45,0.08);border:1px solid rgba(200,55,45,0.2);border-radius:12px;color:#f87171;padding:12px 16px;" : "background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:12px;color:#4ade80;padding:12px 16px;") margin-bottom:16px;"
             class="d-flex justify-content-between align-items-center">
            <span><i class="@(isError ? "bi bi-exclamation-triangle-fill" : "bi bi-check-circle-fill") me-2"></i>@statusMessage</span>
            <button type="button" style="background:none;border:none;color:inherit;cursor:pointer;font-size:1.1rem;padding:0;" @onclick="() => statusMessage = null"><i class="bi bi-x"></i></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="dash-card p-4 mb-4">
                <div class="dash-label mb-3"><i class="bi bi-info-circle me-2"></i>THÔNG TIN CHUNG</div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">TÊN GIAN HÀNG</label>
                    <input type="text" class="form-control dash-input p-3"
                           @bind="poiName" @bind:event="oninput" placeholder="VD: Ốc Oanh Vĩnh Khánh...">
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">MÔ TẢ (dùng cho thuyết minh tự động &amp; app)</label>
                    <textarea class="form-control dash-input p-3" rows="5"
                              @bind="poiDescription" @bind:event="oninput"
                              placeholder="Giới thiệu quán — nội dung này sẽ dùng khi tạo giọng đọc FPT..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">ĐỊA CHỈ CHI TIẾT</label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:#0f0f13;border:1px solid rgba(255,255,255,0.1);color:#4a4a5a;border-radius:10px 0 0 10px;"><i class="bi bi-geo-alt"></i></span>
                        <input type="text" class="form-control dash-input p-3"
                               @bind="poiAddress" placeholder="Số nhà, tên đường...">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small fw-bold">VĨ ĐỘ</label>
                        <input type="text" class="form-control dash-input" @bind="latitude" readonly>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small fw-bold">KINH ĐỘ</label>
                        <input type="text" class="form-control dash-input" @bind="longitude" readonly>
                    </div>
                </div>
            </div>

            <div class="dash-card" style="border-radius:16px;">
                <div style="height: 400px; border-radius: 16px; overflow: hidden;">
                    <div id="map" style="height: 400px; width: 100%; min-height: 400px; background-color: #1a1a1a; border-radius: 12px;"></div>
                </div>
                <div class="text-center pb-3 pt-2">
                    <small style="color:#4a4a5a;"><i class="bi bi-mouse me-1"></i>Kéo thả dấu ghim để cập nhật vị trí</small>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="dash-card p-4 mb-4">
                <div class="dash-label mb-3 text-start"><i class="bi bi-image me-2"></i>ẢNH BÌA (1 ẢNH)</div>
                <div class="image-preview-container mb-3 position-relative mx-auto"
                     style="width: 100%; height: 220px; background: rgba(255,255,255,0.03); border-radius: 12px; overflow: hidden; border: 2px dashed rgba(255,255,255,0.1);">
                    @if (!string.IsNullOrEmpty(mainImageUrl))
                    {
                        <img src="@mainImageUrl" style="width: 100%; height: 100%; object-fit: cover;" alt="Ảnh bìa" />
                    }
                    else
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center" style="color:#4a4a5a;">
                            <i class="bi bi-cloud-arrow-up fs-1"></i>
                            <span>Chưa có ảnh bìa</span>
                        </div>
                    }
                </div>
                <InputFile OnChange="HandleCoverUpload" class="form-control dash-input" accept="image/*" />
                <div class="form-text mt-2 text-start" style="color:#4a4a5a;">Tối đa 15MB (.jpg, .png, .webp)</div>
            </div>

            <div class="dash-card p-4 mb-4">
                <div class="dash-label mb-3"><i class="bi bi-images me-2"></i>ẢNH QUÁN (NHIỀU ẢNH)</div>
                <p class="text-muted small">Thêm nhiều ảnh không gian quán; có thể gỡ từng ảnh.</p>
                <InputFile OnChange="HandleGalleryUpload" class="form-control dash-input mb-3" accept="image/*" multiple />
                <div class="row g-2">
                    @foreach (var g in galleryImages)
                    {
                        <div class="col-6 col-md-4">
                            <div class="position-relative rounded overflow-hidden" style="aspect-ratio:1;border:1px solid rgba(255,255,255,0.08);">
                                <img src="@g.ImageUrl" class="w-100 h-100 object-fit-cover" alt="" />
                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 py-0 px-2"
                                        @onclick="() => RemoveGalleryAsync(g.ImageId)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>


            <div class="dash-card p-4">
                <div class="dash-label mb-3"><i class="bi bi-mic me-2"></i>THUYẾT MINH TỰ ĐỘNG KHI TỚI GẦN POI (TTS)</div>
                <p class="text-muted small mb-3">Dùng nội dung ô <strong>Mô tả</strong> bên trái để tạo audio tự động theo Geofence.</p>
                <label class="form-label text-muted small fw-bold">GIỌNG ĐỌC</label>
                <select class="form-select dash-input mb-3" @bind="ttsVoice">
                    <option value="lannhi">Nữ Miền Nam (Lan Nhi)</option>
                    <option value="banmai">Nữ Miền Nam (Ban Mai)</option>
                    <option value="minhquang">Nam Miền Nam (Minh Quang)</option>
                    <option value="thuquynh">Nữ Miền Bắc (Thu Quỳnh)</option>
                    <option value="leminh">Nam Miền Bắc (Lê Minh)</option>
                </select>
                <button type="button" class="btn btn-danger w-100 rounded-pill" @onclick="GenerateTtsAsync" disabled="@isTtsBusy">
                    @if (isTtsBusy)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Tạo thuyết minh tự động từ mô tả
                </button>
                @if (!string.IsNullOrEmpty(lastAutoAudioUrl))
                {
                    <div class="mt-3 p-3 rounded" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-warning small">Audio tự động gần POI — nghe thử</div>
                            <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                    @onclick="DeleteAutoAudioAsync" disabled="@isDeletingAudio"
                                    title="Xoá audio tự động">
                                @if (isDeletingAudio)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-trash me-1"></i>
                                }
                                Xoá audio
                            </button>
                        </div>
                        <audio controls class="w-100" src="@lastAutoAudioUrl"></audio>
                    </div>
                }

                <div class="my-3 pt-3" style="border-top:1px solid rgba(255,255,255,0.06);">
                    <h6 class="text-white mb-2"><i class="bi bi-qr-code-scan me-2 text-danger"></i>Audio riêng cho quét QR</h6>
                    <label class="form-label text-muted small fw-bold">TẢI FILE AUDIO CHO QR</label>
                    <InputFile OnChange="HandleNarrationAudioUpload" class="form-control dash-input" accept="audio/*" />
                    <div class="form-text text-muted">Hỗ trợ .mp3/.wav/.m4a. File này chỉ dùng khi người dùng quét QR.</div>
                </div>
                @if (!string.IsNullOrEmpty(lastQrAudioUrl))
                {
                    <div class="mt-3 p-3 rounded" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="text-warning small">Audio quét QR — nghe thử</div>
                            <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                    @onclick="DeleteQrAudioAsync" disabled="@isDeletingAudio"
                                    title="Xoá audio QR">
                                @if (isDeletingAudio)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <i class="bi bi-trash me-1"></i>
                                }
                                Xoá audio
                            </button>
                        </div>
                        <audio controls class="w-100" src="@lastQrAudioUrl"></audio>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string poiName = "";
    private string poiDescription = "";
    private string poiAddress = "";
    private double latitude = 10.7578;
    private double longitude = 106.7095;
    private string qrCode = "N/A";
    private string activeQrToken = "";
    private string mainImageUrl = "";
    private List<Image> galleryImages = new();
    private string ttsVoice = "lannhi";
    private string? lastAutoAudioUrl;
    private string? lastQrAudioUrl;
    private int currentPoiId;
    private int currentUserId;
    private bool isSaving;
    private bool isTtsBusy;
    private bool isDeletingAudio;
    private bool isError;
    private string? statusMessage;
    private DotNetObjectReference<ThongTinQuan>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadDataAsync();
        dotNetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("initMapPicker", "map", latitude, longitude, dotNetRef);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MAP]: {ex.Message}");
        }
    }

    private async Task LoadDataAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var displayName = authState.User.Identity?.Name ?? "Quán của tôi";

        if (!int.TryParse(userIdStr, out var userId))
            return;

        currentUserId = userId;
        await PoiService.EnsureVendorPoiAsync(userId, displayName);

        var poi = await PoiService.GetPoiByOwnerIdAsync(userId);
        if (poi is null)
            return;

        currentPoiId = poi.PoiId;
        poiName = poi.Name;
        poiDescription = poi.Description ?? "";
        poiAddress = poi.Address ?? "";
        latitude = (double)poi.Latitude;
        longitude = (double)poi.Longitude;

        var firstQr = poi.QrCodes.OrderByDescending(q => q.IsActive).FirstOrDefault();
        activeQrToken = firstQr?.QrToken ?? "";
        qrCode = string.IsNullOrEmpty(activeQrToken) ? "Chưa tạo mã QR" : activeQrToken;

        mainImageUrl = poi.ImageUrl ?? "";
        galleryImages = await PoiService.GetStallGalleryAsync(poi.PoiId, userId);

        var viNarration = poi.Narrations?.FirstOrDefault(n => n.IsActive && n.Language != null && n.Language.Code.Equals("vi", StringComparison.OrdinalIgnoreCase));
        lastAutoAudioUrl = viNarration?.AudioUrlAuto ?? viNarration?.AudioUrl;
        lastQrAudioUrl = viNarration?.AudioUrlQr;

        StateHasChanged();
    }

    private static string GetQrImageUrl(string token)
    {
        var qrData = Uri.EscapeDataString($"vkfoodtour://{token}");
        return $"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={qrData}";
    }

    private async Task CreateQrAsync()
    {
        isSaving = true;
        statusMessage = null;
        try
        {
            var token = await PoiService.EnsurePrimaryQrForVendorAsync(currentPoiId, currentUserId, "Tại quán");
            if (string.IsNullOrEmpty(token))
            {
                statusMessage = "Không tạo được mã QR.";
                isError = true;
            }
            else
            {
                activeQrToken = token;
                qrCode = token;
                statusMessage = "Đã tạo / cập nhật mã QR.";
                isError = false;
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            isError = true;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteQrAsync()
    {
        if (currentPoiId == 0)
            return;

        isSaving = true;
        try
        {
            var ok = await PoiService.DeleteActiveQrForVendorAsync(currentPoiId, currentUserId);
            if (!ok)
            {
                statusMessage = "Không xóa được mã QR.";
                isError = true;
                return;
            }

            activeQrToken = "";
            qrCode = "Chưa tạo mã QR";
            statusMessage = "Đã xóa mã QR hiện tại. Bạn có thể tạo lại mã mới.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            isError = true;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    /// <summary>Tạo lại token QR từ mô tả + tự động tạo TTS audio để app mobile phát ngay khi quét.</summary>
    private async Task RegenerateQrFromDescriptionOnlyAsync()
    {
        if (currentPoiId == 0)
            return;

        if (string.IsNullOrWhiteSpace(poiDescription))
        {
            statusMessage = "Nhập mô tả quán trước khi cập nhật mã QR.";
            isError = true;
            StateHasChanged();
            return;
        }

        isSaving = true;
        isTtsBusy = true;
        statusMessage = "Đang tạo mã QR và audio thuyết minh…";
        isError = false;
        StateHasChanged();
        try
        {
            await PoiService.UpdateStallInfoAsync(
                currentPoiId,
                poiName,
                poiDescription,
                poiAddress,
                latitude,
                longitude,
                mainImageUrl);

            var langId = await PoiService.GetVietnameseLanguageIdAsync();
            var stem = $"poi{currentPoiId}_vi";
            var tts = await TtsService.GenerateAndPersistLocalAsync(poiDescription.Trim(), ttsVoice, stem);
            if (!string.IsNullOrEmpty(tts.ErrorMessage))
            {
                statusMessage = $"Tạo TTS thất bại: {tts.ErrorMessage}";
                isError = true;
                return;
            }

            lastAutoAudioUrl = tts.Url;
            await PoiService.UpsertNarrationAutoAsync(
                currentPoiId,
                langId,
                poiName,
                poiDescription.Trim(),
                ttsVoice,
                tts.Url);

            var token = await PoiService.RegenerateQrFromDescriptionAsync(
                currentPoiId,
                currentUserId,
                poiDescription,
                "Tại quán (mô tả)");

            if (!string.IsNullOrWhiteSpace(token))
            {
                activeQrToken = token;
                qrCode = token;
            }

            statusMessage = "Đã tạo mã QR + audio thuyết minh từ mô tả. App mobile quét QR sẽ tự động phát audio.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = FormatSaveException(ex);
            isError = true;
        }
        finally
        {
            isSaving = false;
            isTtsBusy = false;
            StateHasChanged();
        }
    }

    private async Task GenerateTtsAsync()
    {
        if (string.IsNullOrWhiteSpace(poiDescription))
        {
            statusMessage = "Hãy nhập mô tả quán trước khi tạo thuyết minh.";
            isError = true;
            StateHasChanged();
            return;
        }

        isTtsBusy = true;
        statusMessage = "Đang gọi FPT.AI và lưu file…";
        isError = false;
        StateHasChanged();

        try
        {
            // Luôn đồng bộ mô tả hiện tại vào POI trước khi tạo TTS
            // để đảm bảo thuyết minh được tạo đúng theo nội dung mới nhất.
            await PoiService.UpdateStallInfoAsync(
                currentPoiId,
                poiName,
                poiDescription,
                poiAddress,
                latitude,
                longitude,
                mainImageUrl);

            var langId = await PoiService.GetVietnameseLanguageIdAsync();
            var stem = $"poi{currentPoiId}_vi";
            var tts = await TtsService.GenerateAndPersistLocalAsync(poiDescription.Trim(), ttsVoice, stem);
            if (!string.IsNullOrEmpty(tts.ErrorMessage))
            {
                statusMessage = tts.ErrorMessage;
                isError = true;
                return;
            }

            lastAutoAudioUrl = tts.Url;
            await PoiService.UpsertNarrationAutoAsync(
                currentPoiId,
                langId,
                poiName,
                poiDescription.Trim(),
                ttsVoice,
                tts.Url);

            var refreshedToken = await PoiService.RegenerateQrFromDescriptionAsync(
                currentPoiId,
                currentUserId,
                poiDescription,
                "Tại quán (tạo từ mô tả)");
            if (!string.IsNullOrWhiteSpace(refreshedToken))
            {
                activeQrToken = refreshedToken;
                qrCode = refreshedToken;
            }

            statusMessage = "Đã lưu file MP3 trên máy chủ (/uploads) và cập nhật mã QR theo mô tả.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = FormatSaveException(ex);
            isError = true;
        }
        finally
        {
            isTtsBusy = false;
            StateHasChanged();
        }
    }

    private static string FormatSaveException(Exception ex)
    {
        var cur = ex;
        var parts = new List<string>();
        while (cur is not null && parts.Count < 4)
        {
            if (!string.IsNullOrWhiteSpace(cur.Message))
                parts.Add(cur.Message.Trim());
            cur = cur.InnerException;
        }

        return parts.Count == 0 ? "Lỗi không xác định." : string.Join(" → ", parts);
    }

    private async Task HandleNarrationAudioUpload(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || currentPoiId == 0)
            return;

        try
        {
            isSaving = true;
            var file = e.File;
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            var fileName = $"poi{currentPoiId}_manual_{Guid.NewGuid():N}{ext}";
            var folder = Path.GetFullPath(Path.Combine(Env.ContentRootPath, "..", "UploadsData", "narration"));
            Directory.CreateDirectory(folder);

            await using var fs = new FileStream(Path.Combine(folder, fileName), FileMode.Create);
            await file.OpenReadStream(30 * 1024 * 1024).CopyToAsync(fs);

            var url = $"/uploads/narration/{fileName}";
            var langId = await PoiService.GetVietnameseLanguageIdAsync();
            await PoiService.UpsertNarrationQrAsync(
                currentPoiId,
                langId,
                string.IsNullOrWhiteSpace(poiName) ? "Thuyết minh QR" : $"{poiName} (QR)",
                string.IsNullOrWhiteSpace(poiDescription) ? $"Nội dung thuyết minh của {poiName}" : poiDescription.Trim(),
                url);

            var refreshedToken = await PoiService.RegenerateQrFromDescriptionAsync(
                currentPoiId,
                currentUserId,
                poiDescription,
                "Tại quán (tạo từ mô tả)");
            if (!string.IsNullOrWhiteSpace(refreshedToken))
            {
                activeQrToken = refreshedToken;
                qrCode = refreshedToken;
            }

            lastQrAudioUrl = url;
            statusMessage = "Đã tải audio cho kịch bản quét QR và cập nhật mã QR theo mô tả.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Lỗi upload audio: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task HandleCoverUpload(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || currentPoiId == 0)
            return;
        try
        {
            isSaving = true;
            var file = e.File;
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();
            var fileName = $"stall_cover_{currentPoiId}_{Guid.NewGuid():N}{ext}";
            var folder = Path.GetFullPath(Path.Combine(Env.ContentRootPath, "..", "UploadsData", "poi"));
            Directory.CreateDirectory(folder);
            await using var fs = new FileStream(Path.Combine(folder, fileName), FileMode.Create);
            await file.OpenReadStream(15 * 1024 * 1024).CopyToAsync(fs);
            mainImageUrl = $"/uploads/poi/{fileName}";
            statusMessage = "Đã chọn ảnh bìa — nhấn Lưu để ghi vào hệ thống.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Lỗi upload: {ex.Message}";
            isError = true;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task HandleGalleryUpload(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || currentPoiId == 0)
            return;
        try
        {
            isSaving = true;
            foreach (var file in e.GetMultipleFiles(20))
            {
                var ext = Path.GetExtension(file.Name).ToLowerInvariant();
                var fileName = $"stall_gal_{currentPoiId}_{Guid.NewGuid():N}{ext}";
                var folder = Path.GetFullPath(Path.Combine(Env.ContentRootPath, "..", "UploadsData", "poi"));
                Directory.CreateDirectory(folder);
                var path = Path.Combine(folder, fileName);
                await using var fs = new FileStream(path, FileMode.Create);
                await file.OpenReadStream(15 * 1024 * 1024).CopyToAsync(fs);
                var url = $"/uploads/poi/{fileName}";
                await PoiService.AddStallGalleryImageAsync(currentPoiId, currentUserId, url);
            }

            galleryImages = await PoiService.GetStallGalleryAsync(currentPoiId, currentUserId);
            statusMessage = "Đã thêm ảnh vào thư viện.";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            isError = true;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task RemoveGalleryAsync(int imageId)
    {
        await PoiService.RemoveStallGalleryImageAsync(imageId, currentUserId);
        galleryImages = await PoiService.GetStallGalleryAsync(currentPoiId, currentUserId);
        StateHasChanged();
    }

    private async Task SaveChanges()
    {
        if (string.IsNullOrWhiteSpace(poiName))
        {
            statusMessage = "Tên quán không được để trống.";
            isError = true;
            return;
        }

        isSaving = true;
        statusMessage = null;
        try
        {
            var ok = await PoiService.UpdateStallInfoAsync(currentPoiId, poiName, poiDescription, poiAddress, latitude, longitude, mainImageUrl);
            statusMessage = ok ? "Đã cập nhật thông tin quán." : "Lưu thất bại.";
            isError = !ok;
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
            isError = true;
        }
        finally
        {
            isSaving = false;
        }
    }

    [JSInvokable]
    public void OnMapLocationChanged(double lat, double lng)
    {
        latitude = lat;
        longitude = lng;
        StateHasChanged();
    }

    private async Task DeleteAutoAudioAsync()
    {
        if (currentPoiId == 0 || isDeletingAudio) return;
        isDeletingAudio = true;
        statusMessage = null;
        try
