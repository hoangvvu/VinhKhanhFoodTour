@page "/vendor/thuc-don"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Entities
@using MenuItem = VKFoodTour.Infrastructure.Entities.MenuItem

@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer

@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject AuthenticationStateProvider AuthStateProvider
@inject PoiService PoiService
@inject MenuService MenuService

@* ══════════════════════════════════════════════════════════
   QUẢN LÝ THỰC ĐƠN
   ══════════════════════════════════════════════════════════ *@

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">QUẢN LÝ THỰC ĐƠN (MENU)</h3>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="ShowAddModal">
            <i class="bi bi-plus-lg me-2"></i>Thêm món mới
        </button>
    </div>

    @* ── Thông báo lỗi/thành công hiện ngay trên trang ── *@
    @if (!string.IsNullOrEmpty(pageMessage))
    {
        <div class="alert @(pageMessageIsError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
            <i class="bi @(pageMessageIsError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-2"></i>
            @pageMessage
            <button type="button" class="btn-close" @onclick="() => pageMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="text-muted mt-3">Đang tải thực đơn...</p>
        </div>
    }
    else if (currentPoiId == 0)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Tài khoản chưa được gán quán. Vui lòng liên hệ Admin.
        </div>
    }
    else
    {
        <div class="card bg-dark-card border-0 shadow" style="border-radius: 16px; overflow: hidden;">
            <div class="card-body p-0">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <thead class="bg-black text-muted small">
                        <tr>
                            <th class="ps-4 py-3">MÓN ĂN</th>
                            <th>GIÁ TIỀN</th>
                            <th>TRẠNG THÁI</th>
                            <th class="text-end pe-4">THAO TÁC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in menuList)
                        {
                            var isHidden = item.Status == "HIDDEN";
                            <tr style="@(isHidden ? "opacity: 0.5;" : "")">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" class="rounded-3 me-3"
                                                 style="width: 60px; height: 60px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-3 me-3 bg-secondary d-flex align-items-center justify-content-center"
                                                 style="width: 60px; height: 60px;">
                                                <i class="bi bi-image text-muted"></i>
                                            </div>
                                        }
                                        <div>
                                            <span class="fw-bold text-white @(isHidden ? "text-decoration-line-through" : "")">
                                                @item.Name
                                            </span><br />
                                            <span class="text-muted small">@item.Category</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-warning fw-bold">
                                    @item.Price.ToString("N0") ₫
                                </td>
                                <td>
                                    @if (!isHidden)
                                    {
                                        <span class="badge bg-success">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Tạm ẩn</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm @(!isHidden ? "btn-outline-warning" : "btn-warning text-dark") me-2"
                                            @onclick="() => ToggleStatus(item)">
                                        <i class="bi @(!isHidden ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-light" @onclick="() => ShowEditModal(item)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </td>
                            </tr>
                        }

                        @if (!menuList.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    Chưa có món ăn nào trong thực đơn.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* ══════════════════════════════════════════════════════════
   MODAL THÊM / SỬA MÓN ĂN
   ══════════════════════════════════════════════════════════ *@

@if (isShowModal)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-dark border-secondary text-white" style="border-radius: 16px;">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold">
                        @(isEditing ? "Cập Nhật Món Ăn" : "Thêm Món Ăn Mới")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2 small" style="border-radius: 8px;">
                            @modalError
                        </div>
                    }

                    <div class="row g-4">
                        @* ── Cột trái: Thông tin cơ bản ── *@
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Tên món ăn <span class="text-danger">*</span></label>
                                <input type="text" class="form-control bg-black border-secondary text-white"
                                       @bind="formName" placeholder="VD: Sò huyết nướng mọi" />
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">Giá tiền (VNĐ) <span class="text-danger">*</span></label>
                                    <input type="number" class="form-control bg-black border-secondary text-white"
                                           @bind="formPrice" placeholder="0" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">Danh mục</label>
                                    <select class="form-select bg-black border-secondary text-white"
                                            @bind="formCategory">
                                        <option value="Món nướng">Món nướng</option>
                                        <option value="Món xào">Món xào</option>
                                        <option value="Món hấp">Món hấp</option>
                                        <option value="Món luộc">Món luộc</option>
                                        <option value="Đồ uống">Đồ uống</option>
                                        <option value="Khác">Khác</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Mô tả món ăn</label>
                                <textarea class="form-control bg-black border-secondary text-white" rows="3"
                                          @bind="formDescription"
                                          placeholder="VD: Sò huyết nướng mọi giữ nguyên vị ngọt tự nhiên..."></textarea>
                            </div>
                        </div>

                        @* ── Cột phải: Upload ảnh ── *@
                        <div class="col-md-6 border-start border-secondary ps-md-4">
                            <h6 class="text-info fw-bold mb-3">
                                <i class="bi bi-image me-2"></i>Hình ảnh món ăn
                            </h6>

                            @if (isUploadingImage)
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <span class="spinner-border spinner-border-sm text-info me-2"></span>
                                    <span class="text-info small">Đang tải ảnh lên...</span>
                                </div>
                            }

                            <label class="w-100 mb-3" style="cursor: pointer;">
                                <div class="bg-black rounded-3 p-3 text-center border border-secondary border-dashed"
                                     style="border-style: dashed !important;">
                                    <i class="bi bi-cloud-upload" style="font-size: 32px; color: #6c757d;"></i>
                                    <p class="text-muted small mb-0 mt-1">Bấm để chọn ảnh (tối đa 5MB)</p>
                                </div>
                                <InputFile OnChange="HandleMenuImageUpload" accept="image/*"
                                           style="display: none;" />
                            </label>

                            @* Preview ảnh *@
                            @if (!string.IsNullOrEmpty(formImageUrl))
                            {
                                <div class="text-center bg-black rounded-3 p-2 border border-secondary position-relative">
                                    <img src="@formImageUrl"
                                         style="max-height: 180px; border-radius: 8px; object-fit: cover;" />
                                    <button class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1"
                                            style="padding: 0.1rem 0.4rem;"
                                            @onclick="() => formImageUrl = string.Empty">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4"
                            @onclick="HideModal">
                        Hủy
                    </button>
                    <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm"
                            @onclick="SaveItem" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-floppy me-2"></i> Lưu món ăn
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── State: Danh sách ────────────────────────────
    private List<MenuItem> menuList = new();
    private int currentPoiId;
    private bool isLoading = true;

    // ── State: Thông báo trên trang ─────────────────
    private string? pageMessage;
    private bool pageMessageIsError;

    // ── State: Modal ────────────────────────────────
    private bool isShowModal = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string modalError = string.Empty;

    // ── State: Form fields ──────────────────────────
    // ĐÃ SỬA: formPrice là decimal (NOT NULL trong DB), default = 0
    private int formId = 0;
    private string formName = string.Empty;
    private decimal formPrice = 0;
    private string formCategory = "Món nướng";
    private string formDescription = string.Empty;
    private string formImageUrl = string.Empty;

    // ── State: Upload ───────────────────────────────
    private bool isUploadingImage = false;

    // ═════════════════════════════════════════════════
    //  LIFECYCLE
    // ═════════════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (int.TryParse(userIdStr, out int userId))
            {
                var poi = await PoiService.GetPoiByOwnerIdAsync(userId);
                if (poi != null)
                {
                    currentPoiId = poi.PoiId;
                    menuList = await MenuService.GetByPoiIdAsync(currentPoiId);
                }
            }
        }
        catch (Exception ex)
        {
            pageMessage = $"Lỗi tải dữ liệu: {ex.Message}";
            pageMessageIsError = true;
            Console.WriteLine($"[MENU] Load error: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    // ═════════════════════════════════════════════════
    //  MODAL
    // ═════════════════════════════════════════════════

    private void ShowAddModal()
    {
        isEditing = false;
        modalError = string.Empty;
        formId = 0;
        formName = string.Empty;
        formPrice = 0;
        formCategory = "Món nướng";
        formDescription = string.Empty;
        formImageUrl = string.Empty;
        isShowModal = true;
    }

    private void ShowEditModal(MenuItem item)
    {
        isEditing = true;
        modalError = string.Empty;
        formId = item.ItemId;
        formName = item.Name;
        formPrice = item.Price;
        formCategory = item.Category ?? "Món nướng";
        formDescription = item.Description ?? string.Empty;
        formImageUrl = item.ImageUrl ?? string.Empty;
        isShowModal = true;
    }

    private void HideModal() => isShowModal = false;

    // ═════════════════════════════════════════════════
    //  UPLOAD ẢNH
    // ═════════════════════════════════════════════════

    private async Task HandleMenuImageUpload(InputFileChangeEventArgs e)
    {
        isUploadingImage = true;
        modalError = string.Empty;
        StateHasChanged();

        try
        {
            var file = e.File;
            long maxSize = 5 * 1024 * 1024;

            if (file.Size > maxSize)
            {
                modalError = $"Ảnh vượt quá 5MB ({(file.Size / 1024 / 1024.0):F1}MB).";
                return;
            }

            if (!file.ContentType.StartsWith("image/"))
            {
                modalError = "File không phải hình ảnh.";
                return;
            }

            var extension = Path.GetExtension(file.Name).ToLower();
            var safeName = $"{Guid.NewGuid()}{extension}";
            var uploadsDir = Path.Combine(Env.ContentRootPath, "..", "UploadsData", "menu");

            if (!Directory.Exists(uploadsDir))
                Directory.CreateDirectory(uploadsDir);

            var filePath = Path.Combine(uploadsDir, safeName);

            await using var readStream = file.OpenReadStream(maxAllowedSize: maxSize);
            await using var writeStream = new FileStream(filePath, FileMode.Create);
            await readStream.CopyToAsync(writeStream);

            formImageUrl = $"/uploads/menu/{safeName}";
        }
        catch (Exception ex)
        {
            modalError = $"Lỗi upload: {ex.Message}";
            Console.WriteLine($"[MENU] Upload error: {ex}");
        }
        finally
        {
            isUploadingImage = false;
            StateHasChanged();
        }
    }

    // ═════════════════════════════════════════════════
    //  SAVE / TOGGLE — GỌI DB THẬT
    // ═════════════════════════════════════════════════

    private async Task SaveItem()
    {
        // ── Validate bắt buộc ───────────────────────
        if (string.IsNullOrWhiteSpace(formName))
        {
            modalError = "Tên món ăn không được để trống.";
            return;
        }

        if (formPrice <= 0)
        {
            modalError = "Giá tiền phải lớn hơn 0.";
            return;
        }

        isSaving = true;
        modalError = string.Empty;

        try
        {
            if (isEditing)
            {
                var success = await MenuService.UpdateItemAsync(
                    formId, formName, formPrice, formCategory,
                    string.IsNullOrWhiteSpace(formDescription) ? null : formDescription,
                    string.IsNullOrWhiteSpace(formImageUrl) ? null : formImageUrl
                );

                if (!success)
                {
                    modalError = "Không tìm thấy món ăn để cập nhật.";
                    return;
                }

                // Reload list từ DB
                menuList = await MenuService.GetByPoiIdAsync(currentPoiId);

                pageMessage = $"Đã cập nhật \"{formName}\" thành công!";
                pageMessageIsError = false;
            }
            else
            {
                var newItem = new MenuItem
                {
                    PoiId = currentPoiId,
                    Name = formName,
                    Price = formPrice,
                    Category = formCategory ?? "Món nướng",
                    Description = formDescription,
                    ImageUrl = formImageUrl,
                    Status = "AVAILABLE"
                };

                var savedItem = await MenuService.AddItemAsync(newItem);

                Console.WriteLine($"[MENU] Đã thêm: {savedItem.Name} (ItemId={savedItem.ItemId}, PoiId={savedItem.PoiId})");

                // Reload list từ DB
                menuList = await MenuService.GetByPoiIdAsync(currentPoiId);

                pageMessage = $"Đã thêm \"{formName}\" thành công!";
                pageMessageIsError = false;
            }

            // Chỉ đóng modal khi KHÔNG CÓ LỖI
            HideModal();
        }
        catch (Exception ex)
        {
            // ĐÃ SỬA: Lỗi hiện RÕ trong modal, KHÔNG đóng modal
            modalError = $"Lỗi lưu DB: {ex.Message}";
            Console.WriteLine($"[MENU] SaveItem EXCEPTION: {ex}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleStatus(MenuItem item)
    {
        try
        {
            await MenuService.ToggleStatusAsync(item.ItemId);
            item.Status = (item.Status == "AVAILABLE") ? "HIDDEN" : "AVAILABLE";
        }
        catch (Exception ex)
        {
            pageMessage = $"Lỗi đổi trạng thái: {ex.Message}";
            pageMessageIsError = true;
            Console.WriteLine($"[MENU] ToggleStatus error: {ex}");
        }
    }
}
