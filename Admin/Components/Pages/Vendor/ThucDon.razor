@page "/vendor/thuc-don"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer
@* Nhớ tiêm TtsService vào để dùng AI tạo giọng đọc cho món ăn *@
@inject TtsService TtsService

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">QUẢN LÝ THỰC ĐƠN (MENU)</h3>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="ShowModal">
            <i class="bi bi-plus-lg me-2"></i>Thêm món mới
        </button>
    </div>

    <div class="card bg-dark-card border-0 shadow" style="border-radius: 16px; overflow: hidden;">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead class="bg-black text-muted small">
                    <tr>
                        <th class="ps-4 py-3">MÓN ĂN</th>
                        <th>GIÁ TIỀN</th>
                        <th>AUDIO (TTS)</th>
                        <th>TRẠNG THÁI</th>
                        <th class="text-end pe-4">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <img src="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?w=150" class="rounded-3 me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                                <div>
                                    <span class="fw-bold text-white">Ốc hương xào bơ tỏi</span><br/>
                                    <span class="text-muted small">Các món ốc</span>
                                </div>
                            </div>
                        </td>
                        <td class="text-warning fw-bold">120,000 ₫</td>
                        <td>
                            <button class="btn btn-sm btn-outline-info rounded-pill"><i class="bi bi-play-fill"></i> Nghe thử</button>
                        </td>
                        <td><span class="badge bg-success">Đang bán</span></td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-outline-light me-2"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ── MODAL THÊM / SỬA MÓN ĂN ── *@
@if (isShowModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-dark border-secondary text-white" style="border-radius: 16px;">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold">Thêm Món Ăn Mới</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Tên món ăn</label>
                                <input type="text" class="form-control bg-black border-secondary text-white" placeholder="VD: Sò huyết nướng mọi" />
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">Giá tiền (VNĐ)</label>
                                    <input type="number" class="form-control bg-black border-secondary text-white" placeholder="VD: 80000" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">Danh mục</label>
                                    <select class="form-select bg-black border-secondary text-white">
                                        <option>Món nướng</option>
                                        <option>Món xào</option>
                                        <option>Đồ uống</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Hình ảnh món ăn</label>
                                <div class="bg-black rounded-3 d-flex flex-column align-items-center justify-content-center p-3" style="border: 1px dashed #6c757d; cursor: pointer;">
                                    <i class="bi bi-cloud-arrow-up fs-3 text-muted"></i>
                                    <span class="text-muted small">Nhấn để tải ảnh lên</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 border-start border-secondary ps-md-4">
                            <h6 class="text-info fw-bold mb-3"><i class="bi bi-magic me-2"></i>Tạo Audio Giới Thiệu (AI TTS)</h6>
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Nội dung / Câu chuyện món ăn</label>
                                <textarea @bind="ttsInput" class="form-control bg-black border-secondary text-white" rows="4" placeholder="VD: Sò huyết nướng mọi giữ nguyên vị ngọt tự nhiên, chấm cùng muối tiêu chanh..."></textarea>
                            </div>
                            
                            <button class="btn btn-outline-info w-100 rounded-pill mb-3" @onclick="GenerateMenuAudio" disabled="@isGeneratingAudio">
                                @if (isGeneratingAudio) {
                                    <span class="spinner-border spinner-border-sm me-2"></span> <span>Đang tạo Audio...</span>
                                } else {
                                    <i class="bi bi-soundwave me-2"></i> <span>Tạo giọng đọc mẫu</span>
                                }
                            </button>

                            @if (!string.IsNullOrEmpty(generatedAudioUrl))
                            {
                                <div class="bg-black p-3 rounded-3 text-center border border-success">
                                    <div class="text-success small mb-2"><i class="bi bi-check-circle me-1"></i> Đã tạo thành công</div>
                                    <audio controls class="w-100" style="height: 35px;" src="@generatedAudioUrl"></audio>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4" @onclick="HideModal">Hủy</button>
                    <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">Lưu món ăn</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isShowModal = false;
    
    // Biến cho phần TTS
    private string ttsInput = "";
    private string? generatedAudioUrl;
    private bool isGeneratingAudio = false;

    private void ShowModal()
    {
        isShowModal = true;
        ttsInput = "";
        generatedAudioUrl = null;
    }

    private void HideModal()
    {
        isShowModal = false;
    }

    private async Task GenerateMenuAudio()
    {
        if (string.IsNullOrWhiteSpace(ttsInput)) return;

        isGeneratingAudio = true;
        generatedAudioUrl = null;
        StateHasChanged();

        // Mặc định gọi giọng đọc Tiếng Việt (Lan Nhi) cho món ăn
        var result = await TtsService.GenerateAudioAsync(ttsInput, "lannhi");
        
        generatedAudioUrl = result.Url;
        
        isGeneratingAudio = false;
        StateHasChanged();
    }
}