@page "/vendor/thuc-don"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IWebHostEnvironment Env

@* ══════════════════════════════════════════════════════════
   QUẢN LÝ THỰC ĐƠN
   FIX: Upload ảnh không còn sập web
   - Dùng OpenReadStream(maxAllowedSize) đúng cách
   - Cần config SignalR MaximumReceiveMessageSize trong Program.cs
   ══════════════════════════════════════════════════════════ *@

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">QUẢN LÝ THỰC ĐƠN (MENU)</h3>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="ShowAddModal">
            <i class="bi bi-plus-lg me-2"></i>Thêm món mới
        </button>
    </div>

    <div class="card bg-dark-card border-0 shadow" style="border-radius: 16px; overflow: hidden;">
        <div class="card-body p-0">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead class="bg-black text-muted small">
                    <tr>
                        <th class="ps-4 py-3">MÓN ĂN</th>
                        <th>GIÁ TIỀN</th>
                        <th>TRẠNG THÁI</th>
                        <th class="text-end pe-4">THAO TÁC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in menuList)
                    {
                        <tr style="@(item.IsHidden ? "opacity: 0.5;" : "")">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="rounded-3 me-3"
                                             style="width: 60px; height: 60px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded-3 me-3 bg-secondary d-flex align-items-center justify-content-center"
                                             style="width: 60px; height: 60px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <div>
                                        <span class="fw-bold text-white @(item.IsHidden ? "text-decoration-line-through" : "")">
                                            @item.Name
                                        </span><br />
                                        <span class="text-muted small">@item.Category</span>
                                    </div>
                                </div>
                            </td>
                            <td class="text-warning fw-bold">
                                @(item.Price?.ToString("N0") ?? "—") ₫
                            </td>
                            <td>
                                @if (!item.IsHidden)
                                {
                                    <span class="badge bg-success">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Tạm ẩn</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm @(!item.IsHidden ? "btn-outline-warning" : "btn-warning text-dark") me-2"
                                        @onclick="() => ToggleStatus(item)">
                                    <i class="bi @(!item.IsHidden ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-light" @onclick="() => ShowEditModal(item)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </td>
                        </tr>
                    }

                    @if (!menuList.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                Chưa có món ăn nào trong thực đơn.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ══════════════════════════════════════════════════════════
   MODAL THÊM / SỬA MÓN ĂN
   ══════════════════════════════════════════════════════════ *@

@if (isShowModal)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-dark border-secondary text-white" style="border-radius: 16px;">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold">
                        @(isEditing ? "Cập Nhật Món Ăn" : "Thêm Món Ăn Mới")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2 small" style="border-radius: 8px;">
                            @modalError
                        </div>
                    }

                    <div class="row g-4">
                        @* ── Cột trái: Thông tin cơ bản ── *@
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Tên món ăn</label>
                                <input type="text" class="form-control bg-black border-secondary text-white"
                                       @bind="formName" placeholder="VD: Sò huyết nướng mọi" />
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">Giá tiền (VNĐ)</label>
                                    <input type="number" class="form-control bg-black border-secondary text-white"
                                           @bind="formPrice" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">Danh mục</label>
                                    <select class="form-select bg-black border-secondary text-white"
                                            @bind="formCategory">
                                        <option value="Món nướng">Món nướng</option>
                                        <option value="Món xào">Món xào</option>
                                        <option value="Món hấp">Món hấp</option>
                                        <option value="Món luộc">Món luộc</option>
                                        <option value="Đồ uống">Đồ uống</option>
                                        <option value="Khác">Khác</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">Mô tả món ăn</label>
                                <textarea class="form-control bg-black border-secondary text-white" rows="3"
                                          @bind="formDescription"
                                          placeholder="VD: Sò huyết nướng mọi giữ nguyên vị ngọt tự nhiên..."></textarea>
                            </div>
                        </div>

                        @* ── Cột phải: Upload ảnh ── *@
                        <div class="col-md-6 border-start border-secondary ps-md-4">
                            <h6 class="text-info fw-bold mb-3">
                                <i class="bi bi-image me-2"></i>Hình ảnh món ăn
                            </h6>

                            @if (isUploadingImage)
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <span class="spinner-border spinner-border-sm text-info me-2"></span>
                                    <span class="text-info small">Đang tải ảnh lên...</span>
                                </div>
                            }

                            <label class="w-100 mb-3" style="cursor: pointer;">
                                <div class="bg-black rounded-3 p-3 text-center border border-secondary border-dashed"
                                     style="border-style: dashed !important;">
                                    <i class="bi bi-cloud-upload" style="font-size: 32px; color: #6c757d;"></i>
                                    <p class="text-muted small mb-0 mt-1">Bấm để chọn ảnh (tối đa 5MB)</p>
                                </div>
                                <InputFile OnChange="HandleMenuImageUpload" accept="image/*"
                                           style="display: none;" />
                            </label>

                            @* Preview ảnh *@
                            @if (!string.IsNullOrEmpty(formImageUrl))
                            {
                                <div class="text-center bg-black rounded-3 p-2 border border-secondary position-relative">
                                    <img src="@formImageUrl"
                                         style="max-height: 180px; border-radius: 8px; object-fit: cover;" />
                                    <button class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1"
                                            style="padding: 0.1rem 0.4rem;"
                                            @onclick="() => formImageUrl = string.Empty">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4"
                            @onclick="HideModal">
                        Hủy
                    </button>
                    <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm"
                            @onclick="SaveItem" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-floppy me-2"></i> Lưu món ăn
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── State: Danh sách ────────────────────────────
    private List<MenuItemLocal> menuList = new();

    // ── State: Modal ────────────────────────────────
    private bool isShowModal = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string modalError = string.Empty;

    // ── State: Form fields ──────────────────────────
    // Dùng từng biến riêng thay vì 1 object phức tạp
    // → tránh lỗi binding khi object bị null
    private int formId = 0;
    private string formName = string.Empty;
    private decimal? formPrice;
    private string formCategory = "Món nướng";
    private string formDescription = string.Empty;
    private string formImageUrl = string.Empty;

    // ── State: Upload ───────────────────────────────
    private bool isUploadingImage = false;

    // ═════════════════════════════════════════════════
    //  LIFECYCLE
    // ═════════════════════════════════════════════════

    protected override void OnInitialized()
    {
        // TODO: Thay bằng gọi Service lấy từ DB
        // menuList = await FoodService.GetByPoiIdAsync(currentPoiId);
        menuList = GetDemoData();
    }

    // ═════════════════════════════════════════════════
    //  MODAL
    // ═════════════════════════════════════════════════

    private void ShowAddModal()
    {
        isEditing = false;
        modalError = string.Empty;
        formId = 0;
        formName = string.Empty;
        formPrice = null;
        formCategory = "Món nướng";
        formDescription = string.Empty;
        formImageUrl = string.Empty;
        isShowModal = true;
    }

    private void ShowEditModal(MenuItemLocal item)
    {
        isEditing = true;
        modalError = string.Empty;
        formId = item.Id;
        formName = item.Name;
        formPrice = item.Price;
        formCategory = item.Category;
        formDescription = item.Description;
        formImageUrl = item.ImageUrl;
        isShowModal = true;
    }

    private void HideModal() => isShowModal = false;

    // ═════════════════════════════════════════════════
    //  UPLOAD ẢNH — ĐÃ FIX LỖI SẬP WEB
    // ═════════════════════════════════════════════════

    private async Task HandleMenuImageUpload(InputFileChangeEventArgs e)
    {
        isUploadingImage = true;
        modalError = string.Empty;
        StateHasChanged();

        try
        {
            var file = e.File;
            long maxSize = 5 * 1024 * 1024; // 5MB

            // ── Validate ────────────────────────────
            if (file.Size > maxSize)
            {
                modalError = $"Ảnh vượt quá 5MB ({(file.Size / 1024 / 1024.0):F1}MB).";
                return;
            }

            if (!file.ContentType.StartsWith("image/"))
            {
                modalError = "File không phải hình ảnh.";
                return;
            }

            // ── Tạo đường dẫn lưu file ─────────────
            var extension = Path.GetExtension(file.Name).ToLower();
            var safeName = $"{Guid.NewGuid()}{extension}";
            var uploadsDir = Path.Combine(Env.WebRootPath, "uploads", "menu");

            if (!Directory.Exists(uploadsDir))
                Directory.CreateDirectory(uploadsDir);

            var filePath = Path.Combine(uploadsDir, safeName);

            // ── Ghi file — ĐIỂM FIX CHÍNH ──────────
            // Phải truyền maxAllowedSize vào OpenReadStream()
            // Mặc định nó chỉ cho 512KB → lỗi với ảnh lớn
            await using var readStream = file.OpenReadStream(maxAllowedSize: maxSize);
            await using var writeStream = new FileStream(filePath, FileMode.Create);
            await readStream.CopyToAsync(writeStream);

            // ── Gán URL vào form ────────────────────
            formImageUrl = $"/uploads/menu/{safeName}";
        }
        catch (Exception ex)
        {
            modalError = $"Lỗi upload: {ex.Message}";
            Console.WriteLine($"Menu image upload error: {ex}");
        }
        finally
        {
            isUploadingImage = false;
            StateHasChanged();
        }
    }

    // ═════════════════════════════════════════════════
    //  SAVE / TOGGLE
    // ═════════════════════════════════════════════════

    private async Task SaveItem()
    {
        if (string.IsNullOrWhiteSpace(formName))
        {
            modalError = "Tên món ăn không được để trống.";
            return;
        }

        isSaving = true;
        modalError = string.Empty;

        try
        {
            if (isEditing)
            {
                var existing = menuList.FirstOrDefault(m => m.Id == formId);
                if (existing != null)
                {
                    existing.Name = formName;
                    existing.Price = formPrice;
                    existing.Category = formCategory;
                    existing.Description = formDescription;
                    existing.ImageUrl = formImageUrl;
                }
            }
            else
            {
                menuList.Add(new MenuItemLocal
                {
                    Id = menuList.Any() ? menuList.Max(m => m.Id) + 1 : 1,
                    Name = formName,
                    Price = formPrice,
                    Category = formCategory,
                    Description = formDescription,
                    ImageUrl = formImageUrl,
                    IsHidden = false
                });
            }

            // TODO: Gọi FoodService.SaveAsync() để lưu DB

            HideModal();
        }
        catch (Exception ex)
        {
            modalError = $"Lỗi lưu: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ToggleStatus(MenuItemLocal item)
    {
        item.IsHidden = !item.IsHidden;
        // TODO: Gọi FoodService.ToggleAsync(item.Id)
    }

    // ═════════════════════════════════════════════════
    //  DEMO DATA (thay bằng DB sau)
    // ═════════════════════════════════════════════════

    private List<MenuItemLocal> GetDemoData() => new()
    {
        new() { Id = 1, Name = "Ốc hương rang muối ớt", Price = 120000, Category = "Món nướng", IsHidden = false },
        new() { Id = 2, Name = "Sò điệp nướng mỡ hành", Price = 80000, Category = "Món nướng", IsHidden = false },
        new() { Id = 3, Name = "Nghêu hấp sả", Price = 65000, Category = "Món hấp", IsHidden = false },
    };

    // ═════════════════════════════════════════════════
    //  MODEL NỘI BỘ
    // ═════════════════════════════════════════════════

    private class MenuItemLocal
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public decimal? Price { get; set; }
        public string Category { get; set; } = "Món nướng";
        public string Description { get; set; } = string.Empty;
        public string ImageUrl { get; set; } = string.Empty;
        public bool IsHidden { get; set; }
    }
}
