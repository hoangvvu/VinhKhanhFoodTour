@page "/vendor/thu-nhap"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Data
@using VKFoodTour.Infrastructure.Entities
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthStateProvider
@inject PoiService PoiService
@inject ApplicationDbContext Db

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">THỐNG KÊ DOANH THU & TƯƠNG TÁC</h2>
            <span style="color: #4a4a5a; font-size: 13px;"><i class="bi bi-bar-chart-line me-1"></i>Thống kê hoạt động hôm nay</span>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <p style="color:#4a4a5a;font-size:13px;letter-spacing:1px;margin-top:12px;">ĐANG TẢI...</p>
        </div>
    }
    else if (currentPoiId == 0)
    {
        <div style="background:rgba(200,55,45,0.08);border:1px solid rgba(200,55,45,0.2);border-radius:12px;color:#f87171;padding:12px 16px;">
            <i class="bi bi-exclamation-triangle me-2"></i>
            Tài khoản chưa được gán quán. Vui lòng liên hệ Admin.
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            @* ── Card 1: Doanh thu (N/A vì chưa có bảng thanh toán) ── *@
            <div class="col-md-3">
                <div class="dash-card p-4" style="border-left: 4px solid #198754 !important;">
                    <div style="background:rgba(25,135,84,0.12);border-radius:10px;padding:10px;width:fit-content;margin-bottom:12px;">
                        <i class="bi bi-currency-dollar" style="color:#4ade80;font-size:1.3rem;"></i>
                    </div>
                    <h2 class="text-white fw-bold mb-1">N/A</h2>
                    <div style="color:#4a4a5a;font-size:12px;letter-spacing:0.5px;">DOANH THU HÔM NAY</div>
                    <small style="color:#4a4a5a;font-size:11px;">Chưa có hệ thống thanh toán</small>
                </div>
            </div>

            @* ── Card 2: Lượt quét QR hôm nay ── *@
            <div class="col-md-3">
                <div class="dash-card p-4" style="border-left: 4px solid #E8A020 !important;">
                    <div style="background:rgba(232,160,32,0.12);border-radius:10px;padding:10px;width:fit-content;margin-bottom:12px;">
                        <i class="bi bi-qr-code-scan" style="color:#E8A020;font-size:1.3rem;"></i>
                    </div>
                    <h2 class="text-white fw-bold mb-1">@qrScanCount</h2>
                    <div style="color:#4a4a5a;font-size:12px;letter-spacing:0.5px;">LƯỢT QUÉT QR HÔM NAY</div>
                </div>
            </div>

            @* ── Card 3: Lượt nghe Audio hôm nay ── *@
            <div class="col-md-3">
                <div class="dash-card p-4" style="border-left: 4px solid #0dcaf0 !important;">
                    <div style="background:rgba(13,202,240,0.12);border-radius:10px;padding:10px;width:fit-content;margin-bottom:12px;">
                        <i class="bi bi-headphones" style="color:#0dcaf0;font-size:1.3rem;"></i>
                    </div>
                    <h2 class="text-white fw-bold mb-1">@audioPlayCount</h2>
                    <div style="color:#4a4a5a;font-size:12px;letter-spacing:0.5px;">LƯỢT NGHE AUDIO HÔM NAY</div>
                </div>
            </div>

            @* ── Card 4: Đánh giá trung bình ── *@
            <div class="col-md-3">
                <div class="dash-card p-4" style="border-left: 4px solid #facc15 !important;">
                    <div style="background:rgba(250,204,21,0.12);border-radius:10px;padding:10px;width:fit-content;margin-bottom:12px;">
                        <i class="bi bi-star-fill" style="color:#facc15;font-size:1.3rem;"></i>
                    </div>
                    @if (averageRating > 0)
                    {
                        <h2 class="text-white fw-bold mb-1">
                            @averageRating.ToString("0.0") <i class="bi bi-star-fill" style="color:#facc15;font-size:0.9rem;"></i>
                        </h2>
                        <div style="color:#4a4a5a;font-size:12px;letter-spacing:0.5px;">ĐÁNH GIÁ TRUNG BÌNH</div>
                        <small style="color:#4a4a5a;font-size:11px;">(@totalReviews đánh giá)</small>
                    }
                    else
                    {
                        <h2 class="text-white fw-bold mb-1">—</h2>
                        <div style="color:#4a4a5a;font-size:12px;letter-spacing:0.5px;">ĐÁNH GIÁ TRUNG BÌNH</div>
                        <small style="color:#4a4a5a;font-size:11px;">Chưa có đánh giá</small>
                    }
                </div>
            </div>
        </div>

        @* ── Danh sách đánh giá gần đây ── *@
        <div class="dash-card p-4">
            <div class="dash-label mb-3"><i class="bi bi-chat-left-quote me-2"></i>ĐÁNH GIÁ GẦN ĐÂY</div>

            @if (recentReviews.Any())
            {
                @foreach (var review in recentReviews)
                {
                    <div class="d-flex justify-content-between align-items-start mb-3 pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center mb-1">
                                @* Hiển thị sao *@
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var starIndex = i;
                                    <i class="bi @(starIndex <= review.Rating ? "bi-star-fill text-warning" : "bi-star text-secondary")"
                                       style="font-size: 0.85rem; margin-right: 2px;"></i>
                                }
                                <span class="text-muted small ms-2">@review.Rating/5</span>
                            </div>
                            <div class="text-white small">
                                @(string.IsNullOrWhiteSpace(review.Comment) ? "(Không có nhận xét)" : review.Comment)
                            </div>
                        </div>
                        <div class="text-muted small text-end ms-3" style="min-width: 100px;">
                            <i class="bi bi-clock-history me-1"></i>@FormatTimeAgo(review.CreatedAt)
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-emoji-smile fs-1 d-block mb-2"></i>
                    Chưa có đánh giá nào. Hãy chờ khách hàng ghé thăm quán bạn!
                </div>
            }
        </div>
    }
</div>

@code {
    // ── State ──────────────────────────────
    private bool isLoading = true;
    private int currentPoiId;

    // Thống kê tracking
    private int qrScanCount;
    private int audioPlayCount;

    // Đánh giá
    private double averageRating;
    private int totalReviews;
    private List<Review> recentReviews = new();

    // ── Lifecycle ──────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDataAsync();
            isLoading = false;
            StateHasChanged();
        }
    }

    // ── Load dữ liệu từ DB ────────────────
    private async Task LoadDataAsync()
    {
        // 1. Lấy UserId từ Authentication (giống ThongTinQuan.razor)
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (!int.TryParse(userIdStr, out int userId)) return;

        // 2. Lấy POI của vendor
        var poi = await PoiService.GetPoiByOwnerIdAsync(userId);
        if (poi == null) return;

        currentPoiId = poi.PoiId;

        // 3. Mốc thời gian: đầu ngày hôm nay
        var today = DateTime.Today;

        // 4. Thống kê TRACKING_LOGS hôm nay
        qrScanCount = await Db.TrackingLogs
            .AsNoTracking()
            .CountAsync(t => t.PoiId == currentPoiId
                          && t.EventType == "qr_scan"
                          && t.CreatedAt >= today);

        audioPlayCount = await Db.TrackingLogs
            .AsNoTracking()
            .CountAsync(t => t.PoiId == currentPoiId
                          && t.EventType == "listen_start"
                          && t.CreatedAt >= today);

        // 5. Thống kê REVIEWS
        var reviewQuery = Db.Reviews
            .AsNoTracking()
            .Where(r => r.PoiId == currentPoiId);

        totalReviews = await reviewQuery.CountAsync();

        if (totalReviews > 0)
        {
            averageRating = await reviewQuery.AverageAsync(r => (double)r.Rating);
        }

        // 6. Lấy 10 đánh giá gần đây nhất
        recentReviews = await reviewQuery
            .OrderByDescending(r => r.CreatedAt)
            .Take(10)
            .ToListAsync();
    }

    // ── Helper: format "X phút trước" ─────
    private string FormatTimeAgo(DateTime? dateTime)
    {
        if (dateTime == null) return "N/A";

        var span = DateTime.Now - dateTime.Value;

        if (span.TotalMinutes < 1) return "Vừa xong";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} phút trước";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} giờ trước";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays} ngày trước";

        return dateTime.Value.ToString("dd/MM/yyyy");
    }
}
