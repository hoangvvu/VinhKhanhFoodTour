@page "/vendor/thu-nhap"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Vendor")]
@rendermode InteractiveServer

<div class="container-fluid p-4">
    <h3 class="text-white fw-bold mb-4">THỐNG KÊ DOANH THU & TƯƠNG TÁC</h3>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card bg-dark-card border-0 p-3 shadow-sm h-100" style="border-radius: 12px; border-left: 4px solid #198754 !important;">
                <div class="text-muted small fw-bold mb-1">DOANH THU HÔM NAY</div>
                <h4 class="text-white fw-bold mb-0">1,250,000 ₫</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark-card border-0 p-3 shadow-sm h-100" style="border-radius: 12px; border-left: 4px solid #E8A020 !important;">
                <div class="text-muted small fw-bold mb-1">LƯỢT QUÉT QR</div>
                <h4 class="text-white fw-bold mb-0">45 lượt</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark-card border-0 p-3 shadow-sm h-100" style="border-radius: 12px; border-left: 4px solid #0dcaf0 !important;">
                <div class="text-muted small fw-bold mb-1">LƯỢT NGHE AUDIO</div>
                <h4 class="text-white fw-bold mb-0">112 lượt</h4>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark-card border-0 p-3 shadow-sm h-100" style="border-radius: 12px; border-left: 4px solid #C8372D !important;">
                <div class="text-muted small fw-bold mb-1">MÓN BÁN CHẠY NHẤT</div>
                <h6 class="text-white fw-bold mb-0 mt-2">Ốc hương bơ tỏi</h6>
            </div>
        </div>
    </div>

    <div class="card bg-dark-card border-0 p-4 shadow-sm" style="border-radius: 16px;">
        <h6 class="text-white fw-bold mb-4 border-bottom border-secondary pb-3">GIAO DỊCH GẦN ĐÂY</h6>
        
        <div class="d-flex justify-content-between align-items-center mb-3 text-muted border-bottom border-secondary pb-2">
            <div><i class="bi bi-clock-history me-2"></i>15 phút trước</div>
            <div class="text-white">Bàn số 04 - Thanh toán Momo</div>
            <div class="text-success fw-bold">+ 345,000 ₫</div>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3 text-muted border-bottom border-secondary pb-2">
            <div><i class="bi bi-clock-history me-2"></i>1 giờ trước</div>
            <div class="text-white">Bàn số 12 - Tiền mặt</div>
            <div class="text-success fw-bold">+ 120,000 ₫</div>
        </div>
    </div>
</div>