@page "/logout"
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation

@* ══════════════════════════════════════════════════════════
   TRANG ĐĂNG XUẤT — Static SSR (không InteractiveServer)
   Cũng cần HttpContext để gọi SignOutAsync()
   ══════════════════════════════════════════════════════════ *@

<div style="background-color: #0F0E0E; min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <p style="color: #8A8078;">Đang đăng xuất...</p>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;

        if (httpContext is not null)
        {
            // Xóa Cookie Auth
            await httpContext.SignOutAsync(CookieAuthenticationDefaults.AuthenticationScheme);
        }

        // Redirect về trang login
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
