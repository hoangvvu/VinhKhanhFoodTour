@page "/admin/pois"
@using Microsoft.AspNetCore.Authorization
@using VKFoodTour.Infrastructure.Entities
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject PoiService PoiService
@inject IJSRuntime JS
@inject AuthService AuthService

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">Gian hàng</h2>
            <span style="color: #4a4a5a; font-size: 13px;"><i class="bi bi-shop me-1"></i>Quản lý danh sách đối tác</span>
        </div>
        @* Đã loại bỏ nút Thêm gian hàng vì nó được tạo tự động khi thêm Vendor *@
    </div>

    <div class="dash-card p-4 mb-4">
        <div class="d-flex gap-3">
            <input type="text" class="form-control dash-input rounded-pill ps-4 w-50"
                   placeholder="Tìm tên quán..."
                   @bind="searchText"
                   @bind:event="oninput" />

            <select class="form-select dash-input rounded-pill w-25" @bind="filterStatus">
                <option value="all">Tất cả trạng thái</option>
                <option value="active">Đang hoạt động</option>
                <option value="inactive">Đang bị khóa</option>
            </select>

            <select class="form-select dash-input rounded-pill w-25" @bind="filterApproval">
                <option value="all">Tất cả (Phê duyệt)</option>
                <option value="Pending">Chờ duyệt</option>
                <option value="Approved">Đã duyệt</option>
                <option value="Rejected">Từ chối</option>
            </select>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <p style="color:#4a4a5a;font-size:13px;letter-spacing:1px;margin-top:12px;">ĐANG TẢI...</p>
        </div>
    }
    else if (!FilteredPois.Any())
    {
        <div class="dash-card p-5 text-center">
            <p style="color:#4a4a5a;" class="fs-5">Không tìm thấy gian hàng nào.</p>
        </div>
    }
    else
    {
        <div class="dash-card" style="overflow:hidden;">
            <div class="table-responsive">
                <table class="table dash-table mb-0">
                    <thead>
                        <tr style="background:rgba(0,0,0,0.4);">
                            <th class="ps-4" style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;">GIAN HÀNG</th>
                            <th style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;">CHỦ & GMAIL</th>
                            <th style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;">TRẠNG THÁI</th>
                            <th style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;">ƯU TIÊN</th>
                            <th style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;">GEOFENCE</th>
                            <th class="text-end pe-4" style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;">HÀNH ĐỘNG</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredPois)
                        {
                            <tr>
                                <td class="ps-4">
                                    <strong style="color:#F0EBE3;">@item.Name</strong><br />
                                    <small style="color:#4a4a5a;">@item.Phone</small>
                                </td>
                                <td>
                                    <small style="color:#4a4a5a;">@GetOwnerLabel(item.OwnerId)</small>
                                </td>
                                <td>
                                    <div class="mb-1">
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle" style="font-size: 10px;">CHỜ DUYỆT</span>
                                        }
                                        else if (item.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle" style="font-size: 10px;">TỪ CHỐI</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle" style="font-size: 10px;">ĐÃ DUYỆT</span>
                                        }
                                    </div>
                                    @if (item.IsActive)
                                    {
                                        <span class="text-success small" style="font-size: 11px;"><i class="bi bi-circle-fill me-1" style="font-size:7px;"></i> Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger small" style="font-size: 11px;"><i class="bi bi-circle-fill me-1" style="font-size:7px;"></i> ĐÃ KHÓA</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi bi-star-fill me-1" style="font-size: 12px; color: @(i <= item.Priority ? GetPriorityColor(item.Priority) : "#1a1a24")"></i>
                                        }
                                    </div>
                                    <small style="color:#4a4a5a;">Mức @item.Priority</small>
                                </td>
                                <td>
                                    <span class="badge bg-info-subtle text-info border border-info-subtle">
                                        @item.Radius m
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        @if (item.Status != "Approved")
                                        {
                                            <button class="btn btn-sm btn-success rounded-pill px-3" @onclick="() => ShowApproveModal(item)">Duyệt</button>
                                        }
                                        <button class="btn btn-sm btn-outline-light rounded-pill px-3" title="Sửa thông tin" @onclick="() => ShowEditModal(item)">
                                            <i class="bi bi-pencil me-1"></i>Sửa
                                        </button>
                                        
                                        @if (item.IsActive)
                                        {
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => ShowHideConfirm(item)">
                                                <i class="bi bi-lock-fill me-1"></i>Khóa
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success rounded-pill px-3" @onclick="() => ToggleActive(item.PoiId)">
                                                <i class="bi bi-unlock-fill me-1"></i>Mở
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* Modal Admin Duyệt *@
@if (isApproveModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.8); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0" style="background:#1a1a24; border-radius:20px; border: 1px solid rgba(255,255,255,0.1);">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-white">Phê duyệt gian hàng</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => isApproveModalVisible = false"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted small">Thiết lập mức ưu tiên cho <strong>@targetPoi?.Name</strong>:</p>
                    <select class="form-select dash-input rounded-3" @bind="targetPriority">
                        <option value="5">5 - VIP</option>
                        <option value="4">4 - Lớn</option>
                        <option value="3">3 - Thường</option>
                        <option value="2">2 - Nhỏ</option>
                        <option value="1">1 - Thấp</option>
                    </select>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-outline-light rounded-pill px-4" @onclick="() => isApproveModalVisible = false">Hủy</button>
                    <button class="btn btn-success rounded-pill px-4 fw-bold" @onclick="ApprovePoiAction">Xác nhận Duyệt</button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal Admin Từ chối *@
@if (isRejectModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.8); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0" style="background:#1a1a24; border-radius:20px; border: 1px solid rgba(255,255,255,0.1);">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-white">Từ chối gian hàng</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => isRejectModalVisible = false"></button>
                </div>
                <div class="modal-body p-4">
                    <textarea class="form-control dash-input rounded-3" rows="3" @bind="targetNote" placeholder="Lý do từ chối..."></textarea>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-outline-light rounded-pill px-4" @onclick="() => isRejectModalVisible = false">Hủy</button>
                    <button class="btn btn-danger rounded-pill px-4 fw-bold" @onclick="RejectPoiAction">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
}

@* Modal Sửa (Rút gọn) *@
@if (isModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.8); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
             <div class="modal-content border-0 shadow-lg" style="background:#1a1a24; border-radius:30px; border: 1px solid rgba(255,255,255,0.08);">
                 <div class="modal-header p-4" style="border-bottom:1px solid rgba(255,255,255,0.05);">
                    <h4 class="modal-title fw-bold text-white">Thông Tin Quản Trị</h4>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label text-white-50 small fw-bold">TÊN GIAN HÀNG</label>
                            <input type="text" class="form-control dash-input p-3" @bind="editingPoi.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-white-50 small fw-bold">SỐ ĐIỆN THOẠI</label>
                            <input type="text" class="form-control dash-input p-3" @bind="editingPoi.Phone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-white-50 small fw-bold">ƯU TIÊN</label>
                             <select class="form-select dash-input p-3" @bind="editingPoi.Priority">
                                <option value="5">5 - VIP</option>
                                <option value="4">4 - Lớn</option>
                                <option value="3">3 - Thường</option>
                                <option value="2">2 - Nhỏ</option>
                                <option value="1">1 - Thấp</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-white-50 small fw-bold">BÁN KÍNH GEOFENCE (m)</label>
                            <input type="number" class="form-control dash-input p-3" min="5" max="200" @bind="editingPoi.Radius" />
                        </div>
                        <div class="col-12">
                            <label class="form-label text-white-50 small fw-bold">CHỦ GIAN HÀNG</label>
                            <select class="form-select dash-input p-3" @bind="editingOwnerIdText">
                                <option value="">-- Chưa gán chủ --</option>
                                @foreach (var v in vendorUsers) { <option value="@v.UserId">@v.Name (@v.Email)</option> }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer p-4 border-0 pt-0">
                    <button class="btn btn-outline-light rounded-pill px-4" @onclick="HideModal">Hủy</button>
                    <button class="btn btn-danger rounded-pill px-5 fw-bold shadow-sm" @onclick="SavePoi" disabled="@isSaving">Lưu thay đổi</button>
                </div>
             </div>
        </div>
    </div>
}

@* Modal Xác nhận Khóa *@
@if (isHideConfirmVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.8); backdrop:blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="background:#1a1a24; border-radius:20px; border: 1px solid rgba(255,255,255,0.1);">
                <div class="modal-body p-5 text-center">
                    <i class="bi bi-lock-fill text-danger display-4 mb-4 d-block"></i>
                    <h4 class="fw-bold text-white mb-3">Khóa gian hàng?</h4>
                    <p class="text-muted mb-5">Gian hàng <strong>@hidingPoi?.Name</strong> sẽ bị tạm dừng và không hiển thị trên bản đồ.</p>
                    <div class="d-flex justify-content-center gap-3">
                        <button class="btn btn-outline-light rounded-pill px-4" @onclick="HideHideConfirm">Hủy</button>
                        <button class="btn btn-danger rounded-pill px-4 fw-bold" @onclick="HidePoiAsync" disabled="@isSaving">Xác nhận Khóa</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .dash-table th { border-top: none !important; border-bottom: 2px solid rgba(255,255,255,0.05) !important; padding: 1.2rem 0.75rem !important; }
    .dash-table td { border-bottom: 1px solid rgba(255,255,255,0.03) !important; padding: 1.2rem 0.75rem !important; vertical-align: middle !important; }
    .dash-table tr:hover { background: rgba(255,255,255,0.01); }
    .dash-input { background: #0f0f13 !important; border: 1px solid rgba(255,255,255,0.08) !important; color: #F0EBE3 !important; }
</style>

@code {
    private List<Poi> pois = new();
    private List<User> vendorUsers = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string searchText = "";
    private string filterStatus = "all";
    private string filterApproval = "all";

    private bool isModalVisible = false;
    private bool isEditing = false;
    private string errorMessage = "";
    private Poi editingPoi = new();
    private string editingOwnerIdText = "";

    private bool isHideConfirmVisible = false;
    private Poi? hidingPoi;

    private bool isApproveModalVisible = false;
    private bool isRejectModalVisible = false;
    private Poi? targetPoi;
    private int targetPriority = 3;
    private string targetNote = "";

    private DotNetObjectReference<PoiList>? dotNetRef;

    private IEnumerable<Poi> FilteredPois => pois
        .Where(p => string.IsNullOrWhiteSpace(searchText) || p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        .Where(p => filterStatus == "all" || (filterStatus == "active" && p.IsActive) || (filterStatus == "inactive" && !p.IsActive))
        .Where(p => filterApproval == "all" || p.Status == filterApproval);

    protected override async Task OnInitializedAsync() { await LoadData(); }

    private async Task LoadData() {
        isLoading = true;
        pois = await PoiService.GetAllAsync();
        vendorUsers = await AuthService.GetAllUsersAsync();
        isLoading = false;
    }

    private void ShowEditModal(Poi poi) {
        isEditing = true;
        editingPoi = new Poi {
            PoiId = poi.PoiId,
            Name = poi.Name,
            Address = poi.Address,
            Phone = poi.Phone,
            Latitude = poi.Latitude,
            Longitude = poi.Longitude,
            Radius = poi.Radius,
            Priority = poi.Priority,
            OwnerId = poi.OwnerId,
            IsActive = poi.IsActive,
            Status = poi.Status,
            RejectionNote = poi.RejectionNote
        };
        editingOwnerIdText = poi.OwnerId?.ToString() ?? "";
        isModalVisible = true;
    }

    private void HideModal() { isModalVisible = false; }

    private async Task SavePoi() {
        if (int.TryParse(editingOwnerIdText, out var oid)) editingPoi.OwnerId = oid; else editingPoi.OwnerId = null;
        editingPoi.Radius = Math.Clamp(editingPoi.Radius, 5, 200);
        editingPoi.Priority = Math.Clamp(editingPoi.Priority, 1, 5);
        isSaving = true;
        await PoiService.UpdateAsync(editingPoi);
        HideModal(); await LoadData();
        isSaving = false;
    }

    private void ShowApproveModal(Poi poi) { targetPoi = poi; targetPriority = 3; isApproveModalVisible = true; }
    private async Task ApprovePoiAction() {
        if (targetPoi == null) return;
        await PoiService.ApprovePoiAsync(targetPoi.PoiId, targetPriority);
        isApproveModalVisible = false; await LoadData();
    }

    private void ShowRejectModal(Poi poi) { targetPoi = poi; targetNote = ""; isRejectModalVisible = true; }
    private async Task RejectPoiAction() {
        if (targetPoi == null) return;
        await PoiService.RejectPoiAsync(targetPoi.PoiId, targetNote);
        isRejectModalVisible = false; await LoadData();
    }

    private void ShowHideConfirm(Poi poi) { hidingPoi = poi; isHideConfirmVisible = true; }
    private void HideHideConfirm() { isHideConfirmVisible = false; }
    private async Task HidePoiAsync() { if (hidingPoi != null) await PoiService.HideStallAsync(hidingPoi.PoiId); HideHideConfirm(); await LoadData(); }

    private async Task ToggleActive(int id) { await PoiService.ToggleActiveAsync(id); await LoadData(); }

    private string GetOwnerLabel(int? ownerId) {
        if (ownerId == null) return "Chưa gán";
        var u = vendorUsers.FirstOrDefault(x => x.UserId == ownerId);
        return u == null ? $"User #{ownerId}" : $"{u.Name}";
    }

    private string GetPriorityColor(int p) => p switch { 5 => "#ff4d4d", 4 => "#ff8c1a", 3 => "#ffff4d", 2 => "#4dff4d", _ => "#8A8078" };

    public async ValueTask DisposeAsync() { dotNetRef?.Dispose(); }
}
