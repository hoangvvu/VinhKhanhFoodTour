@page "/admin/pois"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject PoiService PoiService

@* ══════════════════════════════════════════════════════════════
   PHẦN 1: HEADER — Giữ nguyên giao diện gốc của bạn
   ══════════════════════════════════════════════════════════════ *@

<div class="container-fluid p-4" style="background-color: #f8f9fa; min-height: 100vh;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold">Gian hàng</h3>
        <div class="d-flex align-items-center gap-3">
            <div class="position-relative">
                <input type="text" class="form-control rounded-pill border-0 shadow-sm ps-4" placeholder="Tìm kiếm...">
                <span class="bi bi-search position-absolute text-muted" style="top: 10px; right: 15px;"></span>
            </div>
            <button class="btn btn-link text-muted position-relative">
                <span class="bi bi-bell fs-5"></span>
                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
            </button>
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-danger rounded-circle p-3 fs-6">A</span>
                <div class="small">
                    <strong>Admin</strong><br>
                    <small class="text-muted">Quản trị viên</small>
                </div>
            </div>
        </div>
    </div>

    @* ══════════════════════════════════════════════════════════
       PHẦN 2: THANH LỌC + NÚT THÊM
       Thay đổi: Thêm @bind cho ô tìm kiếm và dropdown lọc
       ══════════════════════════════════════════════════════════ *@

    <div class="card card-admin mb-4 border-0 shadow-sm" style="border-radius: 15px;">
        <div class="card-body d-flex gap-3">
            <input type="text" class="form-control rounded-pill bg-light border-0 ps-4 w-50"
                   placeholder="Tìm gian hàng..."
                   @bind="searchText"
                   @bind:event="oninput" />

            <select class="form-select rounded-pill bg-light border-0 w-25"
                    @bind="filterStatus">
                <option value="all">Tất cả trạng thái</option>
                <option value="active">Đang hoạt động</option>
                <option value="inactive">Đã tắt</option>
            </select>

            <button class="btn btn-dark rounded-pill px-4 ms-auto" @onclick="ShowAddModal">
                + Thêm gian hàng
            </button>
        </div>
    </div>

    @* ══════════════════════════════════════════════════════════
       PHẦN 3: BẢNG DANH SÁCH — Đọc từ DB thay vì data giả
       Thay đổi: 
       - Dùng FilteredPois (có lọc) thay vì list tĩnh
       - Trạng thái đọc từ IsActive
       - Thêm cột Hành động (Sửa/Xóa)
       ══════════════════════════════════════════════════════════ *@

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang tải dữ liệu...</p>
        </div>
    }
    else if (!FilteredPois.Any())
    {
        <div class="card card-admin border-0 shadow-sm text-center py-5" style="border-radius: 15px;">
            <p class="text-muted fs-5">Không tìm thấy gian hàng nào.</p>
        </div>
    }
    else
    {
        <div class="card card-admin border-0 shadow-sm" style="border-radius: 15px;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0 table-admin table-hover align-middle">
                        <thead>
                            <tr>
                                <th class="ps-4">GIAN HÀNG</th>
                                <th>ĐỊA CHỈ</th>
                                <th>TỌA ĐỘ</th>
                                <th>BÁN KÍNH</th>
                                <th>ƯU TIÊN</th>
                                <th>TRẠNG THÁI</th>
                                <th class="text-end pe-4">HÀNH ĐỘNG</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in FilteredPois)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <strong>@item.Name</strong><br />
                                        <small class="text-muted">@item.Phone</small>
                                    </td>
                                    <td>@item.Address</td>
                                    <td>
                                        <small class="text-muted">
                                            @item.Latitude.ToString("F8")<br />
                                            @item.Longitude.ToString("F8")
                                        </small>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary rounded-pill">
                                            @item.Radius m
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-warning-subtle text-warning rounded-pill">
                                            @item.Priority
                                        </span>
                                    </td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success rounded-pill"
                                                  style="cursor: pointer;"
                                                  @onclick="() => ToggleActive(item.PoiId)">
                                                Đã bật
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary rounded-pill"
                                                  style="cursor: pointer;"
                                                  @onclick="() => ToggleActive(item.PoiId)">
                                                Đã tắt
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <button class="btn btn-sm btn-outline-primary rounded-pill me-1"
                                                @onclick="() => ShowEditModal(item)">
                                            <span class="bi bi-pencil"></span> Sửa
                                        </button>
                                        <button class="btn btn-sm btn-outline-warning rounded-pill"
                                                @onclick="() => ShowHideConfirm(item)">
                                            <span class="bi bi-eye-slash"></span> Ẩn
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@* ══════════════════════════════════════════════════════════════
   PHẦN 4: MODAL THÊM / SỬA — Dùng chung 1 modal
   Thay đổi:
   - Tất cả input đều @bind vào editingPoi
   - Nút submit gọi SavePoi()
   - Title thay đổi theo isEditing (Thêm / Sửa)
   ══════════════════════════════════════════════════════════════ *@

@if (isModalVisible)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-0 pe-4 pt-4">
                    <h5 class="modal-title fw-bold">
                        @(isEditing ? "Sửa gian hàng" : "Thêm gian hàng mới")
                    </h5>
                    <button type="button" class="btn-close" @onclick="HideModal"></button>
                </div>
                <div class="modal-body p-4">
                    @* Hiển thị lỗi nếu có *@
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger rounded-pill text-center">
                            @errorMessage
                        </div>
                    }

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label text-uppercase small fw-bold text-muted">Tên gian hàng</label>
                            <input type="text"
                                   class="form-control rounded-pill bg-light border-0 ps-3 fs-5"
                                   placeholder="VD: Ốc Oanh"
                                   @bind="editingPoi.Name" />
                        </div>
                        <div class="col-12">
                            <label class="form-label text-uppercase small fw-bold text-muted">Địa chỉ</label>
                            <input type="text"
                                   class="form-control rounded-pill bg-light border-0 ps-3 fs-5"
                                   placeholder="Địa chỉ chi tiết"
                                   @bind="editingPoi.Address" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-bold text-muted">Số điện thoại</label>
                            <input type="text"
                                   class="form-control rounded-pill bg-light border-0 ps-3 fs-5"
                                   placeholder="VD: 0901234567"
                                   @bind="editingPoi.Phone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-bold text-muted">Chủ gian hàng (Owner ID)</label>
                            <input type="number"
                                   class="form-control rounded-pill bg-light border-0 ps-3 fs-5"
                                   placeholder="Để trống nếu chưa gán"
                                   @bind="editingPoi.OwnerId" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-bold text-muted">Vĩ độ (Latitude)</label>
                            <input type="number" step="0.00000001"
                                   class="form-control rounded-pill bg-light border-0 ps-3 fs-5"
                                   @bind="editingPoi.Latitude" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-bold text-muted">Kinh độ (Longitude)</label>
                            <input type="number" step="0.00000001"
                                   class="form-control rounded-pill bg-light border-0 ps-3 fs-5"
                                   @bind="editingPoi.Longitude" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-bold text-muted">Bán kính Geofence (m)</label>
                            <input type="number"
                                   class="form-control rounded-pill bg-light border-0 ps-3 fs-5"
                                   min="5" max="200"
                                   @bind="editingPoi.Radius" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small fw-bold text-muted">Mức ưu tiên (1=Cao)</label>
                            <select class="form-select rounded-pill bg-light border-0 ps-3 fs-5"
                                    @bind="editingPoi.Priority">
                                <option value="1">1 - Cao nhất</option>
                                <option value="2">2 - Cao</option>
                                <option value="3">3 - Trung bình</option>
                                <option value="4">4 - Thấp</option>
                                <option value="5">5 - Thấp nhất</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       id="switchActive"
                                       @bind="editingPoi.IsActive" />
                                <label class="form-check-label" for="switchActive">
                                    @(editingPoi.IsActive ? "Đang hoạt động" : "Đã tắt")
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4">
                    <button class="btn text-muted" @onclick="HideModal" disabled="@isSaving">
                        Hủy
                    </button>
                    <button class="btn btn-dark px-4 rounded-pill"
                            @onclick="SavePoi"
                            disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @(isEditing ? "Lưu thay đổi" : "Tạo gian hàng")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════
   PHẦN 5: MODAL XÁC NHẬN ẨN GIAN HÀNG
   ══════════════════════════════════════════════════════════════ *@

@if (isHideConfirmVisible)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-body p-4 text-center">
                    <div class="fs-1 mb-3">👁‍🗨</div>
                    <h5 class="fw-bold">Ẩn gian hàng</h5>
                    <p class="text-muted">
                        Gian hàng <strong>@hidingPoi?.Name</strong> sẽ được đánh dấu <strong>không hoạt động</strong> (ẩn khỏi app khách).<br />
                        <small class="text-secondary">Dữ liệu vẫn lưu trong CSDL; có thể bật lại bằng trạng thái trong bảng hoặc sửa gian hàng.</small>
                    </p>
                    <div class="d-flex justify-content-center gap-2 mt-3">
                        <button class="btn text-muted px-4" @onclick="HideHideConfirm">Hủy</button>
                        <button class="btn btn-warning text-dark rounded-pill px-4"
                                @onclick="HidePoiAsync"
                                disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Ẩn gian hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════
   PHẦN 6: CODE-BEHIND — Toàn bộ logic C#
   ══════════════════════════════════════════════════════════════ *@

@code {
    // ── State: Danh sách ────────────────────────────────
    private List<Poi> allPois = new();
    private bool isLoading = true;

    // ── State: Tìm kiếm & Lọc ──────────────────────────
    private string searchText = string.Empty;
    private string filterStatus = "all";

    // ── State: Modal Thêm/Sửa ──────────────────────────
    private bool isModalVisible = false;
    private bool isEditing = false;           // false = Thêm, true = Sửa
    private bool isSaving = false;
    private string errorMessage = string.Empty;
    private Poi editingPoi = new();

    // ── State: Modal Ẩn ────────────────────────────────
    private bool isHideConfirmVisible = false;
    private Poi? hidingPoi;

    // ═════════════════════════════════════════════════════
    //  COMPUTED PROPERTY: Danh sách đã lọc
    //  Mỗi khi searchText hoặc filterStatus thay đổi,
    //  Blazor tự gọi lại render → property này chạy lại
    // ═════════════════════════════════════════════════════
    private IEnumerable<Poi> FilteredPois
    {
        get
        {
            var query = allPois.AsEnumerable();

            // Lọc theo text tìm kiếm (tên hoặc địa chỉ)
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var term = searchText.Trim().ToLower();
                query = query.Where(p =>
                    p.Name.ToLower().Contains(term) ||
                    (p.Address ?? "").ToLower().Contains(term));
            }

            // Lọc theo trạng thái
            query = filterStatus switch
            {
                "active" => query.Where(p => p.IsActive),
                "inactive" => query.Where(p => !p.IsActive),
                _ => query  // "all" — không lọc
            };

            return query;
        }
    }

    // ═════════════════════════════════════════════════════
    //  LIFECYCLE: Chạy khi page load lần đầu
    // ═════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            allPois = await PoiService.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi tải dữ liệu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    // ═════════════════════════════════════════════════════
    //  MODAL: Hiện/Ẩn
    // ═════════════════════════════════════════════════════

    private void ShowAddModal()
    {
        isEditing = false;
        errorMessage = string.Empty;

        // Tạo POI mới với giá trị mặc định hợp lý
        editingPoi = new Poi
        {
            Radius = 20,
            Priority = 1,
            IsActive = true,
            // Tọa độ mặc định = trung tâm phố Vĩnh Khánh
            Latitude = 10.76012345m,
            Longitude = 106.70298765m
        };

        isModalVisible = true;
    }

    private void ShowEditModal(Poi poi)
    {
        isEditing = true;
        errorMessage = string.Empty;

        // TẠO BẢN SAO để chỉnh sửa — không sửa trực tiếp trên list
        // Nếu user bấm Hủy, data gốc không bị ảnh hưởng
        editingPoi = new Poi
        {
            PoiId = poi.PoiId,
            Name = poi.Name,
            Address = poi.Address,
            Phone = poi.Phone,
            Latitude = poi.Latitude,
            Longitude = poi.Longitude,
            Radius = poi.Radius,
            Priority = poi.Priority,
            OwnerId = poi.OwnerId,
            IsActive = poi.IsActive,
            CreatedAt = poi.CreatedAt
        };

        isModalVisible = true;
    }

    private void HideModal()
    {
        isModalVisible = false;
        errorMessage = string.Empty;
    }

    // ═════════════════════════════════════════════════════
    //  SAVE: Xử lý cả Thêm mới và Cập nhật
    // ═════════════════════════════════════════════════════
    private async Task SavePoi()
    {
        // Validate cơ bản phía client
        if (string.IsNullOrWhiteSpace(editingPoi.Name))
        {
            errorMessage = "Tên gian hàng không được để trống.";
            return;
        }

        // Kiểm tra trùng tên
        var nameExists = await PoiService.IsNameExistsAsync(
            editingPoi.Name.Trim(),
            editingPoi.PoiId  // excludeId: 0 nếu thêm mới, >0 nếu sửa
        );
        if (nameExists)
        {
            errorMessage = $"Tên \"{editingPoi.Name}\" đã tồn tại.";
            return;
        }

        isSaving = true;
        errorMessage = string.Empty;

        try
        {
            if (isEditing)
            {
                var success = await PoiService.UpdateAsync(editingPoi);
                if (!success)
                {
                    errorMessage = "Không tìm thấy gian hàng để cập nhật.";
                    return;
                }
            }
            else
            {
                await PoiService.CreateAsync(editingPoi);
            }

            // Thành công → đóng modal, reload data
            HideModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi lưu dữ liệu: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    // ═════════════════════════════════════════════════════
    //  ẨN gian hàng (soft — IsActive = false)
    // ═════════════════════════════════════════════════════

    private void ShowHideConfirm(Poi poi)
    {
        hidingPoi = poi;
        isHideConfirmVisible = true;
    }

    private void HideHideConfirm()
    {
        isHideConfirmVisible = false;
        hidingPoi = null;
    }

    private async Task HidePoiAsync()
    {
        if (hidingPoi is null)
            return;

        isSaving = true;

        try
        {
            await PoiService.HideStallAsync(hidingPoi.PoiId);
            HideHideConfirm();
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    // ═════════════════════════════════════════════════════
    //  TOGGLE: Bật/Tắt nhanh từ bảng
    // ═════════════════════════════════════════════════════
    private async Task ToggleActive(int poiId)
    {
        await PoiService.ToggleActiveAsync(poiId);
        await LoadData();
    }
}
