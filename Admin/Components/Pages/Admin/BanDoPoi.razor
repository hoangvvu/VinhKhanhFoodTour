@page "/admin/ban-do"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using VKFoodTour.Infrastructure.Data
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@implements IAsyncDisposable

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">BẢN ĐỒ GIAN HÀNG</h2>
            <span style="color: #4a4a5a; font-size: 13px;"><i class="bi bi-map me-1"></i>Các POI đang hoạt động (OpenStreetMap + Leaflet)</span>
        </div>
        <a href="admin/pois" class="btn btn-outline-danger rounded-pill px-4">Quản lý POI</a>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <p style="color:#4a4a5a;font-size:13px;letter-spacing:1px;margin-top:12px;">ĐANG TẢI...</p>
        </div>
    }
    else
    {
        <div class="dash-card p-0 position-relative" style="border-radius: 16px; overflow: hidden;">
            @* Floating Controls *@
            <div class="heatmap-panel">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="form-check form-switch m-0 d-flex align-items-center">
                        <input class="form-check-input me-2" type="checkbox" role="switch" id="heatmapToggle" @bind="showHeatmap" @bind:after="OnToggleHeatmap">
                        <label class="form-check-label text-white small fw-bold" for="heatmapToggle" style="cursor: pointer; user-select: none;">
                            <i class="bi bi-fire text-danger me-1"></i> HEATMAP
                        </label>
                    </div>
                    @if (showHeatmap && isHeatmapLoading)
                    {
                        <div class="spinner-border spinner-border-sm text-danger" role="status"></div>
                    }
                </div>

                @if (showHeatmap)
                {
                    <div class="fade-in pt-2 mt-2 border-top border-secondary">
                        <div class="mb-3">
                            <label class="tiny-label">KHOẢNG THỜI GIAN</label>
                            <select class="form-select form-select-sm dash-select-sm" @bind="hours" @bind:after="ReloadHeatmapAsync">
                                <option value="1">1 giờ qua</option>
                                <option value="6">6 giờ qua</option>
                                <option value="24">24 giờ qua</option>
                                <option value="168">7 ngày qua</option>
                            </select>
                        </div>
                        <div class="mt-3 text-end d-flex justify-content-between align-items-center">
                            <span class="live-indicator @(isHeatmapLoading ? "loading" : "")">
                                <span class="dot"></span> LIVE
                            </span>
                            <span class="text-white-50" style="font-size: 10px;">@totalPoints vùng ghi nhận</span>
                        </div>
                    </div>
                }
            </div>

            <div id="admin-poi-map" style="height: min(70vh, 640px); min-height: 420px;"></div>
        </div>
    }
</div>

<style>
    .heatmap-panel {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 1000;
        background: rgba(15, 15, 15, 0.85);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        padding: 14px 18px;
        border-radius: 16px;
        border: 1px solid rgba(200, 55, 45, 0.4);
        width: 200px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.8), 0 0 15px rgba(200, 55, 45, 0.15);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .live-indicator {
        font-size: 9px;
        font-weight: 800;
        color: #4ade80;
        display: flex;
        align-items: center;
        gap: 4px;
        letter-spacing: 1px;
    }
    .live-indicator .dot {
        width: 6px;
        height: 6px;
        background-color: #4ade80;
        border-radius: 50%;
        display: inline-block;
        animation: pulse 1.5s infinite;
    }
    .live-indicator.loading .dot {
        background-color: #ff4444;
        animation: rotate 1s linear infinite;
        border-radius: 2px;
    }
    @@keyframes pulse {
        0% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.8); }
        100% { opacity: 1; transform: scale(1); }
    }
    @@keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    .tiny-label {
        font-size: 9px;
        color: #8A8078;
        letter-spacing: 0.8px;
        font-weight: 700;
        display: block;
        margin-bottom: 4px;
        text-transform: uppercase;
    }
    .dash-select-sm {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        color: #ddd !important;
        font-size: 11px !important;
        padding-top: 2px !important;
        padding-bottom: 2px !important;
    }
    .dash-select-sm:focus {
        border-color: #C8372D !important;
        box-shadow: none !important;
    }
    .fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private bool isLoading = true;
    private List<PoiMapMarker> _markers = new();
    private bool _mapInitialized;

    // Heatmap states
    private bool showHeatmap;
    private int hours = 24;
    private int totalPoints = 0;
    private bool isHeatmapLoading;

    // Timer & Disposal
    private System.Threading.Timer? _refreshTimer;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var pois = await db.Pois
            .AsNoTracking()
            .Where(p => p.IsActive)
            .OrderBy(p => p.Priority)
            .ThenBy(p => p.Name)
            .ToListAsync();

        _markers = pois.Select(p => new PoiMapMarker
        {
            lat = (double)p.Latitude,
            lng = (double)p.Longitude,
            name = p.Name,
            address = p.Address ?? "",
            radius = p.Radius,
            priority = p.Priority
        }).ToList();

        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initPoiOverviewMap", "admin-poi-map", _markers);
            _mapInitialized = true;

            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                if (showHeatmap && !_disposed)
                {
                    await ReloadHeatmapAsync();
                }
            }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
        }
    }

    private async Task OnToggleHeatmap()
    {
        if (showHeatmap)
        {
            await ReloadHeatmapAsync();
        }
        else
        {
            await JS.InvokeVoidAsync("toggleOverviewHeatmap", false);
        }
    }

    private async Task ReloadHeatmapAsync()
    {
        if (!showHeatmap) return;

        await InvokeAsync(() =>
        {
            isHeatmapLoading = true;
            StateHasChanged();
        });

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var threshold = DateTime.Now.AddHours(-hours);
            // Lấy tất cả sự kiện để phản ánh đúng chỗ nào đông người nhất
            var query = db.TrackingLogs
                .AsNoTracking()
                .Where(t => t.CreatedAt >= threshold && t.Latitude != 0m && t.Longitude != 0m);

            var raw = await query
                .OrderByDescending(t => t.CreatedAt)
                .Take(50_000)
                .Select(t => new { t.Latitude, t.Longitude })
                .ToListAsync();

            var buckets = new Dictionary<(double, double), int>();
            foreach (var row in raw)
            {
                var lat = Math.Round((double)row.Latitude, 4);
                var lng = Math.Round((double)row.Longitude, 4);
                var key = (lat, lng);
                buckets[key] = buckets.TryGetValue(key, out var c) ? c + 1 : 1;
            }

            var maxWeight = buckets.Count > 0 ? buckets.Values.Max() : 1;
            var jsArr = buckets
                .Select(kvp => new double[]
                {
                    kvp.Key.Item1,
                    kvp.Key.Item2,
                    Math.Round((double)kvp.Value / maxWeight, 3)
                })
                .ToArray();

            totalPoints = buckets.Count;
            await InvokeAsync(StateHasChanged); // Update UI count safely
            
            var jsonStr = System.Text.Json.JsonSerializer.Serialize(jsArr);
            await JS.InvokeVoidAsync("updateOverviewHeatmap", jsonStr);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading heatmap: {ex.Message}");
        }
        finally
        {
            await InvokeAsync(() =>
            {
                isHeatmapLoading = false;
                StateHasChanged();
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_refreshTimer is not null) await _refreshTimer.DisposeAsync();
    }

    private sealed class PoiMapMarker
    {
        public double lat { get; set; }
        public double lng { get; set; }
        public string name { get; set; } = "";
        public string address { get; set; } = "";
        public int radius { get; set; }
        public int priority { get; set; }
    }
}
