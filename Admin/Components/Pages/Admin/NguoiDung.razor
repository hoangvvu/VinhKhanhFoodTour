@page "/nguoi-dung"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">NHÂN SỰ QUẢN TRỊ</h2>
            <span style="color: #4a4a5a; font-size: 13px;"><i class="bi bi-clock me-1"></i>Quản lý tài khoản hệ thống</span>
        </div>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="ShowModal">
            <i class="bi bi-person-plus me-2"></i>Thêm người dùng
        </button>
    </div>

    @if (users == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <p style="color:#4a4a5a;font-size:13px;letter-spacing:1px;margin-top:12px;">ĐANG TẢI...</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var user in users)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="dash-card h-100">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-danger rounded-circle d-flex justify-content-center align-items-center me-3 text-white fw-bold shadow" style="width: 50px; height: 50px; font-size: 1.2rem; flex-shrink: 0;">
                                    @(string.IsNullOrWhiteSpace(user.Name) ? "U" : user.Name.Substring(0, 1).ToUpper())
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1 fw-bold" style="color:#F0EBE3;">@user.Name</h6>
                                    <small style="color:#4a4a5a;" class="d-block mb-2">@user.Email</small>
                                    <div>
                                        <span class="badge px-3 py-2" style="@(user.Role == "Admin" ? "background:rgba(232,160,32,0.12);color:#E8A020;border:1px solid rgba(232,160,32,0.25);border-radius:20px;" : "background:rgba(34,197,94,0.12);color:#4ade80;border:1px solid rgba(34,197,94,0.25);border-radius:20px;")">@user.Role</span>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge px-3 py-2 ms-1" style="background:rgba(34,197,94,0.12);color:#4ade80;border:1px solid rgba(34,197,94,0.25);border-radius:20px;">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge px-3 py-2 ms-1" style="background:rgba(107,114,128,0.12);color:#6b7280;border:1px solid rgba(107,114,128,0.25);border-radius:20px;">Đã ẩn</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3 pt-3" style="border-top:1px solid rgba(255,255,255,0.06);">
                                <button type="button"
                                        class="btn btn-sm w-100 rounded-pill @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                        disabled="@(user.UserId == currentUserId || togglingId == user.UserId)"
                                        @onclick="() => ToggleUserAsync(user)">
                                    @if (togglingId == user.UserId)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    <i class="bi @(user.IsActive ? "bi-eye-slash" : "bi-eye") me-1"></i>
                                    @(user.IsActive ? "Ẩn tài khoản" : "Kích hoạt lại")
                                </button>
                                @if (user.UserId == currentUserId)
                                {
                                    <small style="color:#4a4a5a;" class="d-block mt-2 text-center">Không thể ẩn chính mình.</small>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* ── MODAL THÊM NGƯỜI DÙNG & GIAN HÀNG ── *@
@if (isShowModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(4px); overflow-y: auto;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 600px;">
            <div class="modal-content border-0" style="background:#1a1a24;border-radius:20px;border:1px solid rgba(255,255,255,0.08);">
                <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.06);">
                    <h5 class="modal-title fw-bold" style="color:#F0EBE3;">Thêm Nhân Sự & Gian Hàng Mới</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger p-3 small rounded-3"><i class="bi bi-exclamation-triangle me-2"></i>@errorMessage</div>
                    }

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="color:#8A8078;font-size:11px;letter-spacing:1px;font-weight:700;">HỌ VÀ TÊN</label>
                            <input type="text" class="form-control dash-input rounded-3" @bind="newName" placeholder="VD: Nguyễn Văn A" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="color:#8A8078;font-size:11px;letter-spacing:1px;font-weight:700;">EMAIL ĐĂNG NHẬP</label>
                            <input type="email" class="form-control dash-input rounded-3" @bind="newEmail" placeholder="VD: vendor1@vinhkhanh.vn" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="color:#8A8078;font-size:11px;letter-spacing:1px;font-weight:700;">MẬT KHẨU</label>
                            <input type="password" class="form-control dash-input rounded-3" @bind="newPassword" placeholder="Tạo mật khẩu..." />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label" style="color:#8A8078;font-size:11px;letter-spacing:1px;font-weight:700;">PHÂN QUYỀN</label>
                            <select class="form-select dash-input rounded-3" @bind="newRole">
                                <option value="Vendor">Vendor (Chủ quán ăn)</option>
                                <option value="Admin">Admin (Quản trị viên)</option>
                            </select>
                        </div>
                    </div>

                    @if (newRole == "Vendor")
                    {
                        <hr style="border-color: rgba(255,255,255,0.06);" />
                        <h6 class="fw-bold mb-3" style="color:#F0EBE3;">Thông Tin Kèm Theo (Gian Hàng)</h6>
                        
                        <div class="row">
                            <div class="col-12 mb-3">
                                <label class="form-label" style="color:#8A8078;font-size:11px;letter-spacing:1px;font-weight:700;">TÊN QUÁN ĂN (SƠ BỘ)</label>
                                <input type="text" class="form-control dash-input rounded-3" @bind="newPoiName" placeholder="Tên gian hàng..." />
                                <div class="form-text mt-1" style="color:#4a4a5a; font-size: 11px;">Vendor sẽ tự cập nhật địa chỉ và tọa độ sau khi đăng nhập.</div>
                            </div>
                        </div>
                    }

                </div>
                <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.06);">
                    <button type="button" class="btn btn-outline-light rounded-pill px-4" @onclick="HideModal">Hủy</button>
                    <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm" @onclick="SaveUser" disabled="@isSaving">
                        @if (isSaving) {
                            <span class="spinner-border spinner-border-sm me-2"></span> <span>Đang lưu...</span>
                        } else {
                            <i class="bi bi-check2-circle me-2"></i><span>Tạo tài khoản @(newRole == "Vendor" ? "& Gian hàng" : "")</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<User>? users;
    private int? currentUserId;
    private int? togglingId;

    // Các biến trạng thái Modal
    private bool isShowModal = false;
    private bool isSaving = false;
    private string errorMessage = "";

    // Các biến lưu dữ liệu Form User
    private string newName = "";
    private string newEmail = "";
    private string newPassword = "";
    private string newRole = "Vendor";

    // Các biến lưu dữ liệu Form POI
    private string newPoiName = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var idStr = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idStr, out var me))
            currentUserId = me;

        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await AuthService.GetAllUsersAsync();
    }

    private async Task ToggleUserAsync(User user)
    {
        if (user.UserId == currentUserId)
            return;

        togglingId = user.UserId;
        try
        {
            await AuthService.SetUserActiveAsync(user.UserId, !user.IsActive);
            await LoadUsers();
        }
        finally
        {
            togglingId = null;
        }
    }

    private void ShowModal()
    {
        newName = "";
        newEmail = "";
        newPassword = "";
        newRole = "Vendor";
        newPoiName = "";
        errorMessage = "";
        isShowModal = true;
    }

    private void HideModal()
    {
        isShowModal = false;
    }

    private async Task SaveUser()
    {
        if (string.IsNullOrWhiteSpace(newName) || string.IsNullOrWhiteSpace(newEmail) || string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "Vui lòng nhập đầy đủ Họ Tên, Email và Mật khẩu.";
            return;
        }

        if (newRole == "Vendor" && string.IsNullOrWhiteSpace(newPoiName))
        {
            errorMessage = "Vui lòng nhập tên quán (gian hàng).";
            return;
        }

        isSaving = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            if (newRole == "Vendor")
            {
                await AuthService.CreateVendorWithPoiAsync(newName, newEmail, newPassword, newPoiName);
            }
            else
            {
                await AuthService.CreateUserAsync(newName, newEmail, newPassword, newRole);
            }
            
            HideModal();
            await LoadUsers(); 
        }
        catch (Exception ex)
        {
            errorMessage = $"Có lỗi xảy ra: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}