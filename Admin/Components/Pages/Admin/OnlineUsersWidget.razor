@using Microsoft.EntityFrameworkCore
@using VKFoodTour.Infrastructure.Data
@implements IAsyncDisposable
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<style>
    @@keyframes vk-pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.35; transform: scale(0.85); }
    }
    .vk-live-dot {
        display: inline-block;
        animation: vk-pulse 1.6s ease-in-out infinite;
    }
    @@keyframes vk-count-in {
        from { opacity: 0; transform: translateY(4px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .vk-count { animation: vk-count-in 0.4s ease; }
</style>

<div class="h-100 p-4" style="border-radius: 20px; background: linear-gradient(135deg, #0d2818 0%, #0a3d1f 100%); border: 1px solid rgba(34,197,94,0.25); position: relative; overflow: hidden; min-height: 160px;">
    <div style="position: absolute; top: -25px; right: -25px; width: 110px; height: 110px; background: rgba(34,197,94,0.07); border-radius: 50%;"></div>
    <div style="position: absolute; bottom: -20px; right: 40px; width: 60px; height: 60px; background: rgba(34,197,94,0.04); border-radius: 50%;"></div>

    <div class="d-flex justify-content-between align-items-start position-relative">
        <div>
            <div class="small fw-bold mb-2" style="letter-spacing: 1.5px; color: #4ade80;">
                @if (isLive)
                {
                    <span class="vk-live-dot" style="color: #4ade80;">●</span>
                }
                else if (isFirstLoad)
                {
                    <span style="color: #374151;">◌</span>
                }
                else
                {
                    <span style="color: #374151;">○</span>
                }
                <span class="ms-1">NGƯỜI DÙNG ĐANG ONLINE</span>
            </div>

            @if (isFirstLoad)
            {
                <div class="d-flex align-items-center gap-2 mt-1 mb-1">
                    <div class="spinner-border spinner-border-sm" style="color: #4ade80; width: 1.5rem; height: 1.5rem;" role="status"></div>
                    <span style="color: #166534; font-size: 12px;">Đang kết nối...</span>
                </div>
            }
            else
            {
                <h1 class="vk-count fw-bold mb-0" style="font-size: 3.2rem; color: #fff; line-height: 1;">
                    @onlineCount
                </h1>
                <small style="color: #2d6a4f; font-size: 11px; display: block; margin-top: 4px;">
                    thiết bị trong @windowSeconds giây qua
                </small>
                <small style="color: #1b4332; font-size: 10px;">
                    cập nhật @secondsAgo giây trước
                </small>
            }
        </div>
        <div style="background: rgba(34,197,94,0.15); border-radius: 14px; padding: 12px; flex-shrink: 0;">
            <i class="bi bi-people-fill" style="font-size: 1.8rem; color: #4ade80;"></i>
        </div>
    </div>
</div>

@code {
    [Parameter] public int WindowSeconds { get; set; } = 15;
    [Parameter] public int RefreshSeconds { get; set; } = 5;

    private int onlineCount = 0;
    private int windowSeconds = 15;
    private int secondsAgo = 0;
    private bool isLive = false;
    private bool isFirstLoad = true;
    private bool _disposed = false;
    private System.Threading.Timer? _refreshTimer;
    private System.Threading.Timer? _tickTimer;
    private DateTime _lastRefresh = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        windowSeconds = WindowSeconds;
        await LoadAsync();
        isFirstLoad = false;

        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(RefreshSeconds), TimeSpan.FromSeconds(RefreshSeconds));

        _tickTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            secondsAgo = (int)(DateTime.Now - _lastRefresh).TotalSeconds;
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task LoadAsync()
    {
        try
        {
            // Mỗi lần tạo DbContext mới để tránh "DbContext was disposed" trong Timer callback
            await using var db = await DbFactory.CreateDbContextAsync();
            var threshold = DateTime.Now.AddSeconds(-windowSeconds);
            onlineCount = await db.TrackingLogs
                .AsNoTracking()
                .Where(t => t.CreatedAt >= threshold)
                .Select(t => t.DeviceId)
                .Distinct()
                .CountAsync();
            isLive = true;
            _lastRefresh = DateTime.Now;
            secondsAgo = 0;
        }
        catch
        {
            isLive = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_refreshTimer is not null) await _refreshTimer.DisposeAsync();
        if (_tickTimer is not null) await _tickTimer.DisposeAsync();
    }
}
