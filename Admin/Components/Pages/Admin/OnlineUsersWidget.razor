@using Microsoft.EntityFrameworkCore
@using VKFoodTour.Infrastructure.Data
@implements IDisposable
@rendermode InteractiveServer

@inject ApplicationDbContext Db

<div class="h-100 p-4" style="border-radius: 20px; background: linear-gradient(135deg, #0d2818 0%, #0a3d1f 100%); border: 1px solid rgba(34,197,94,0.25); position: relative; overflow: hidden; min-height: 130px;">
    <div style="position: absolute; top: -25px; right: -25px; width: 110px; height: 110px; background: rgba(34,197,94,0.08); border-radius: 50%;"></div>
    <div style="position: absolute; bottom: -20px; right: 40px; width: 60px; height: 60px; background: rgba(34,197,94,0.05); border-radius: 50%;"></div>

    <div class="d-flex justify-content-between align-items-start position-relative">
        <div>
            <div class="small fw-bold mb-2" style="letter-spacing: 1.5px; color: #4ade80;">
                @if (isLive)
                {
                    <span style="animation: pulse 2s infinite; display: inline-block;">●</span>
                }
                else
                {
                    <span style="color: #374151;">○</span>
                }
                <span class="ms-1">NGƯỜI DÙNG ĐANG ONLINE</span>
            </div>
            <h1 class="fw-bold mb-1" style="font-size: 3rem; color: #fff; line-height: 1;">@onlineCount</h1>
            <small style="color: #166534; font-size: 11px;">trong @windowMinutes phút qua · cập nhật @secondsAgo giây trước</small>
        </div>
        <div style="background: rgba(34,197,94,0.15); border-radius: 14px; padding: 12px;">
            <i class="bi bi-people-fill" style="font-size: 1.8rem; color: #4ade80;"></i>
        </div>
    </div>
</div>

@code {
    [Parameter] public int WindowMinutes { get; set; } = 2;
    [Parameter] public int RefreshSeconds { get; set; } = 10;

    private int onlineCount = 0;
    private int windowMinutes = 2;
    private int secondsAgo = 0;
    private bool isLive = false;
    private System.Threading.Timer? _refreshTimer;
    private System.Threading.Timer? _tickTimer;
    private DateTime _lastRefresh = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        windowMinutes = WindowMinutes;
        await LoadAsync();

        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(RefreshSeconds), TimeSpan.FromSeconds(RefreshSeconds));

        _tickTimer = new System.Threading.Timer(async _ =>
        {
            secondsAgo = (int)(DateTime.Now - _lastRefresh).TotalSeconds;
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task LoadAsync()
    {
        try
        {
            var threshold = DateTime.Now.AddMinutes(-windowMinutes);
            onlineCount = await Db.TrackingLogs
                .AsNoTracking()
                .Where(t => t.CreatedAt >= threshold)
                .Select(t => t.DeviceId)
                .Distinct()
                .CountAsync();
            isLive = true;
            _lastRefresh = DateTime.Now;
            secondsAgo = 0;
        }
        catch
        {
            isLive = false;
        }
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        _tickTimer?.Dispose();
    }
}
