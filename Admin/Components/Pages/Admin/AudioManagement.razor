@page "/admin/audio-management"
@using Microsoft.AspNetCore.Authorization
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Entities
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject PoiService PoiService
@inject TtsService TtsService
@inject IJSRuntime JS

<PageTitle>Quản lý Audio Toàn Hệ Thống</PageTitle>

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color:#F0EBE3;"><i class="bi bi-soundwave me-2 text-danger"></i>Quản lý Audio Toàn Hệ Thống</h2>
            <p class="text-muted mb-0">Tạo, xem và quản lý audio thuyết minh cho tất cả gian hàng</p>
        </div>
        <button class="btn btn-danger rounded-pill" @onclick="GenerateAllTtsAsync" disabled="@isGeneratingAll">
            @if (isGeneratingAll)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            <i class="bi bi-magic me-2"></i>Tạo TTS cho tất cả quán chưa có audio
        </button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-dismissible fade show" role="alert"
             style="@(isError ? "background:rgba(200,55,45,0.08);border:1px solid rgba(200,55,45,0.2);border-radius:12px;" : "background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:12px;")">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="dash-card p-4 h-100 text-center">
                <i class="bi bi-shop mb-2" style="font-size:1.5rem;color:#C8372D;"></i>
                <h2 class="fw-bold mb-1" style="color:#C8372D;">@totalStalls</h2>
                <div class="text-muted small">Tổng gian hàng</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card p-4 h-100 text-center">
                <i class="bi bi-music-note-beamed mb-2" style="font-size:1.5rem;color:#22c55e;"></i>
                <h2 class="fw-bold mb-1" style="color:#22c55e;">@stallsWithAudio</h2>
                <div class="text-muted small">Có audio</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card p-4 h-100 text-center">
                <i class="bi bi-exclamation-circle mb-2" style="font-size:1.5rem;color:#f59e0b;"></i>
                <h2 class="fw-bold mb-1" style="color:#f59e0b;">@stallsWithoutAudio</h2>
                <div class="text-muted small">Chưa có audio</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="dash-card p-4 h-100 text-center">
                <i class="bi bi-qr-code mb-2" style="font-size:1.5rem;color:#38bdf8;"></i>
                <h2 class="fw-bold mb-1" style="color:#38bdf8;">@stallsWithQr</h2>
                <div class="text-muted small">Có mã QR</div>
            </div>
        </div>
    </div>

    <!-- QR Code chung cho cả phố -->
    <div class="dash-card p-4 mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="dash-label mb-2"><i class="bi bi-qr-code me-2"></i>Mã QR Chung - Tour Vĩnh Khánh</div>
                <p class="text-muted mb-0">
                    Du khách quét mã này sẽ nghe audio của <strong>TẤT CẢ</strong> gian hàng trên phố, 
                    sắp xếp theo khoảng cách từ vị trí hiện tại. Không cần mã riêng từng quán.
                </p>
            </div>
            <div class="col-md-4 text-end">
                <img src="@masterQrImageUrl" alt="Master QR" class="img-fluid" style="max-width: 150px;" />
                <div class="mt-2">
                    <a href="@masterQrImageUrl" download="VinhKhanh-Tour-QR.png" class="btn btn-outline-light btn-sm rounded-pill">
                        <i class="bi bi-download me-1"></i>Tải ảnh QR
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Audio List Table -->
    <div class="dash-card" style="overflow:hidden;">
        <div class="p-4 d-flex justify-content-between align-items-center">
            <div class="dash-label mb-0"><i class="bi bi-list-ul me-2"></i>Danh sách Audio theo Gian hàng</div>
            <select class="form-select form-select-sm dash-input" style="width: auto;" @bind="filterStatus">
                <option value="all">Tất cả</option>
                <option value="with-audio">Có audio</option>
                <option value="without-audio">Chưa có audio</option>
            </select>
        </div>
        <div class="table-responsive">
            <table class="table dash-table mb-0">
                    <thead>
                        <tr class="text-muted small">
                            <th style="width: 50px;">STT</th>
                            <th>Gian hàng</th>
                            <th>Chủ quán</th>
                            <th style="width: 80px;">Ưu tiên</th>
                            <th>Trạng thái Audio (Đa ngôn ngữ)</th>
                            <th>Mã QR</th>
                            <th style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (poi, index) in FilteredPois.Select((p, i) => (p, i)))
                        {
                            <tr>
                                <td class="text-muted">@(index + 1)</td>
                                <td>
                                    <div class="fw-bold text-white">@poi.Name</div>
                                    <div class="text-muted small">@(poi.Address ?? "Chưa có địa chỉ")</div>
                                </td>
                                <td class="text-muted small">@(poi.OwnerId?.ToString() ?? "—")</td>
                                <td>
                                    <span class="badge bg-@(GetPriorityColor(poi.Priority))">@poi.Priority</span>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var lang in activeLanguages)
                                        {
                                            var nar = poi.Narrations?.FirstOrDefault(n => n.LanguageId == lang.LanguageId && n.IsActive);
                                            var hasAudio = !string.IsNullOrEmpty(nar?.AudioUrlQr) || !string.IsNullOrEmpty(nar?.AudioUrlAuto);
                                            
                                            <div class="btn-group btn-group-sm">
                                                <span class="badge @(hasAudio ? "bg-success" : "bg-dark border border-secondary text-muted")" 
                                                      style="min-width: 35px; cursor: default;" 
                                                      title="@(hasAudio ? $"Đã có audio {lang.Name}" : $"Chưa có audio {lang.Name}")">
                                                    @lang.Code.ToUpper()
                                                </span>
                                                @if (hasAudio)
                                                {
                                                    <button class="btn btn-sm btn-outline-light py-0 px-1" style="font-size: 10px;"
                                                            @onclick="() => PlayAudio(nar?.AudioUrlQr ?? nar?.AudioUrlAuto)">
                                                        <i class="bi bi-play-fill"></i>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (poi.QrCodes?.Any(q => q.IsActive) == true)
                                    {
                                        <span class="badge bg-success">
                                            @poi.QrCodes.First(q => q.IsActive).QrToken
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Chưa tạo</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-warning" title="Đồng bộ Audio Đa ngôn ngữ" 
                                                @onclick="() => GenerateTtsForPoiAsync(poi)"
                                                disabled="@(generatingPoiId == poi.PoiId)">
                                            @if (generatingPoiId == poi.PoiId)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-arrow-repeat"></i>
                                            }
                                        </button>
                                        <button class="btn btn-outline-light" title="Tạo QR" 
                                                @onclick="() => CreateQrForPoiAsync(poi)">
                                            <i class="bi bi-qr-code"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
        </div>
    </div>

    <!-- Audio Player (floating) -->
    @if (!string.IsNullOrEmpty(currentPlayingUrl))
    {
        <div class="position-fixed bottom-0 start-50 translate-middle-x mb-3 p-3 bg-dark rounded-pill shadow-lg border border-secondary"
             style="z-index: 1050; min-width: 400px;">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-danger btn-sm rounded-circle" @onclick="StopAudio">
                    <i class="bi bi-stop-fill"></i>
                </button>
                <audio id="audioPlayer" controls autoplay class="flex-grow-1" style="height: 36px;">
                    <source src="@currentPlayingUrl" type="audio/mpeg" />
                </audio>
                <button class="btn btn-outline-light btn-sm rounded-circle" @onclick="() => currentPlayingUrl = null">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        </div>
    }
</div>

@code {
    private List<VKFoodTour.Infrastructure.Entities.Poi> allPois = new();
    private List<Language> activeLanguages = new();
    private string? statusMessage;
    private bool isError;
    private bool isGeneratingAll;
    private int? generatingPoiId;
    private string? currentPlayingUrl;
    private string filterStatus = "all";

    private int totalStalls => allPois.Count;
    private int stallsWithAudio => allPois.Count(p => HasAnyAudio(p));
    private int stallsWithoutAudio => allPois.Count(p => !HasAnyAudio(p));
    private int stallsWithQr => allPois.Count(p => p.QrCodes?.Any(q => q.IsActive) == true);

    private string masterQrImageUrl => "https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=" + 
        Uri.EscapeDataString("vkfoodtour://VINH-KHANH-TOUR");

    private IEnumerable<VKFoodTour.Infrastructure.Entities.Poi> FilteredPois => filterStatus switch
    {
        "with-audio" => allPois.Where(p => HasAnyAudio(p)),
        "without-audio" => allPois.Where(p => !HasAnyAudio(p)),
        _ => allPois
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        allPois = await PoiService.GetAllWithNarrationsAsync();
        activeLanguages = await PoiService.GetActiveLanguagesAsync();
    }

    private bool HasAnyAudio(VKFoodTour.Infrastructure.Entities.Poi poi)
    {
        var narration = poi.Narrations?.FirstOrDefault(n => n.IsActive);
        if (narration == null) return false;
        return !string.IsNullOrEmpty(narration.AudioUrl) || 
               !string.IsNullOrEmpty(narration.AudioUrlAuto) || 
               !string.IsNullOrEmpty(narration.AudioUrlQr);
    }

    private string? GetAudioUrlAuto(VKFoodTour.Infrastructure.Entities.Poi poi)
    {
        var narration = poi.Narrations?.FirstOrDefault(n => n.IsActive);
        return narration?.AudioUrlAuto ?? narration?.AudioUrl;
    }

    private string? GetAudioUrlQr(VKFoodTour.Infrastructure.Entities.Poi poi)
    {
        var narration = poi.Narrations?.FirstOrDefault(n => n.IsActive);
        return narration?.AudioUrlQr;
    }

    private string GetPriorityColor(int priority) => priority switch
    {
        1 => "danger",
        2 => "warning",
        3 => "info",
        4 => "secondary",
        _ => "dark"
    };

    private async Task GenerateTtsForPoiAsync(VKFoodTour.Infrastructure.Entities.Poi poi)
    {
        if (string.IsNullOrWhiteSpace(poi.Description))
        {
            statusMessage = $"Quán '{poi.Name}' chưa có mô tả. Vui lòng thêm mô tả trước khi tạo TTS.";
            isError = true;
            return;
        }

        generatingPoiId = poi.PoiId;
        StateHasChanged();

        try
        {
            // forceRefresh = true để ghi đè (vì nút này là Admin chủ động nhấn để đồng bộ)
            var results = await PoiService.UpdateMultilingualNarrationsAsync(poi.PoiId, forceRefresh: true);
            
            var successCount = results.Count(r => r.Success);
            if (successCount > 0)
            {
                statusMessage = $"Đã đồng bộ audio {successCount} ngôn ngữ cho '{poi.Name}'.";
                isError = false;
            }
            else
            {
                statusMessage = $"Lỗi đồng bộ audio cho '{poi.Name}'.";
                isError = true;
            }
            
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"Lỗi: {ex.Message}";
            isError = true;
        }
        finally
        {
            generatingPoiId = null;
            StateHasChanged();
        }
    }

    private async Task GenerateAllTtsAsync()
    {
        isGeneratingAll = true;
        StateHasChanged();

        var poisWithoutAudio = allPois.Where(p => !HasAnyAudio(p) && !string.IsNullOrWhiteSpace(p.Description)).ToList();
        var total = poisWithoutAudio.Count;
        var processed = 0;

        foreach (var poi in poisWithoutAudio)
        {
            try
            {
                await PoiService.UpdateMultilingualNarrationsAsync(poi.PoiId);
            }
            catch { }

            processed++;
            if (processed % 2 == 0) StateHasChanged();
            await Task.Delay(200);
        }

        statusMessage = $"Hoàn tất xử lý audio cho {processed}/{total} quán.";
        isError = false;
        isGeneratingAll = false;
        await LoadDataAsync();
    }

    private async Task CreateQrForPoiAsync(VKFoodTour.Infrastructure.Entities.Poi poi)
    {
        if (poi.OwnerId == null)
        {
            statusMessage = $"Quán '{poi.Name}' chưa có chủ quán. Vui lòng gán chủ quán trước.";
            isError = true;
            return;
        }

        try
        {
            var token = await PoiService.EnsurePrimaryQrForVendorAsync(poi.PoiId, poi.OwnerId.Value, "Tại quán");
            if (string.IsNullOrEmpty(token))
            {
                statusMessage = $"Không tạo được mã QR cho '{poi.Name}'.";
                isError = true;
            }
            else
            {
                statusMessage = $"Đã tạo mã QR '{token}' cho '{poi.Name}'.";
                isError = false;
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Lỗi: {ex.Message}";
            isError = true;
        }
    }

    private void PlayAudio(string? url)
    {
        if (string.IsNullOrEmpty(url)) return;
        currentPlayingUrl = url.StartsWith("http") ? url : $"/uploads/{url.TrimStart('/')}";
    }

    private void StopAudio()
    {
        currentPlayingUrl = null;
    }
}
