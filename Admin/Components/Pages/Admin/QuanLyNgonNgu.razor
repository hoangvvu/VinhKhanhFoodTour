@page "/quan-ly-ngon-ngu"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@inject ApplicationDbContext Db
@inject GoogleTranslateService TranslateService
@inject TtsService TtsService
@inject PoiService PoiService
@inject IJSRuntime JS

<style>
    .lang-page-title { color: #F0EBE3; }
    .lang-panel { border-radius: 16px; background: linear-gradient(145deg, #11151c, #171d26); border: 1px solid rgba(255,255,255,0.06); }
    .lang-kpi { border-radius: 12px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }
    .audit-box { border-radius: 12px; border: 1px dashed rgba(255,255,255,0.2); background: rgba(255,255,255,0.02); }
    .status-chip { border-radius: 999px; padding: 2px 10px; font-size: 12px; }
    .lookup-item { border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; background: rgba(255,255,255,0.02); }
</style>

<div class="dash-page p-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1 lang-page-title"><i class="bi bi-translate me-2 text-danger"></i>QUẢN LÝ NGÔN NGỮ & DỊCH TỰ ĐỘNG</h2>
            <div class="text-muted small">Thêm ngôn ngữ mới, dịch hàng loạt và kiểm tra nhanh chất lượng bản dịch trong cùng một màn hình.</div>
        </div>
        <span class="badge px-3 py-2 rounded-pill" style="background:rgba(200,55,45,0.12);color:#C8372D;border:1px solid rgba(200,55,45,0.25);">
            <i class="bi bi-translate me-1"></i> Google Translate API
        </span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="lang-kpi p-3 h-100">
                <div class="text-muted small">Tổng ngôn ngữ</div>
                <div class="fs-4 fw-bold text-white">@languages.Count</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="lang-kpi p-3 h-100">
                <div class="text-muted small">Ngôn ngữ đang bật</div>
                <div class="fs-4 fw-bold text-white">@languages.Count(l => l.IsActive)</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="lang-kpi p-3 h-100">
                <div class="text-muted small">POI có dữ liệu dịch (@GetLangCode(auditTargetLanguageId))</div>
                <div class="fs-4 fw-bold text-white">@auditTranslatedPois/@auditTotalPois</div>
            </div>
        </div>
    </div>

    @* ── THÔNG BÁO ── *@
    @if (!string.IsNullOrEmpty(alertMessage))
    {
        <div class="alert alert-dismissible fade show small" role="alert"
             style="@(alertClass == "alert-success" ? "background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:12px;" : "background:rgba(200,55,45,0.08);border:1px solid rgba(200,55,45,0.2);border-radius:12px;")">
            <i class="bi @alertIcon me-1"></i> @alertMessage
            <button type="button" class="btn-close" @onclick="() => alertMessage = null"></button>
        </div>
    }

    <div class="lang-panel p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div class="dash-label mb-0"><i class="bi bi-globe2 me-2"></i>NGÔN NGỮ HIỆN CÓ</div>
            <small class="text-muted">Để thêm nhanh: chọn mẫu ở phần "Tra cứu mã & voice" phía dưới.</small>
        </div>
        @if (isLoadingLanguages)
        {
            <div class="text-center py-4">
                <div class="spinner-border spinner-border-sm text-danger" role="status"></div>
            </div>
        }
        else if (!languages.Any())
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-inbox display-4 d-block mb-2 opacity-25"></i>
                Chưa có ngôn ngữ nào trong hệ thống.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table dash-table mb-0 align-middle small">
                    <thead class="text-muted">
                        <tr>
                            <th>MÃ</th>
                            <th>TÊN</th>
                            <th>TTS</th>
                            <th class="text-center">NARRATIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lang in languages)
                        {
                            <tr>
                                <td><span class="badge bg-secondary rounded-pill">@lang.Code.ToUpper()</span></td>
                                <td class="text-white">@lang.Name</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(lang.TtsVoice))
                                    {
                                        <span class="status-chip text-success-emphasis bg-success-subtle">Có voice</span>
                                    }
                                    else
                                    {
                                        <span class="status-chip text-warning-emphasis bg-warning-subtle">Chưa cấu hình</span>
                                    }
                                </td>
                                <td class="text-center"><span class="badge bg-info-subtle text-info">@lang.NarrationCount</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="lang-panel p-4 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <div class="dash-label mb-0"><i class="bi bi-plus-circle me-2"></i>THÊM NGÔN NGỮ MỚI</div>
                    <small class="text-muted">1) Chọn mẫu 2) Kiểm tra mã 3) Thêm ngôn ngữ</small>
                </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">MÃ NGÔN NGỮ</label>
                            <div class="input-group">
                                <input type="text" @bind="newLangCode" @bind:event="oninput"
                                       class="form-control dash-input rounded-start-3"
                                       placeholder="vd: en, ja, ko, zh-TW" />
                                <button class="btn btn-outline-light rounded-end-3" @onclick="CheckLanguageCode"
                                        disabled="@isCheckingCode">
                                    @if (isCheckingCode)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-search"></i>
                                    }
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold">TTS VOICE (TÙY CHỌN)</label>
                            <input type="text" @bind="newTtsVoice"
                                   class="form-control dash-input rounded-3"
                                   placeholder="vd: en-US-Standard-A" />
                        </div>
                        <div class="col-12">
                            <label class="form-label text-muted small fw-bold">TÊN HIỂN THỊ (THỦ CÔNG)</label>
                            <input type="text" @bind="newLangDisplayName" @bind:event="oninput"
                                   class="form-control dash-input rounded-3"
                                   placeholder="Bắt buộc nếu chưa cấu hình Google API; hoặc ghi đè tên khi Google không nhận mã." />
                            <div class="form-text text-muted small">Dùng khi không có Google Translate hoặc cần tên tùy chỉnh (vd: English, 日本語).</div>
                        </div>
                    </div>

                    @if (previewLangName != null)
                    {
                        <div class="mt-3 p-3 rounded-3" style="background-color: #1a2e1a; border: 1px solid #2d5a2d;">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="text-white">Sẽ thêm: <strong>@previewLangName</strong> (<code>@newLangCode</code>)</span>
                        </div>
                    }
                    else if (previewError != null)
                    {
                        <div class="mt-3 p-3 rounded-3" style="background-color: #2e1a1a; border: 1px solid #5a2d2d;">
                            <i class="bi bi-x-circle-fill text-danger me-2"></i>
                            <span class="text-white">@previewError</span>
                        </div>
                    }

                    <div class="mt-4">
                        <label class="form-label text-muted small fw-bold">TRA CỨU MÃ NGÔN NGỮ & TTS VOICE</label>
                        <input type="text" class="form-control dash-input mb-2" @bind="voiceLookupKeyword" @bind:event="oninput"
                               placeholder="Tìm theo tên, mã, voice... vd: Japanese, zh, AriaNeural" />
                        <div class="small text-muted mb-2">Chọn một dòng để tự điền Code + Voice + Tên hiển thị.</div>
                        <div style="max-height:200px; overflow-y:auto;" class="d-flex flex-column gap-2">
                            @foreach (var item in FilteredVoiceLookupItems)
                            {
                                <button type="button" class="lookup-item text-start p-2 btn btn-sm btn-outline-light"
                                        @onclick="() => ApplyVoiceLookup(item)">
                                    <div class="text-white fw-semibold">@item.DisplayName <span class="text-muted">(@item.Code)</span></div>
                                    <div class="small text-muted">@item.Voice</div>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label text-muted small fw-bold">GỢI Ý NHANH</label>
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick='() => SetLangSuggest("en", "en-US-AriaNeural", "English")'>🇺🇸 English</button>
                            <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick='() => SetLangSuggest("ja", "ja-JP-NanamiNeural", "日本語")'>🇯🇵 Japanese</button>
                            <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick='() => SetLangSuggest("ko", "ko-KR-SunHiNeural", "한국어")'>🇰🇷 Korean</button>
                            <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick='() => SetLangSuggest("zh-cn", "zh-CN-XiaoxiaoNeural", "简体中文")'>🇨🇳 Chinese</button>
                            <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick='() => SetLangSuggest("vi", "vi-VN-HoaiMyNeural", "Tiếng Việt (Edge)")'>🇻🇳 Việt Neural</button>
                        </div>
                    </div>

                    <button class="btn btn-danger rounded-pill px-4 fw-bold mt-4 d-flex align-items-center gap-2"
                            @onclick="AddLanguage"
                            disabled="@(isAddingLanguage || isCheckingCode)">
                        @if (isAddingLanguage)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        <i class="bi bi-plus-lg"></i> Thêm ngôn ngữ
                    </button>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="lang-panel p-4 mb-4">
                <div class="dash-label mb-4 d-flex align-items-center">
                    <div class="me-3" style="width:32px;height:32px;background:rgba(200,55,45,0.1);color:#C8372D;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    CÔNG CỤ DỊCH HÀNG LOẠT & TTS TỰ ĐỘNG
                </div>

                <div class="p-4 rounded-4 mb-4" style="background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">NGÔN NGỮ NGUỒN</label>
                            <select class="form-select dash-input" @bind="sourceLanguageId">
                                @foreach (var l in languages)
                                {
                                    <option value="@l.LanguageId">@l.Name (@l.Code)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">NGÔN NGỮ ĐÍCH (DỊCH SANG)</label>
                            <select class="form-select dash-input" @bind="targetLanguageId">
                                <option value="0">-- Chọn ngôn ngữ --</option>
                                @foreach (var l in languages.Where(x => x.LanguageId != sourceLanguageId))
                                {
                                    <option value="@l.LanguageId">@l.Name (@l.Code)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold">PHẠM VI POI</label>
                            <select class="form-select dash-input" @bind="selectedPoiId">
                                <option value="0">Tất cả POI</option>
                                @foreach (var poi in pois)
                                {
                                    <option value="@poi.PoiId">@poi.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="StartBatchTranslate" disabled="@isProcessing">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-translate me-2"></i>Dịch & Tạo Audio Hàng Loạt
                    </button>
                    <button class="btn btn-outline-danger rounded-pill px-4" @onclick="CleanupLegacyAudio" disabled="@isProcessing">
                        <i class="bi bi-trash3 me-2"></i>Dọn dẹp Audio cũ
                    </button>
                </div>

                @if (isTranslating || translateResults.Any())
                {
                    <div class="mt-4">
                        @if (isTranslating)
                        {
                            <div class="progress rounded-pill mb-3" style="height: 8px; background-color: #2a2a2a;">
                                <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" style="width: @progressPercent%"></div>
                            </div>
                            <div class="text-muted small mb-3">Đang xử lý: @translateCurrent / @translateTotal narration...</div>
                        }

                        <div style="max-height: 280px; overflow-y: auto;">
                            @foreach (var result in translateResults.TakeLast(30))
                            {
                                <div class="d-flex align-items-start gap-2 mb-2 p-2 rounded-3" style="background-color: @(result.Success ? "#121a12" : "#1a1212");">
                                    <i class="bi @(result.Success ? "bi-check-circle text-success" : "bi-x-circle text-danger") mt-1"></i>
                                    <div class="small">
                                        <div class="text-white fw-bold">@result.PoiName</div>
                                        <div class="text-muted">@result.Title</div>
                                        @if (!result.Success)
                                        {
                                            <div class="text-danger">@result.Error</div>
                                        }
                                        @if (result.Overwritten)
                                        {
                                            <span class="badge bg-warning-subtle text-warning small">Đã ghi đè</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="lang-panel p-4 mb-4">
                <div class="dash-label mb-3"><i class="bi bi-clipboard2-data me-2"></i>KIỂM TRA BẢN DỊCH</div>
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label text-muted small fw-bold">SO SÁNH TỪ</label>
                        <select class="form-select dash-input" @bind="auditSourceLanguageId">
                            @foreach (var l in languages)
                            {
                                <option value="@l.LanguageId">@l.Name (@l.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label text-muted small fw-bold">SANG NGÔN NGỮ</label>
                        <select class="form-select dash-input" @bind="auditTargetLanguageId">
                            @foreach (var l in languages.Where(x => x.LanguageId != auditSourceLanguageId))
                            {
                                <option value="@l.LanguageId">@l.Name (@l.Code)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-outline-light w-100" @onclick="RunTranslationAudit" disabled="@isAuditing">
                            @if (isAuditing)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi bi-search"></i>
                            }
                        </button>
                    </div>
                </div>

                <div class="audit-box p-3 mt-3">
                    <div class="d-flex justify-content-between flex-wrap gap-2">
                        <div class="text-muted small">Độ phủ dịch</div>
                        <div class="text-white small fw-semibold">@auditTranslatedPois / @auditTotalPois POI</div>
                    </div>
                    <div class="progress mt-2" style="height:8px;">
                        <div class="progress-bar bg-info" style="width:@auditCoveragePercent%"></div>
                    </div>
                    <div class="mt-3">
                        <div class="text-muted small mb-1">POI chưa có bản dịch: @auditMissingPoiNames.Count</div>
                        @if (auditMissingPoiNames.Any())
                        {
                            <div class="small text-warning">@string.Join(", ", auditMissingPoiNames.Take(8))@(auditMissingPoiNames.Count > 8 ? ", ..." : "")</div>
                        }
                        else
                        {
                            <div class="small text-success">Tất cả POI đã có bản dịch ở ngôn ngữ đích.</div>
                        }
                    </div>
                    <div class="mt-3">
                        <div class="text-muted small mb-1">Cảnh báo chất lượng dịch: @auditIssues.Count</div>
                        @if (auditIssues.Any())
                        {
                            @foreach (var issue in auditIssues.Take(6))
                            {
                                <div class="small text-warning mb-1"><i class="bi bi-exclamation-triangle me-1"></i>@issue.PoiName: @issue.Message</div>
                            }
                        }
                        else
                        {
                            <div class="small text-success">Không phát hiện dấu hiệu dịch lỗi phổ biến.</div>
                        }
                    </div>
                </div>
            </div>

            @if (showOverwriteConfirm)
            {
                <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.7);">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content bg-dark border-secondary rounded-4">
                            <div class="modal-header border-secondary">
                                <h6 class="modal-title text-warning">
                                    <i class="bi bi-exclamation-triangle me-2"></i>Xác nhận ghi đè
                                </h6>
                            </div>
                            <div class="modal-body text-white">
                                <p>Đã tìm thấy <strong>@overwriteCount</strong> narration đã tồn tại ở ngôn ngữ đích.</p>
                                <p class="text-muted small mb-0">Bạn muốn ghi đè nội dung cũ hay chỉ dịch những narration chưa có?</p>
                            </div>
                            <div class="modal-footer border-secondary">
                                <button class="btn btn-outline-light rounded-pill px-3" @onclick="() => ConfirmOverwrite(false)">Bỏ qua đã có</button>
                                <button class="btn btn-danger rounded-pill px-3" @onclick="() => ConfirmOverwrite(true)"><i class="bi bi-arrow-repeat me-1"></i> Ghi đè tất cả</button>
                                <button class="btn btn-secondary rounded-pill px-3" @onclick="CancelTranslate">Hủy</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    // ── Danh sách data ──
    private List<LanguageRow> languages = new();
    private List<Poi> pois = new();
    private bool isLoadingLanguages = true;
    private bool isProcessing;

    // ── Form thêm ngôn ngữ ──
    private string newLangCode = "";
    private string newTtsVoice = "";
    private string newLangDisplayName = "";
    private string? previewLangName;
    private string? previewError;
    private bool isCheckingCode;
    private bool isAddingLanguage;
    private string voiceLookupKeyword = "";

    // ── Dịch hàng loạt ──
    private int sourceLanguageId;
    private int targetLanguageId;
    private int selectedPoiId; // 0 = tất cả
    private bool isTranslating;
    private int translateCurrent;
    private int translateTotal;
    private int progressPercent;
    private List<TranslateResult> translateResults = new();

    // ── Modal ghi đè ──
    private bool showOverwriteConfirm;
    private int overwriteCount;
    private TaskCompletionSource<bool?>? overwriteTcs;

    // ── Audit chất lượng dịch ──
    private int auditSourceLanguageId;
    private int auditTargetLanguageId;
    private bool isAuditing;
    private int auditTotalPois;
    private int auditTranslatedPois;
    private List<string> auditMissingPoiNames = new();
    private List<AuditIssue> auditIssues = new();
    private int auditCoveragePercent => auditTotalPois == 0 ? 0 : (int)Math.Round((double)auditTranslatedPois * 100 / auditTotalPois);
    private IEnumerable<VoiceLookupItem> FilteredVoiceLookupItems =>
        VoiceLookupCatalog
            .Where(x =>
                string.IsNullOrWhiteSpace(voiceLookupKeyword)
                || x.DisplayName.Contains(voiceLookupKeyword, StringComparison.OrdinalIgnoreCase)
                || x.Code.Contains(voiceLookupKeyword, StringComparison.OrdinalIgnoreCase)
                || x.Voice.Contains(voiceLookupKeyword, StringComparison.OrdinalIgnoreCase))
            .Take(12);

    // ── Alert ──
    private string? alertMessage;
    private string alertClass = "alert-danger";
    private string alertIcon = "bi-exclamation-triangle";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoadingLanguages = true;
        try
        {
            var langs = await Db.Languages.AsNoTracking()
                .OrderBy(l => l.LanguageId)
                .ToListAsync();

            var narrationCounts = await Db.Narrations
                .Where(n => n.IsActive)
                .GroupBy(n => n.LanguageId)
                .Select(g => new { LanguageId = g.Key, Count = g.Count() })
                .ToDictionaryAsync(x => x.LanguageId, x => x.Count);

            languages = langs.Select(l => new LanguageRow
            {
                LanguageId = l.LanguageId,
                Code = l.Code,
                Name = l.Name,
                TtsVoice = l.TtsVoice,
                IsActive = l.IsActive,
                NarrationCount = narrationCounts.GetValueOrDefault(l.LanguageId, 0)
            }).ToList();

            pois = await Db.Pois.AsNoTracking()
                .Where(p => p.IsActive)
                .OrderBy(p => p.Name)
                .ToListAsync();

            // Mặc định ngôn ngữ nguồn = "vi" nếu có
            var viLang = languages.FirstOrDefault(l => l.Code.Equals("vi", StringComparison.OrdinalIgnoreCase));
            if (viLang != null) sourceLanguageId = viLang.LanguageId;
            else if (languages.Any()) sourceLanguageId = languages.First().LanguageId;

            if (languages.Any())
            {
                auditSourceLanguageId = sourceLanguageId;
                auditTargetLanguageId = languages.FirstOrDefault(l => l.LanguageId != auditSourceLanguageId)?.LanguageId ?? sourceLanguageId;
            }
        }
        catch (Exception ex)
        {
            ShowAlert($"Lỗi tải dữ liệu: {ex.Message}", "danger");
        }
        finally
        {
            isLoadingLanguages = false;
        }

        await RunTranslationAudit();
    }

    // ══════════════════════════════════════════
    // KIỂM TRA MÃ NGÔN NGỮ
    // ══════════════════════════════════════════
    private async Task CheckLanguageCode()
    {
        previewLangName = null;
        previewError = null;

        var code = newLangCode?.Trim();
        if (string.IsNullOrEmpty(code))
        {
            previewError = "Vui lòng nhập mã ngôn ngữ (vd: en, ja, ko).";
            return;
        }

        // Kiểm tra trùng
        var exists = languages.Any(l => l.Code.Equals(code, StringComparison.OrdinalIgnoreCase));
        if (exists)
        {
            previewError = $"Mã \"{code}\" đã tồn tại trong hệ thống.";
            return;
        }

        if (!TranslateService.IsConfigured)
        {
            var manual = newLangDisplayName?.Trim();
            if (string.IsNullOrEmpty(manual))
            {
                previewError = "Chưa cấu GoogleTranslate:ApiKey — nhập tên hiển thị thủ công (ô bên dưới) rồi nhấn Thêm hoặc tra cứu lại.";
                return;
            }

            previewLangName = manual;
            return;
        }

        isCheckingCode = true;
        StateHasChanged();

        try
        {
            var name = await TranslateService.GetLanguageNameAsync(code, code);
            if (name != null)
            {
                previewLangName = name;
            }
            else
            {
                var manual = newLangDisplayName?.Trim();
                if (!string.IsNullOrEmpty(manual))
                    previewLangName = manual;
                else
                    previewError = $"Mã \"{code}\" không phải mã ngôn ngữ hợp lệ trên Google Translate. Nhập tên hiển thị thủ công hoặc sửa mã.";
            }
        }
        catch (Exception ex)
        {
            previewError = $"Lỗi khi gọi Google Translate API: {ex.Message}";
        }
        finally
        {
            isCheckingCode = false;
        }
    }

    // ══════════════════════════════════════════
    // THÊM NGÔN NGỮ
    // ══════════════════════════════════════════
    private async Task AddLanguage()
    {
        var manual = newLangDisplayName?.Trim();
        if (previewLangName == null && !string.IsNullOrEmpty(manual))
            previewLangName = manual;

        if (previewLangName == null)
        {
            await CheckLanguageCode();
            StateHasChanged();
            if (previewLangName == null && !string.IsNullOrEmpty(newLangDisplayName?.Trim()))
                previewLangName = newLangDisplayName.Trim();
            if (previewLangName == null)
            {
                ShowAlert("Cần tên ngôn ngữ: tra cứu mã thành công hoặc nhập tên hiển thị thủ công.", "warning");
                return;
            }
        }

        isAddingLanguage = true;
        StateHasChanged();

        try
        {
            var code = newLangCode.Trim().ToLowerInvariant();
            var duplicate = await Db.Languages.AnyAsync(l => l.Code.ToLower() == code);
            if (duplicate)
            {
                ShowAlert($"Mã ngôn ngữ \"{code}\" đã tồn tại!", "warning");
                return;
            }

            var lang = new Language
            {
                Code = code,
                Name = previewLangName,
                TtsVoice = string.IsNullOrWhiteSpace(newTtsVoice) ? null : newTtsVoice.Trim(),
                IsActive = true
            };

            Db.Languages.Add(lang);
            await Db.SaveChangesAsync();

            // Reset form
            newLangCode = "";
            newTtsVoice = "";
            newLangDisplayName = "";
            previewLangName = null;
            previewError = null;

            ShowAlert($"Đã thêm ngôn ngữ \"{lang.Name}\" ({lang.Code}) thành công!", "success");
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowAlert($"Lỗi khi thêm ngôn ngữ: {ex.Message}", "danger");
        }
        finally
        {
            isAddingLanguage = false;
        }
    }

    // ══════════════════════════════════════════
    // DỊCH HÀNG LOẠT
    // ══════════════════════════════════════════
    private async Task StartBatchTranslate()
    {
        if (targetLanguageId == 0)
        {
            ShowAlert("Vui lòng chọn ngôn ngữ đích.", "warning");
            return;
        }
        if (sourceLanguageId == targetLanguageId)
        {
            ShowAlert("Ngôn ngữ nguồn và đích không được trùng nhau.", "warning");
            return;
        }

        var sourceLang = languages.FirstOrDefault(l => l.LanguageId == sourceLanguageId);
        var targetLang = languages.FirstOrDefault(l => l.LanguageId == targetLanguageId);
        if (sourceLang == null || targetLang == null) return;

        var eligiblePoisQuery = Db.Pois
            .AsNoTracking()
            .Where(p => p.IsActive && p.Status != null && p.Status.ToUpper() == "APPROVED");

        if (selectedPoiId > 0)
            eligiblePoisQuery = eligiblePoisQuery.Where(p => p.PoiId == selectedPoiId);

        var eligiblePois = await eligiblePoisQuery
            .Select(p => new { p.PoiId, p.Name })
            .OrderBy(p => p.Name)
            .ToListAsync();

        if (!eligiblePois.Any())
        {
            ShowAlert("Không có POI nào đang hoạt động và đã được admin duyệt trong phạm vi bạn chọn.", "warning");
            return;
        }

        var eligiblePoiIds = eligiblePois.Select(p => p.PoiId).ToList();
        var sourceNarrationsRaw = await Db.Narrations
            .AsNoTracking()
            .Where(n => n.LanguageId == sourceLanguageId && n.IsActive && eligiblePoiIds.Contains(n.PoiId))
            .ToListAsync();

        var sourceByPoi = sourceNarrationsRaw
            .GroupBy(n => n.PoiId)
            .ToDictionary(
                g => g.Key,
                g => g.OrderByDescending(x => x.UpdatedAt ?? DateTime.MinValue)
                      .ThenByDescending(x => x.NarrationId)
                      .First());

        if (!sourceByPoi.Any())
        {
            ShowAlert("Không tìm thấy narration nguồn hợp lệ cho POI đang hoạt động và đã được admin duyệt.", "warning");
            return;
        }

        // Kiểm tra narration đã tồn tại ở ngôn ngữ đích
        var sourcePoiIds = sourceByPoi.Keys.ToList();
        var existingTargetNarrations = await Db.Narrations
            .Where(n => n.LanguageId == targetLanguageId && n.IsActive && sourcePoiIds.Contains(n.PoiId))
            .AsNoTracking()
            .ToListAsync();

        var existingSet = existingTargetNarrations
            .Select(n => n.PoiId)
            .ToHashSet();

        var overlapCount = sourcePoiIds.Count(id => existingSet.Contains(id));

        bool overwrite = false;
        if (overlapCount > 0)
        {
            // Hiện modal xác nhận
            overwriteCount = overlapCount;
            showOverwriteConfirm = true;
            overwriteTcs = new TaskCompletionSource<bool?>();
            StateHasChanged();

            var choice = await overwriteTcs.Task;
            showOverwriteConfirm = false;

            if (choice == null) return; // Hủy
            overwrite = choice.Value;
        }

        // Bắt đầu dịch
        isTranslating = true;
        translateResults.Clear();
        translateTotal = eligiblePois.Count;
        translateCurrent = 0;
        progressPercent = 0;
        alertMessage = null;
        StateHasChanged();

        foreach (var poi in eligiblePois)
        {
            translateCurrent++;
            progressPercent = (int)((double)translateCurrent / translateTotal * 100);
            StateHasChanged();
            await Task.Delay(50); // Cho UI cập nhật

            if (!sourceByPoi.TryGetValue(poi.PoiId, out var narration))
            {
                translateResults.Add(new TranslateResult
                {
                    PoiName = poi.Name,
                    Title = "(chưa có narration nguồn)",
                    Success = false,
                    Error = $"POI chưa có narration ở ngôn ngữ nguồn [{sourceLang.Code.ToUpper()}]."
                });
                continue;
            }

            var poiName = poi.Name;

            // Kiểm tra đã tồn tại
            var existingNarration = await Db.Narrations
                .Where(n => n.PoiId == narration.PoiId && n.LanguageId == targetLanguageId && n.IsActive)
                .OrderByDescending(n => n.UpdatedAt ?? DateTime.MinValue)
                .ThenByDescending(n => n.NarrationId)
                .FirstOrDefaultAsync();

            if (existingNarration != null && !overwrite)
            {
                translateResults.Add(new TranslateResult
                {
                    PoiName = poiName,
                    Title = narration.Title,
                    Success = true,
                    Error = "Đã bỏ qua (narration đã tồn tại)"
                });
                continue;
            }

            try
            {
                // Dịch title
                var translatedTitle = await TranslateService.TranslateAsync(
                    narration.Title, sourceLang.Code, targetLang.Code);

                // Dịch content
                var translatedContent = await TranslateService.TranslateAsync(
                    narration.Content, sourceLang.Code, targetLang.Code);

                // ── TỰ ĐỘNG SINH TTS ──
                string? autoAudioUrl = null;
                var voice = targetLang.TtsVoice;
                if (!string.IsNullOrEmpty(voice) && !string.IsNullOrEmpty(translatedContent))
                {
                    var stem = $"auto_{targetLang.Code}_{narration.PoiId}";
                    var tts = await TtsService.GenerateAndPersistLocalAsync(
                        translatedContent, voice, stem, targetLang.Code);
                    
                    if (string.IsNullOrEmpty(tts.ErrorMessage))
                        autoAudioUrl = tts.Url;
                }

                if (existingNarration != null)
                {
                    // Ghi đè
                    existingNarration.Title = translatedTitle;
                    existingNarration.Content = translatedContent;
                    existingNarration.AudioUrlAuto = autoAudioUrl ?? existingNarration.AudioUrlAuto;
                    existingNarration.UpdatedAt = DateTime.Now;
                    Db.Narrations.Update(existingNarration);
                }
                else
                {
                    // Tạo mới
                    var newNarration = new Narration
                    {
                        PoiId = narration.PoiId,
                        LanguageId = targetLanguageId,
                        Title = translatedTitle,
                        Content = translatedContent,
                        AudioUrlAuto = autoAudioUrl,
                        TtsVoice = targetLang.TtsVoice,
                        IsActive = true,
                        UpdatedAt = DateTime.Now
                    };
                    Db.Narrations.Add(newNarration);
                }

                await Db.SaveChangesAsync();

                translateResults.Add(new TranslateResult
                {
                    PoiName = poiName,
                    Title = translatedTitle,
                    Success = true,
                    Overwritten = existingNarration != null
                });
            }
            catch (Exception ex)
            {
                translateResults.Add(new TranslateResult
                {
                    PoiName = poiName,
                    Title = narration.Title,
                    Success = false,
                    Error = ex.Message
                });
            }

            StateHasChanged();
        }

        isTranslating = false;
        await LoadData(); // Reload để cập nhật số lượng narration
        StateHasChanged();
    }

    private async Task RunTranslationAudit()
    {
        if (auditSourceLanguageId <= 0 || auditTargetLanguageId <= 0 || auditSourceLanguageId == auditTargetLanguageId)
        {
            auditTotalPois = 0;
            auditTranslatedPois = 0;
            auditMissingPoiNames.Clear();
            auditIssues.Clear();
            return;
        }

        isAuditing = true;
        StateHasChanged();

        try
        {
            var eligiblePois = await Db.Pois
                .AsNoTracking()
                .Where(p => p.IsActive && p.Status != null && p.Status.ToUpper() == "APPROVED")
                .Select(p => new { p.PoiId, p.Name })
                .OrderBy(p => p.Name)
                .ToListAsync();

            var eligiblePoiIds = eligiblePois.Select(p => p.PoiId).ToList();
            var poiNameMap = eligiblePois.ToDictionary(x => x.PoiId, x => x.Name);

            var sourceRows = await Db.Narrations
                .Where(n => n.LanguageId == auditSourceLanguageId && n.IsActive && eligiblePoiIds.Contains(n.PoiId))
                .AsNoTracking()
                .ToListAsync();

            var sourceByPoi = sourceRows
                .GroupBy(n => n.PoiId)
                .ToDictionary(
                    g => g.Key,
                    g => g.OrderByDescending(x => x.UpdatedAt ?? DateTime.MinValue)
                          .ThenByDescending(x => x.NarrationId)
                          .First());

            var targetRows = await Db.Narrations
                .Where(n => n.LanguageId == auditTargetLanguageId && n.IsActive && eligiblePoiIds.Contains(n.PoiId))
                .AsNoTracking()
                .ToListAsync();

            var targetByPoi = targetRows
                .GroupBy(n => n.PoiId)
                .ToDictionary(
                    g => g.Key,
                    g => g.OrderByDescending(x => x.UpdatedAt ?? DateTime.MinValue)
                          .ThenByDescending(x => x.NarrationId)
                          .First());

            auditTotalPois = eligiblePoiIds.Count;
            auditTranslatedPois = eligiblePoiIds.Count(id => targetByPoi.ContainsKey(id));

            auditMissingPoiNames = eligiblePoiIds
                .Where(id => !targetByPoi.ContainsKey(id))
                .Select(id => poiNameMap.GetValueOrDefault(id) ?? $"POI #{id}")
                .OrderBy(x => x)
                .ToList();

            var sourceCode = GetLangCode(auditSourceLanguageId);
            var targetCode = GetLangCode(auditTargetLanguageId);
            var issues = new List<AuditIssue>();

            foreach (var poiId in eligiblePoiIds)
            {
                var poiName = poiNameMap.GetValueOrDefault(poiId) ?? $"POI #{poiId}";

                if (!sourceByPoi.TryGetValue(poiId, out var sourceNarration))
                {
                    issues.Add(new AuditIssue { PoiName = poiName, Message = $"Chưa có narration nguồn ({sourceCode})." });
                    continue;
                }

                if (!targetByPoi.TryGetValue(poiId, out var targetNarration))
                    continue;

                var src = sourceNarration.Content?.Trim() ?? string.Empty;
                var dst = targetNarration.Content?.Trim() ?? string.Empty;

                if (string.IsNullOrWhiteSpace(dst))
                {
                    issues.Add(new AuditIssue { PoiName = poiName, Message = "Nội dung đích đang trống." });
                    continue;
                }

                if (!string.Equals(sourceCode, targetCode, StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(src, dst, StringComparison.OrdinalIgnoreCase) &&
                    src.Length > 20)
                {
                    issues.Add(new AuditIssue { PoiName = poiName, Message = "Nội dung đích giống hệt nguồn, có thể chưa dịch." });
                    continue;
                }

                if (src.Length > 60 && dst.Length < (int)(src.Length * 0.35))
                    issues.Add(new AuditIssue { PoiName = poiName, Message = "Nội dung đích quá ngắn so với nguồn, nên rà soát lại." });
            }

            auditIssues = issues;
        }
        catch (Exception ex)
        {
            ShowAlert($"Không thể chạy kiểm tra bản dịch: {ex.Message}", "warning");
        }
        finally
        {
            isAuditing = false;
            StateHasChanged();
        }
    }

    private void ConfirmOverwrite(bool doOverwrite)
    {
        overwriteTcs?.TrySetResult(doOverwrite);
    }

    private async Task CleanupLegacyAudio()
    {
        if (isProcessing) return;
        
        var confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa tất cả liên kết audio thủ công cũ của TOÀN BỘ các quán không? Hành động này không thể hoàn tác.");
        if (!confirm) return;

        isProcessing = true;
        alertMessage = "Đang dọn dẹp dữ liệu audio cũ...";
        alertClass = "alert-info";
        alertIcon = "bi-info-circle";
        StateHasChanged();

        try
        {
            var count = await PoiService.GlobalCleanupLegacyAudioAsync();
            alertMessage = $"Đã dọn dẹp xong! Tổng cộng {count} bản ghi narration đã được đưa về trạng thái thuần AI.";
            alertClass = "alert-success";
            alertIcon = "bi-check-circle";
        }
        catch (Exception ex)
        {
            alertMessage = $"Lỗi khi dọn dẹp: {ex.Message}";
            alertClass = "alert-danger";
            alertIcon = "bi-exclamation-triangle";
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void CancelTranslate()
    {
        overwriteTcs?.TrySetResult(null);
    }

    // ── Helpers ──
    private void ShowAlert(string message, string type)
    {
        alertMessage = message;
        alertClass = type switch
        {
            "success" => "alert-success",
            "warning" => "alert-warning",
            _ => "alert-danger"
        };
        alertIcon = type switch
        {
            "success" => "bi-check-circle-fill",
            "warning" => "bi-exclamation-triangle-fill",
            _ => "bi-exclamation-triangle"
        };
    }

