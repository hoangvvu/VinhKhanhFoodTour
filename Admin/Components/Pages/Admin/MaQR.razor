@page "/ma-qr"
@using Microsoft.AspNetCore.Authorization
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@inject ApplicationDbContext Db
@inject IJSRuntime JS
@inject PoiService PoiService

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">QUẢN LÝ MÃ QR</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-danger rounded-pill" @onclick="DeleteAllQrAsync">
                <i class="bi bi-trash me-1"></i>Xóa toàn bộ QR cũ
            </button>
            <button class="btn btn-warning rounded-pill" @onclick="CreateMasterQrAsync">
                <i class="bi bi-qr-code me-1"></i>Tạo QR tổng duy nhất
            </button>
        </div>
    </div>

    <div class="alert alert-secondary border-0 mb-4" style="border-radius: 12px; background-color: #1A1818; color: #F0EBE3;">
        <i class="bi bi-info-circle me-2 text-warning"></i>
        Mã QR đầu phố do <strong>Admin quản lý</strong>. Chủ gian hàng chỉ quản lý TTS/audio.
    </div>

    @if (!string.IsNullOrEmpty(pageMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @pageMessage
            <button type="button" class="btn-close" @onclick="() => pageMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="text-muted mt-3">Đang tải...</p>
        </div>
    }
    else
    {
        <div class="card bg-dark-card border-0 shadow-sm mb-4" style="border-radius: 16px;">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small">QR Tổng hệ thống</div>
                    <h5 class="text-white mb-1">@PoiService.MasterTourQrToken</h5>
                    <div class="text-muted small">Dùng 1 mã duy nhất để khởi động hàng đợi audio toàn tuyến.</div>
                </div>
                <img src="@GetQrImageUrl(PoiService.MasterTourQrToken)" class="img-fluid bg-white p-2 rounded-3" alt="Master QR" style="width: 96px; height: 96px;" />
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px;">
                    <div class="text-muted small fw-bold">TỔNG MÃ QR</div>
                    <h3 class="text-white fw-bold mb-0">@qrList.Count</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px;">
                    <div class="text-muted small fw-bold">ĐANG HOẠT ĐỘNG</div>
                    <h3 class="text-success fw-bold mb-0">@qrList.Count(q => q.IsActive)</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px;">
                    <div class="text-muted small fw-bold">LƯỢT QUÉT HÔM NAY</div>
                    <h3 class="text-warning fw-bold mb-0">@todayScans</h3>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var qr in qrList)
            {
                <div class="col text-center">
                    <div class="card bg-dark-card border-0 shadow-sm h-100" style="border-radius: 16px;">
                        <div class="card-body p-3">
                            <div class="p-3 bg-white rounded-4 shadow-sm mb-3 mx-auto" style="width: fit-content;">
                                <img src="@GetQrImageUrl(qr.QrToken)" class="img-fluid" alt="QR" style="width: 150px; height: 150px;" />
                            </div>
                            <p class="text-white fw-bold mb-1">@qr.PoiName</p>
                            <p class="text-muted small mb-1">Chủ: <span class="text-white">@qr.OwnerName</span></p>
                            <p class="text-muted small mb-2">@qr.OwnerEmail</p>
                            <p class="text-muted small mb-2">@qr.LocationNote</p>
                            <div class="bg-black rounded-pill px-3 py-1 d-inline-block mb-2">
                                <code class="text-danger small">@qr.QrToken</code>
                            </div>
                            <div class="mb-2">
                                @if (qr.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã tắt</span>
                                }
                            </div>
                            <div class="d-flex gap-1 justify-content-center">
                                <button class="btn btn-sm btn-outline-info rounded-pill" type="button" @onclick="() => DownloadQr(qr.QrToken)" title="Tải QR">
                                    <i class="bi bi-download"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-light rounded-pill" type="button" @onclick="() => RegenerateByDescription(qr)" title="Cập nhật token theo mô tả">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                                <button class="btn btn-sm @(qr.IsActive ? "btn-outline-warning" : "btn-warning text-dark") rounded-pill" type="button" @onclick="() => ToggleQr(qr.QrId)" title="Bật/Tắt">
                                    <i class="bi @(qr.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!qrList.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-qr-code display-1 d-block mb-3 opacity-25"></i>
                <p>Chưa có mã QR. Chủ quán tạo mã tại <strong>Mô tả &amp; hình ảnh</strong>.</p>
            </div>
        }
    }
</div>

@code {
    private List<QrDisplayItem> qrList = new();
    private bool isLoading = true;
    private int todayScans;
    private string? pageMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
        var today = DateTime.Today;

        qrList = await (
            from q in Db.QrCodes.AsNoTracking()
            join p in Db.Pois.AsNoTracking() on q.PoiId equals p.PoiId
            join u in Db.Users.AsNoTracking() on p.OwnerId equals u.UserId into uj
            from u in uj.DefaultIfEmpty()
            where p.OwnerId != null
            orderby p.Name, q.QrToken
            select new QrDisplayItem
            {
                QrId = q.QrId,
                QrToken = q.QrToken,
                PoiId = p.PoiId,
                PoiName = p.Name,
                PoiDescription = p.Description ?? "",
                LocationNote = q.LocationNote ?? "",
                IsActive = q.IsActive,
                OwnerUserId = p.OwnerId ?? 0,
                OwnerName = u != null ? u.Name : "—",
                OwnerEmail = u != null ? u.Email : "—"
            }).ToListAsync();

        todayScans = await Db.TrackingLogs
            .CountAsync(t => t.EventType == "qr_scan" && t.CreatedAt >= today);
    }

    private static string GetQrImageUrl(string token)
    {
        var qrData = Uri.EscapeDataString($"vkfoodtour://{token}");
        return $"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={qrData}";
    }

    private async Task ToggleQr(int qrId)
    {
        var qr = await Db.QrCodes.FindAsync(qrId);
        if (qr is null)
            return;
        qr.IsActive = !qr.IsActive;
        await Db.SaveChangesAsync();
        await LoadData();
    }

    private async Task RegenerateByDescription(QrDisplayItem qr)
    {
        if (qr.PoiId <= 0 || qr.OwnerUserId <= 0)
            return;

        var token = await PoiService.RegenerateQrFromDescriptionAsync(
            qr.PoiId,
            qr.OwnerUserId,
            qr.PoiDescription,
            "QR dau pho (admin)");

        if (!string.IsNullOrWhiteSpace(token))
            pageMessage = $"Da cap nhat QR cho {qr.PoiName}: {token}";

        await LoadData();
    }

    private async Task DownloadQr(string token)
    {
        await JS.InvokeVoidAsync("open", GetQrImageUrl(token), "_blank");
    }

    private async Task DeleteAllQrAsync()
    {
        var deleted = await PoiService.DeleteAllQrAsync();
        pageMessage = $"Đã xóa {deleted} mã QR cũ.";
        await LoadData();
    }

    private async Task CreateMasterQrAsync()
    {
        var token = await PoiService.EnsureMasterTourQrAsync();
        pageMessage = string.IsNullOrWhiteSpace(token)
            ? "Không thể tạo QR tổng (chưa có quán active để gắn mã)."
            : $"Đã tạo QR tổng: {token}";
        await LoadData();
    }

    private sealed class QrDisplayItem
    {
        public int QrId { get; set; }
        public string QrToken { get; set; } = "";
        public int PoiId { get; set; }
        public int OwnerUserId { get; set; }
        public string PoiName { get; set; } = "";
        public string PoiDescription { get; set; } = "";
        public string LocationNote { get; set; } = "";
        public string OwnerName { get; set; } = "";
        public string OwnerEmail { get; set; } = "";
        public bool IsActive { get; set; }
    }
}
