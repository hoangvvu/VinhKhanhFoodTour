@page "/ma-qr"
@using Microsoft.AspNetCore.Authorization
@using VKFoodTour.Infrastructure.Data
@using VKFoodTour.Infrastructure.Entities
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@rendermode InteractiveServer

@inject ApplicationDbContext Db
@inject IJSRuntime JS

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-white fw-bold mb-0">QUẢN LÝ MÃ QR</h3>
        <button class="btn btn-danger rounded-pill px-4 shadow" @onclick="ShowAddModal">
            <i class="bi bi-plus-lg me-2"></i>Tạo mã QR mới
        </button>
    </div>

    @if (!string.IsNullOrEmpty(pageMessage))
    {
        <div class="alert @(pageIsError ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @pageMessage
            <button type="button" class="btn-close" @onclick="() => pageMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
            <p class="text-muted mt-3">Đang tải...</p>
        </div>
    }
    else
    {
        @* ── Thống kê nhanh ── *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px;">
                    <div class="text-muted small fw-bold">TỔNG MÃ QR</div>
                    <h3 class="text-white fw-bold mb-0">@qrList.Count</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px;">
                    <div class="text-muted small fw-bold">ĐANG HOẠT ĐỘNG</div>
                    <h3 class="text-success fw-bold mb-0">@qrList.Count(q => q.IsActive)</h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px;">
                    <div class="text-muted small fw-bold">LƯỢT QUÉT HÔM NAY</div>
                    <h3 class="text-warning fw-bold mb-0">@todayScans</h3>
                </div>
            </div>
        </div>

        @* ── Grid hiển thị QR codes ── *@
        <div class="row row-cols-2 row-cols-md-4 g-4">
            @foreach (var qr in qrList)
            {
                <div class="col text-center">
                    <div class="card bg-dark-card border-0 shadow-sm h-100" style="border-radius: 16px;">
                        <div class="card-body p-3">
                            @* Ảnh QR — dùng API miễn phí, encode token vào QR *@
                            <div class="p-3 bg-white rounded-4 shadow-sm mb-3 mx-auto" style="width: fit-content;">
                                <img src="@GetQrImageUrl(qr.QrToken)"
                                     class="img-fluid" alt="QR @qr.QrToken"
                                     style="width: 150px; height: 150px;" />
                            </div>

                            @* Tên POI *@
                            <p class="text-white fw-bold mb-1">@qr.PoiName</p>
                            <p class="text-muted small mb-2">@qr.LocationNote</p>

                            @* Token *@
                            <div class="bg-black rounded-pill px-3 py-1 d-inline-block mb-2">
                                <code class="text-danger small">@qr.QrToken</code>
                            </div>

                            @* Trạng thái *@
                            <div class="mb-2">
                                @if (qr.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã tắt</span>
                                }
                            </div>

                            @* Actions *@
                            <div class="d-flex gap-1 justify-content-center">
                                <button class="btn btn-sm btn-outline-info rounded-pill"
                                        @onclick="() => DownloadQr(qr.QrToken)"
                                        title="Tải QR">
                                    <i class="bi bi-download"></i>
                                </button>
                                <button class="btn btn-sm @(qr.IsActive ? "btn-outline-warning" : "btn-warning text-dark") rounded-pill"
                                        @onclick="() => ToggleQr(qr.QrId)"
                                        title="Bật/Tắt">
                                    <i class="bi @(qr.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!qrList.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-qr-code display-1 d-block mb-3 opacity-25"></i>
                <p>Chưa có mã QR nào. Bấm "Tạo mã QR mới" để bắt đầu.</p>
            </div>
        }
    }
</div>

@* ══════════════════════════════════════════════════════════
   MODAL TẠO MÃ QR MỚI
   ══════════════════════════════════════════════════════════ *@

@if (isShowModal)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary text-white" style="border-radius: 16px;">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold">Tạo Mã QR Mới</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="HideModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(modalError))
                    {
                        <div class="alert alert-danger py-2 small" style="border-radius: 8px;">@modalError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Gian hàng / Điểm đặt QR</label>
                        <select class="form-select bg-black border-secondary text-white" @bind="selectedPoiId">
                            <option value="0">-- Chọn gian hàng --</option>
                            @foreach (var poi in allPois)
                            {
                                <option value="@poi.PoiId">@poi.Name</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Ghi chú vị trí đặt QR</label>
                        <input type="text" class="form-control bg-black border-secondary text-white"
                               @bind="newLocationNote"
                               placeholder="VD: Tại bàn thu ngân, Trạm xe buýt Khánh Hội..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Token (tự động tạo)</label>
                        <div class="input-group">
                            <input type="text" class="form-control bg-black border-secondary text-info fw-bold"
                                   value="@generatedToken" readonly />
                            <button class="btn btn-outline-info" @onclick="RegenerateToken">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </div>
                        <small class="text-muted">Token này sẽ được nhúng vào mã QR. App mobile quét → nhận token → phát thuyết minh.</small>
                    </div>

                    @* ── Preview QR ── *@
                    @if (selectedPoiId > 0)
                    {
                        <div class="text-center mt-3 p-3 bg-white rounded-4">
                            <img src="@GetQrImageUrl(generatedToken)"
                                 style="width: 200px; height: 200px;" />
                        </div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-outline-light rounded-pill px-4" @onclick="HideModal">Hủy</button>
                    <button class="btn btn-danger rounded-pill px-4 fw-bold" @onclick="SaveQr" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-qr-code me-2"></i>Tạo mã QR
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── State ───────────────────────────────
    private List<QrDisplayItem> qrList = new();
    private List<Poi> allPois = new();
    private bool isLoading = true;
    private int todayScans;

    // ── Modal ───────────────────────────────
    private bool isShowModal = false;
    private bool isSaving = false;
    private string modalError = string.Empty;
    private int selectedPoiId;
    private string newLocationNote = string.Empty;
    private string generatedToken = string.Empty;

    // ── Page messages ───────────────────────
    private string? pageMessage;
    private bool pageIsError;

    // ═══════════════════════════════════════════
    //  LIFECYCLE
    // ═══════════════════════════════════════════

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
        var today = DateTime.Today;

        // Lấy tất cả QR codes kèm tên POI
        qrList = await Db.QrCodes
            .Include(q => q.Poi)
            .OrderBy(q => q.Poi.Name)
            .ThenBy(q => q.LocationNote)
            .Select(q => new QrDisplayItem
            {
                QrId = q.QrId,
                QrToken = q.QrToken,
                PoiName = q.Poi.Name,
                LocationNote = q.LocationNote ?? "",
                IsActive = q.IsActive
            })
            .AsNoTracking()
            .ToListAsync();

        // Lượt quét hôm nay
        todayScans = await Db.TrackingLogs
            .CountAsync(t => t.EventType == "qr_scan" && t.CreatedAt >= today);

        // Danh sách POI cho modal
        allPois = await Db.Pois
            .Where(p => p.IsActive)
            .OrderBy(p => p.Name)
            .AsNoTracking()
            .ToListAsync();
    }

    // ═══════════════════════════════════════════
    //  QR IMAGE URL
    //  Dùng API miễn phí goqr.me
    //  Data trong QR = "vkfoodtour://{token}"
    //  App mobile sẽ quét → parse scheme → tìm POI → phát audio
    // ═══════════════════════════════════════════

    private string GetQrImageUrl(string token)
    {
        // Format: vkfoodtour://VK-POI-001-OC-OANH
        // App mobile đăng ký Deep Link scheme "vkfoodtour://"
        // Khi quét QR → app mở, parse token → lookup POI → phát thuyết minh
        var qrData = Uri.EscapeDataString($"vkfoodtour://{token}");
        return $"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={qrData}";
    }

    // ═══════════════════════════════════════════
    //  MODAL
    // ═══════════════════════════════════════════

    private void ShowAddModal()
    {
        modalError = string.Empty;
        selectedPoiId = 0;
        newLocationNote = string.Empty;
        RegenerateToken();
        isShowModal = true;
    }

    private void HideModal() => isShowModal = false;

    private void RegenerateToken()
    {
        // Tạo token format: VK-{random 8 ký tự}
        var random = Guid.NewGuid().ToString("N")[..8].ToUpper();
        generatedToken = $"VK-{random}";
    }

    private async Task SaveQr()
    {
        if (selectedPoiId == 0)
        {
            modalError = "Vui lòng chọn gian hàng.";
            return;
        }

        // Kiểm tra token trùng
        var exists = await Db.QrCodes.AnyAsync(q => q.QrToken == generatedToken);
        if (exists)
        {
            modalError = "Token đã tồn tại. Bấm nút tạo lại.";
            return;
        }

        isSaving = true;
        modalError = string.Empty;

        try
        {
            var qr = new QrCode
            {
                PoiId = selectedPoiId,
                QrToken = generatedToken,
                LocationNote = string.IsNullOrWhiteSpace(newLocationNote) ? null : newLocationNote,
                IsActive = true
            };

            Db.QrCodes.Add(qr);
            await Db.SaveChangesAsync();

            pageMessage = $"Đã tạo mã QR \"{generatedToken}\" thành công!";
            pageIsError = false;

            HideModal();
            await LoadData();
        }
        catch (Exception ex)
        {
            modalError = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    // ═══════════════════════════════════════════
    //  TOGGLE / DOWNLOAD
    // ═══════════════════════════════════════════

    private async Task ToggleQr(int qrId)
    {
        var qr = await Db.QrCodes.FindAsync(qrId);
        if (qr != null)
        {
            qr.IsActive = !qr.IsActive;
            await Db.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task DownloadQr(string token)
    {
        var url = GetQrImageUrl(token);
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    // ═══════════════════════════════════════════
    //  DISPLAY MODEL
    // ═══════════════════════════════════════════

    private class QrDisplayItem
    {
        public int QrId { get; set; }
        public string QrToken { get; set; } = "";
        public string PoiName { get; set; } = "";
        public string LocationNote { get; set; } = "";
        public bool IsActive { get; set; }
    }
}
