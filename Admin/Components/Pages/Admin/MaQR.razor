@page "/ma-qr"
@using Microsoft.AspNetCore.Authorization
@using global::Admin.Services
@using VKFoodTour.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@inject ApplicationDbContext Db
@inject IJSRuntime JS
@inject PoiService PoiService

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">QUẢN LÝ MÃ QR</h2>
            <span style="color: #4a4a5a; font-size: 13px;"><i class="bi bi-clock me-1"></i>Mã QR đầu phố &amp; hệ thống</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-danger rounded-pill" @onclick="DeleteAllQrAsync">
                <i class="bi bi-trash me-1"></i>Xóa toàn bộ QR cũ
            </button>
            <button class="btn btn-warning rounded-pill" @onclick="CreateMasterQrAsync">
                <i class="bi bi-qr-code me-1"></i>Tạo QR tổng duy nhất
            </button>
        </div>
    </div>

    <div class="p-3 mb-4" style="background:rgba(232,160,32,0.08);border:1px solid rgba(232,160,32,0.2);border-radius:12px;color:#d1d5db;">
        <i class="bi bi-info-circle me-2 text-warning"></i>
        Mã QR đầu phố do <strong>Admin quản lý</strong>. Chủ gian hàng chỉ quản lý TTS/audio.
    </div>

    @if (!string.IsNullOrEmpty(pageMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @pageMessage
            <button type="button" class="btn-close" @onclick="() => pageMessage = null"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <p style="color:#4a4a5a;font-size:13px;letter-spacing:1px;margin-top:12px;">ĐANG TẢI...</p>
        </div>
    }
    else
    {
        <div class="dash-card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;font-weight:700;" class="mb-1">QR TỔNG HỆ THỐNG</div>
                    <h5 style="color:#F0EBE3;" class="mb-1">@PoiService.MasterTourQrToken</h5>
                    <div style="color:#4a4a5a;" class="small">Dùng 1 mã duy nhất để khởi động hàng đợi audio toàn tuyến.</div>
                </div>
                <img src="@GetQrImageUrl(PoiService.MasterTourQrToken)" class="img-fluid bg-white p-2 rounded-3" alt="Master QR" style="width: 96px; height: 96px;" />
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="dash-card p-4">
                    <div style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;font-weight:700;" class="mb-2">TỔNG MÃ QR</div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="background:rgba(232,160,32,0.12);border-radius:12px;padding:10px;" class="d-flex align-items-center justify-content-center">
                            <i class="bi bi-qr-code fs-4" style="color:#E8A020;"></i>
                        </div>
                        <h3 class="fw-bold mb-0" style="color:#F0EBE3;">@qrList.Count</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dash-card p-4">
                    <div style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;font-weight:700;" class="mb-2">ĐANG HOẠT ĐỘNG</div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="background:rgba(34,197,94,0.12);border-radius:12px;padding:10px;" class="d-flex align-items-center justify-content-center">
                            <i class="bi bi-check-circle fs-4" style="color:#4ade80;"></i>
                        </div>
                        <h3 class="fw-bold mb-0" style="color:#4ade80;">@qrList.Count(q => q.IsActive)</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="dash-card p-4">
                    <div style="color:#4a4a5a;font-size:11px;letter-spacing:1.5px;font-weight:700;" class="mb-2">LƯỢT QUÉT HÔM NAY</div>
                    <div class="d-flex align-items-center gap-3">
                        <div style="background:rgba(232,160,32,0.12);border-radius:12px;padding:10px;" class="d-flex align-items-center justify-content-center">
                            <i class="bi bi-bar-chart fs-4" style="color:#E8A020;"></i>
                        </div>
                        <h3 class="fw-bold mb-0" style="color:#E8A020;">@todayScans</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var qr in qrList)
            {
                <div class="col text-center">
                    <div class="dash-card p-3 h-100">
                        <div class="p-3 bg-white rounded-4 shadow-sm mb-3 mx-auto" style="width: fit-content;">
                            <img src="@GetQrImageUrl(qr.QrToken)" class="img-fluid" alt="QR" style="width: 150px; height: 150px;" />
                        </div>
                        <p class="fw-bold mb-1" style="color:#F0EBE3;">@qr.PoiName</p>
                        <p class="small mb-1" style="color:#4a4a5a;">Chủ: <span style="color:#F0EBE3;">@qr.OwnerName</span></p>
                        <p class="small mb-2" style="color:#4a4a5a;">@qr.OwnerEmail</p>
                        <p class="small mb-2" style="color:#4a4a5a;">@qr.LocationNote</p>
                        <div class="d-inline-block mb-2" style="background:rgba(0,0,0,0.3);border-radius:8px;padding:8px 12px;">
                            <code style="color:#E8A020;" class="small">@qr.QrToken</code>
                        </div>
                        <div class="mb-2">
                            @if (qr.IsActive)
                            {
                                <span class="badge px-3 py-2" style="background:rgba(34,197,94,0.12);color:#4ade80;border:1px solid rgba(34,197,94,0.25);border-radius:20px;">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge px-3 py-2" style="background:rgba(107,114,128,0.12);color:#6b7280;border:1px solid rgba(107,114,128,0.25);border-radius:20px;">Đã tắt</span>
                            }
                        </div>

                        <!-- TRẠNG THÁI AUDIO -->
                        <div class="d-flex flex-wrap gap-1 justify-content-center mb-3">
                            @foreach (var lang in activeLanguages)
                            {
                                var hasAudio = qr.Narrations.Any(n => n.LanguageId == lang.LanguageId && (!string.IsNullOrWhiteSpace(n.AudioUrlAuto) || !string.IsNullOrWhiteSpace(n.AudioUrlQr)));
                                <div class="badge-status @(hasAudio ? "ready" : "missing")" title="@lang.Name: @(hasAudio ? "Sẵn sàng" : "Chưa có audio")">
                                    @lang.Code.ToUpper()
                                </div>
                            }
                        </div>
                        <div class="d-flex gap-1 justify-content-center">
                            <button class="btn btn-sm btn-outline-info rounded-pill" type="button" @onclick="() => DownloadQr(qr.QrToken)" title="Tải QR">
                                <i class="bi bi-download"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-light rounded-pill" type="button" 
                                    @onclick="() => RegenerateByDescription(qr)" 
                                    disabled="@qr.IsSyncing"
                                    title="Cập nhật QR & Đồng bộ thuyết minh AI">
                                @if (qr.IsSyncing)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <i class="bi bi-arrow-repeat"></i>
                                }
                            </button>
                            <button class="btn btn-sm @(qr.IsActive ? "btn-outline-warning" : "btn-warning text-dark") rounded-pill" type="button" @onclick="() => ToggleQr(qr.QrId)" title="Bật/Tắt">
                                <i class="bi @(qr.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!qrList.Any())
        {
            <div class="text-center py-5" style="color:#4a4a5a;">
                <i class="bi bi-qr-code display-1 d-block mb-3 opacity-25"></i>
                <p>Chưa có mã QR. Chủ quán tạo mã tại <strong>Mô tả &amp; hình ảnh</strong>.</p>
            </div>
        }
    }
</div>

@code {
    private List<QrDisplayItem> qrList = new();
    private List<VKFoodTour.Infrastructure.Entities.Language> activeLanguages = new();
    private bool isLoading = true;
    private int todayScans;
    private string? pageMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        isLoading = false;
    }

    private async Task LoadData()
    {
        var today = DateTime.Today;
        activeLanguages = await PoiService.GetActiveLanguagesAsync();

        var qrs = await Db.QrCodes.AsNoTracking()
            .Include(q => q.Poi)
                .ThenInclude(p => p.Narrations)
            .Where(q => q.Poi.OwnerId != null)
            .OrderBy(q => q.Poi.Name)
            .ThenBy(q => q.QrToken)
            .ToListAsync();

        var userIds = qrs.Select(q => q.Poi.OwnerId).Distinct().ToList();
        var users = await Db.Users.AsNoTracking()
            .Where(u => userIds.Contains(u.UserId))
            .ToDictionaryAsync(u => u.UserId, u => u);

        qrList = qrs.Select(q => {
            var u = q.Poi.OwnerId != null && users.ContainsKey(q.Poi.OwnerId.Value) ? users[q.Poi.OwnerId.Value] : null;
            return new QrDisplayItem
            {
                QrId = q.QrId,
                QrToken = q.QrToken,
                PoiId = q.PoiId,
                PoiName = q.Poi.Name,
                PoiDescription = q.Poi.Description ?? "",
                LocationNote = q.LocationNote ?? "",
                IsActive = q.IsActive,
                OwnerUserId = q.Poi.OwnerId ?? 0,
                OwnerName = u?.Name ?? "—",
                OwnerEmail = u?.Email ?? "—",
                Narrations = q.Poi.Narrations.ToList()
            };
        }).ToList();

        todayScans = await Db.TrackingLogs
            .CountAsync(t => t.EventType == "qr_scan" && t.CreatedAt >= today);
    }

    private static string GetQrImageUrl(string token)
    {
        var qrData = Uri.EscapeDataString($"vkfoodtour://{token}");
        return $"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={qrData}";
    }

    private async Task ToggleQr(int qrId)
    {
        var qr = await Db.QrCodes.FindAsync(qrId);
        if (qr is null)
            return;
        qr.IsActive = !qr.IsActive;
        await Db.SaveChangesAsync();
        await LoadData();
    }

    private async Task RegenerateByDescription(QrDisplayItem qr)
    {
        if (qr.PoiId <= 0 || qr.OwnerUserId <= 0)
            return;

        qr.IsSyncing = true;
        StateHasChanged();

        try
        {
            // 1. Cập nhật mã QR (mô tả -> token)
            var token = await PoiService.RegenerateQrFromDescriptionAsync(
                qr.PoiId,
                qr.OwnerUserId,
                qr.PoiDescription,
                "QR (Admin sync)");

            // 2. Cập nhật thuyết minh đa ngôn ngữ (Dịch & TTS)
            await PoiService.UpdateMultilingualNarrationsAsync(qr.PoiId);

            if (!string.IsNullOrWhiteSpace(token))
                pageMessage = $"Đã cập nhật QR & Đồng bộ thuyết minh cho {qr.PoiName}";
        }
        catch (Exception ex)
        {
            pageMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            qr.IsSyncing = false;
            await LoadData();
        }
    }

    private async Task DownloadQr(string token)
    {
        await JS.InvokeVoidAsync("open", GetQrImageUrl(token), "_blank");
    }

    private async Task DeleteAllQrAsync()
    {
        var deleted = await PoiService.DeleteAllQrAsync();
        pageMessage = $"Đã xóa {deleted} mã QR cũ.";
        await LoadData();
    }

    private async Task CreateMasterQrAsync()
    {
        var token = await PoiService.EnsureMasterTourQrAsync();
        pageMessage = string.IsNullOrWhiteSpace(token)
            ? "Không thể tạo QR tổng (chưa có quán active để gắn mã)."
            : $"Đã tạo QR tổng: {token}";
        await LoadData();
    }

    private sealed class QrDisplayItem
    {
        public int QrId { get; set; }
        public string QrToken { get; set; } = "";
        public int PoiId { get; set; }
        public int OwnerUserId { get; set; }
        public string PoiName { get; set; } = "";
        public string PoiDescription { get; set; } = "";
        public string LocationNote { get; set; } = "";
        public string OwnerName { get; set; } = "";
        public string OwnerEmail { get; set; } = "";
        public bool IsActive { get; set; }
        public bool IsSyncing { get; set; }
        public List<VKFoodTour.Infrastructure.Entities.Narration> Narrations { get; set; } = new();
    }
}

<style>
    .badge-status {
        width: 32px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 800;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .badge-status.ready {
        background: rgba(34, 197, 94, 0.15);
        color: #4ade80;
        border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .badge-status.missing {
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
</style>
