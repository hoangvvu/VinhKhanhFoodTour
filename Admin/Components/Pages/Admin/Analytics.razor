@page "/analytics"
@using Microsoft.AspNetCore.Authorization
@using VKFoodTour.Infrastructure.Data
@using VKFoodTour.Infrastructure.Entities
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@rendermode InteractiveServer

@inject ApplicationDbContext Db

<div class="container-fluid p-4">
    <h3 class="text-white fw-bold mb-4">PHÂN TÍCH & THỐNG KÊ</h3>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" role="status"></div>
        </div>
    }
    else
    {
        @* ── Thẻ tổng quan ── *@
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px; border-left: 4px solid #E8A020 !important;">
                    <div class="text-muted small fw-bold">TỔNG LƯỢT TRUY CẬP</div>
                    <h3 class="text-white fw-bold">@totalEvents</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px; border-left: 4px solid #0dcaf0 !important;">
                    <div class="text-muted small fw-bold">THIẾT BỊ DUY NHẤT</div>
                    <h3 class="text-white fw-bold">@uniqueDevices</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px; border-left: 4px solid #198754 !important;">
                    <div class="text-muted small fw-bold">THỜI GIAN NGHE TB</div>
                    <h3 class="text-white fw-bold">@avgListenSec giây</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px; border-left: 4px solid #C8372D !important;">
                    <div class="text-muted small fw-bold">TỔNG ĐÁNH GIÁ</div>
                    <h3 class="text-white fw-bold">@totalReviews</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-dark-card border-0 p-3 shadow-sm" style="border-radius: 12px; border-left: 4px solid #6f42c1 !important;">
                    <div class="text-muted small fw-bold">TRUY CẬP ẨN DANH</div>
                    <h3 class="text-white fw-bold">@anonymousVisits</h3>
                </div>
            </div>
        </div>

        <div class="row g-4">
            @* ── Top quán được quan tâm ── *@
            <div class="col-md-6">
                <div class="card bg-dark-card text-white border-0 p-4 shadow-sm" style="border-radius: 16px;">
                    <h5 class="fw-bold mb-3"><i class="bi bi-trophy me-2 text-warning"></i>Quán ăn được quan tâm nhất</h5>
                    @if (topVisitedPois.Any())
                    {
                        @foreach (var (item, i) in topVisitedPois.Select((x, i) => (x, i)))
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 @(i < topVisitedPois.Count - 1 ? "border-bottom border-secondary" : "")">
                                <div>
                                    <span class="badge @(i == 0 ? "bg-warning text-dark" : "bg-secondary") me-2">@(i + 1)</span>
                                    <span>@item.Name</span>
                                </div>
                                <span class="text-warning fw-bold">@item.Count lượt</span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Chưa có dữ liệu.</p>
                    }
                </div>
            </div>

            @* ── Ngôn ngữ sử dụng ── *@
            <div class="col-md-6">
                <div class="card bg-dark-card text-white border-0 p-4 shadow-sm" style="border-radius: 16px;">
                    <h5 class="fw-bold mb-3"><i class="bi bi-translate me-2 text-info"></i>Ngôn ngữ sử dụng</h5>
                    @if (languageStats.Any())
                    {
                        @foreach (var lang in languageStats)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@lang.Name (@lang.Code.ToUpper())</span>
                                <div class="d-flex align-items-center gap-2" style="min-width: 120px;">
                                    <div class="progress flex-grow-1" style="height: 8px; background: #333;">
                                        <div class="progress-bar bg-info" style="width: @lang.Percent%"></div>
                                    </div>
                                    <span class="text-info small fw-bold" style="min-width: 35px;">@lang.Percent%</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">Chưa có dữ liệu ngôn ngữ.</p>
                    }
                </div>
            </div>

            @* ── Sự kiện theo loại ── *@
            <div class="col-md-6">
                <div class="card bg-dark-card text-white border-0 p-4 shadow-sm" style="border-radius: 16px;">
                    <h5 class="fw-bold mb-3"><i class="bi bi-bar-chart me-2 text-success"></i>Sự kiện theo loại</h5>
                    @foreach (var evt in eventTypeStats)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-dark border border-secondary px-3">@evt.EventType</span>
                            <span class="text-white fw-bold">@evt.Count</span>
                        </div>
                    }
                </div>
            </div>

            @* ── Đánh giá phân bổ sao ── *@
            <div class="col-md-6">
                <div class="card bg-dark-card text-white border-0 p-4 shadow-sm" style="border-radius: 16px;">
                    <h5 class="fw-bold mb-3"><i class="bi bi-star-fill me-2 text-warning"></i>Phân bổ đánh giá</h5>
                    @for (int star = 5; star >= 1; star--)
                    {
                        var count = ratingDistribution.GetValueOrDefault(star, 0);
                        var percent = totalReviews > 0 ? (count * 100 / totalReviews) : 0;
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="text-warning" style="min-width: 25px;">@star <i class="bi bi-star-fill" style="font-size: 0.7rem;"></i></span>
                            <div class="progress flex-grow-1" style="height: 8px; background: #333;">
                                <div class="progress-bar bg-warning" style="width: @percent%"></div>
                            </div>
                            <span class="text-muted small" style="min-width: 40px;">@count</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;

    // Stats
    private int totalEvents, uniqueDevices, avgListenSec, totalReviews, anonymousVisits;
    private List<NameCount> topVisitedPois = new();
    private List<LangStat> languageStats = new();
    private List<EventStat> eventTypeStats = new();
    private Dictionary<int, int> ratingDistribution = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Tổng events
            totalEvents = await Db.TrackingLogs.CountAsync();
            uniqueDevices = await Db.TrackingLogs.Select(t => t.DeviceId).Distinct().CountAsync();
            anonymousVisits = await Db.TrackingLogs
                .CountAsync(t => t.PoiId == null &&
                                 t.EventType == "move" &&
                                 t.LanguageCode != null &&
                                 t.LanguageCode.StartsWith("anon:"));

            // Thời gian nghe trung bình
            var listenLogs = Db.TrackingLogs.Where(t => t.EventType == "listen_end" && t.ListenedDurationSec != null);
            if (await listenLogs.AnyAsync())
                avgListenSec = (int)await listenLogs.AverageAsync(t => t.ListenedDurationSec!.Value);

            // Top POI
            topVisitedPois = await Db.TrackingLogs
                .Where(t => t.PoiId != null && (t.EventType == "enter" || t.EventType == "qr_scan"))
                .GroupBy(t => t.PoiId)
                .OrderByDescending(g => g.Count())
                .Take(5)
                .Select(g => new NameCount { PoiId = g.Key!.Value, Count = g.Count() })
                .ToListAsync();

            var ids = topVisitedPois.Select(x => x.PoiId).ToList();
            var names = await Db.Pois.Where(p => ids.Contains(p.PoiId)).ToDictionaryAsync(p => p.PoiId, p => p.Name);
            foreach (var item in topVisitedPois)
                item.Name = names.GetValueOrDefault(item.PoiId, "N/A");

            // Ngôn ngữ
            var langCounts = await Db.TrackingLogs
                .Where(t => t.LanguageCode != null)
                .GroupBy(t => t.LanguageCode)
                .Select(g => new { Code = g.Key!, Count = g.Count() })
                .ToListAsync();

            var total = langCounts.Sum(l => l.Count);
            var langNames = await Db.Languages.ToDictionaryAsync(l => l.Code, l => l.Name);

            languageStats = langCounts
                .OrderByDescending(l => l.Count)
                .Select(l => new LangStat
                {
                    Code = l.Code,
                    Name = langNames.GetValueOrDefault(l.Code, l.Code),
                    Percent = total > 0 ? (int)(l.Count * 100.0 / total) : 0
                })
                .ToList();

            // Events by type
            eventTypeStats = await Db.TrackingLogs
                .GroupBy(t => t.EventType)
                .Select(g => new EventStat { EventType = g.Key, Count = g.Count() })
                .OrderByDescending(e => e.Count)
                .ToListAsync();

            // Reviews
            totalReviews = await Db.Reviews.CountAsync();
            ratingDistribution = await Db.Reviews
                .GroupBy(r => (int)r.Rating)
                .ToDictionaryAsync(g => g.Key, g => g.Count());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ANALYTICS] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private class NameCount { public int PoiId; public string Name = ""; public int Count; }
    private class LangStat { public string Code = ""; public string Name = ""; public int Percent; }
    private class EventStat { public string EventType = ""; public int Count; }
}
