@page "/analytics"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

<div class="container-fluid p-4">
    <h3 class="text-white fw-bold mb-4">PHÂN TÍCH & THỐNG KÊ</h3>
    
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card bg-dark-card text-white border-0 p-4">
                <h5>Quán ăn yêu thích nhất</h5>
                <ol class="mt-3">
                    <li class="mb-2">Ốc Oanh (450 lượt quét)</li>
                    <li class="mb-2">Sushi Viên VK (320 lượt quét)</li>
                    <li>Lãng Quán (280 lượt quét)</li>
                </ol>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-dark-card text-white border-0 p-4">
                <h5>Ngôn ngữ sử dụng</h5>
                <ul class="list-unstyled mt-3">
                    <li class="d-flex justify-content-between mb-2"><span>Tiếng Việt</span> <span>70%</span></li>
                    <li class="d-flex justify-content-between mb-2"><span>Tiếng Anh</span> <span>25%</span></li>
                    <li class="d-flex justify-content-between"><span>Khác</span> <span>5%</span></li>
                </ul>
            </div>
        </div>
    </div>
</div>
