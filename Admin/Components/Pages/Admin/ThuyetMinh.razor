@page "/thuyet-minh"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="container-fluid p-4">
    <div class="card bg-dark-card border-0 shadow-sm p-4" style="border-radius: 16px;">
        <h4 class="text-white fw-bold mb-3">THUYẾT MINH ĐÃ CHUYỂN CHO CHỦ GIAN HÀNG</h4>
        <p class="text-muted mb-2">
            Chức năng tạo thuyết minh TTS và tải lên file audio có sẵn hiện được thực hiện tại trang
            <strong>Mô tả &amp; Hình ảnh</strong> của từng chủ gian hàng.
        </p>
        <p class="text-muted mb-0">
            Admin chỉ quản lý tổng quan POI, QR, người dùng và thống kê.
        </p>
    </div>
</div>