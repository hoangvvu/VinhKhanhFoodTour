@page "/thuyet-minh"
@rendermode InteractiveServer

<div class="container-fluid p-4">
    <h3 class="text-white fw-bold mb-4">KHO THUYẾT MINH AUDIO</h3>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card bg-dark-card text-white border-0 p-3 shadow-sm">
                <div class="d-flex justify-content-between mb-3">
                    <span class="badge bg-warning text-dark">VIETNAMESE</span>
                    <i class="bi bi-play-circle fs-4 text-danger"></i>
                </div>
                <h5 class="mb-1">Ốc Oanh - Giới thiệu</h5>
                <p class="text-muted small">Dung lượng: 2.4 MB | Thời lượng: 1:30</p>
                <div class="d-flex gap-2 mt-2">
                    <button class="btn btn-dark btn-sm flex-grow-1 border">Thay file</button>
                    <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>
