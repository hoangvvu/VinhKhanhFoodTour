@page "/gian-hang"
@using Microsoft.AspNetCore.Authorization
@using VKFoodTour.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

@inject ApplicationDbContext Db

<div class="dash-page p-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold mb-1" style="color: #F0EBE3;">QUẢN LÝ GIAN HÀNG</h2>
            <span style="color: #4a4a5a; font-size: 13px;"><i class="bi bi-shop me-1"></i>Toàn bộ gian hàng trên phố Vĩnh Khánh</span>
        </div>
        <a href="/admin/pois" class="btn btn-danger rounded-pill px-4 shadow">
            <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa / ẩn gian hàng
        </a>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-danger" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <p style="color:#4a4a5a;font-size:13px;letter-spacing:1px;margin-top:12px;">ĐANG TẢI...</p>
        </div>
    }
    else
    {
        <div class="dash-card" style="overflow:hidden;">
            <div class="table-responsive">
                <table class="table dash-table mb-0">
                        <thead class="bg-black text-muted small">
                            <tr>
                                <th class="ps-4 py-3">GIAN HÀNG</th>
                                <th>CHỦ &amp; GMAIL</th>
                                <th>ẢNH</th>
                                <th>ĐỊA CHỈ</th>
                                <th>NGÔN NGỮ TM</th>
                                <th>MÓN ĂN</th>
                                <th class="text-end pe-4">TRẠNG THÁI</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in rows)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold">@row.PoiName</span><br />
                                        <span class="badge @(row.Priority == 1 ? "bg-danger-subtle text-danger" : "bg-secondary") small">
                                            Ưu tiên @row.Priority
                                        </span>
                                    </td>
                                    <td class="small">
                                        <div class="text-white">@row.OwnerName</div>
                                        <div class="text-muted">@row.OwnerEmail</div>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap" style="max-width: 140px;">
                                            @if (!string.IsNullOrEmpty(row.CoverUrl))
                                            {
                                                <img src="@row.CoverUrl" class="rounded border border-secondary" style="width:44px;height:44px;object-fit:cover;" alt="" />
                                            }
                                            @foreach (var u in row.GalleryUrls)
                                            {
                                                <img src="@u" class="rounded border border-secondary" style="width:44px;height:44px;object-fit:cover;" alt="" />
                                            }
                                        </div>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(row.Address) ? "—" : row.Address)</td>
                                    <td>
                                        @foreach (var langCode in row.LangCodes)
                                        {
                                            <span class="badge-lang @(langCode is "vi" or "en" ? "badge-vi" : "badge-other")">
                                                @langCode.ToUpper()
                                            </span>
                                        }
                                        @if (!row.LangCodes.Any())
                                        {
                                            <span class="text-muted small">Chưa có</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info">@row.FoodCount món</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (row.IsActive)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Đã ẩn / tắt</span>
                                        }
                                    </td>
                                </tr>
                            }

                            @if (!rows.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">Chưa có gian hàng nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
            </div>
        </div>
    }
</div>

@code {
    private List<GianHangRow> rows = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var pois = await Db.Pois
                .AsNoTracking()
                .OrderBy(p => p.Priority)
                .ThenBy(p => p.Name)
                .ToListAsync();

            var ownerIds = pois.Where(p => p.OwnerId != null).Select(p => p.OwnerId!.Value).Distinct().ToList();
            var users = await Db.Users.AsNoTracking()
                .Where(u => ownerIds.Contains(u.UserId))
                .ToDictionaryAsync(u => u.UserId, u => u);

            var narrations = await Db.Narrations
                .Include(n => n.Language)
                .Where(n => n.IsActive)
                .AsNoTracking()
                .Select(n => new { n.PoiId, n.Language!.Code })
                .ToListAsync();

            var langsByPoi = narrations
                .GroupBy(n => n.PoiId)
                .ToDictionary(g => g.Key, g => g.Select(x => x.Code).Distinct().ToList());

            var foodCounts = await Db.Foods
                .Where(f => f.IsAvailable)
                .GroupBy(f => f.PoiId)
                .ToDictionaryAsync(g => g.Key, g => g.Count());

            var images = await Db.Images
                .AsNoTracking()
                .Where(i => i.PoiId != null && i.FoodId == null && !i.IsCover)
                .GroupBy(i => i.PoiId!.Value)
                .ToDictionaryAsync(g => g.Key, g => g.OrderBy(i => i.SortOrder).Select(i => i.ImageUrl).Take(3).ToList());

            rows = pois.Select(p =>
            {
                users.TryGetValue(p.OwnerId ?? 0, out var u);
                langsByPoi.TryGetValue(p.PoiId, out var lc);
                images.TryGetValue(p.PoiId, out var gal);
                return new GianHangRow
                {
                    PoiName = p.Name,
                    Priority = p.Priority,
                    Address = p.Address,
                    IsActive = p.IsActive,
                    OwnerName = u?.Name ?? "—",
                    OwnerEmail = u?.Email ?? "—",
                    CoverUrl = p.ImageUrl ?? "",
                    GalleryUrls = gal ?? new List<string>(),
                    LangCodes = lc ?? new List<string>(),
                    FoodCount = foodCounts.GetValueOrDefault(p.PoiId, 0)
                };
            }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[GIANHANG] {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed class GianHangRow
    {
        public string PoiName { get; set; } = "";
        public int Priority { get; set; }
        public string? Address { get; set; }
        public bool IsActive { get; set; }
        public string OwnerName { get; set; } = "";
        public string OwnerEmail { get; set; } = "";
        public string CoverUrl { get; set; } = "";
        public List<string> GalleryUrls { get; set; } = new();
        public List<string> LangCodes { get; set; } = new();
        public int FoodCount { get; set; }
    }
}
