@using Microsoft.EntityFrameworkCore
@using VKFoodTour.Infrastructure.Data
@implements IAsyncDisposable
@rendermode InteractiveServer

@inject IDbContextFactory<ApplicationDbContext> DbFactory

<style>
    @@keyframes vk-pulse-green {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.3; transform: scale(0.8); }
    }
    .vk-dev-dot {
        display: inline-block;
        animation: vk-pulse-green 1.6s ease-in-out infinite;
    }
    @@keyframes vk-count-pop {
        from { opacity: 0; transform: translateY(6px) scale(0.95); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .vk-dev-count {
        animation: vk-count-pop 0.35s ease;
    }
    .vk-dev-list-item {
        transition: background 0.15s;
        border-radius: 8px;
    }
    .vk-dev-list-item:hover {
        background: rgba(124,58,237,0.12) !important;
    }
</style>

<div class="h-100 p-4" style="border-radius: 20px; background: linear-gradient(135deg, #1e0a3c 0%, #2d1b69 100%); border: 1px solid rgba(124,58,237,0.3); position: relative; overflow: hidden; min-height: 160px;">
    @* Decorative circles *@
    <div style="position: absolute; top: -25px; right: -25px; width: 120px; height: 120px; background: rgba(124,58,237,0.12); border-radius: 50%; pointer-events:none;"></div>
    <div style="position: absolute; bottom: -20px; right: 40px; width: 65px; height: 65px; background: rgba(124,58,237,0.07); border-radius: 50%; pointer-events:none;"></div>

    @* Header row *@
    <div class="d-flex justify-content-between align-items-start mb-3 position-relative">
        <div>
            <div class="small fw-bold mb-2" style="letter-spacing: 1.5px; color: #a78bfa;">
                @if (isLive)
                {
                    <span class="vk-dev-dot" style="color: #4ade80;">●</span>
                }
                else if (isFirstLoad)
                {
                    <span style="color: #374151;">◌</span>
                }
                else
                {
                    <span style="color: #6b7280;">○</span>
                }
                <span class="ms-1">THIẾT BỊ ĐANG DÙNG APP</span>
            </div>

            @if (isFirstLoad)
            {
                <div class="d-flex align-items-center gap-2 mt-1">
                    <div class="spinner-border spinner-border-sm" style="color:#a78bfa; width:1.4rem; height:1.4rem;" role="status"></div>
                    <span style="color:#4a3a7a; font-size:12px;">Đang kết nối…</span>
                </div>
            }
            else
            {
                <h1 class="vk-dev-count fw-bold mb-0" style="font-size: 3.2rem; color: #fff; line-height: 1;">@activeCount</h1>
                <small style="color: #7c6faa; font-size: 11px; display: block; margin-top: 4px;">
                    thiết bị trong @windowMinutes phút qua
                </small>
                <small style="color: #4a3a7a; font-size: 10px;">
                    cập nhật @secondsAgo giây trước
                </small>
            }
        </div>

        <div style="background: rgba(124,58,237,0.2); border-radius: 14px; padding: 12px; flex-shrink: 0;">
            <i class="bi bi-phone-fill" style="font-size: 1.8rem; color: #a78bfa;"></i>
        </div>
    </div>

    @* Device list *@
    @if (!isFirstLoad && activeDevices.Any())
    {
        <div style="max-height: 160px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: #4a3a7a transparent;">
            @foreach (var dev in activeDevices.Take(8))
            {
                <div class="vk-dev-list-item d-flex justify-content-between align-items-center py-1 px-2 mb-1"
                     style="background: rgba(255,255,255,0.03);">
                    <div class="d-flex align-items-center gap-2">
                        <span style="width:7px;height:7px;background:#4ade80;border-radius:50%;display:inline-block;flex-shrink:0;box-shadow:0 0 6px #4ade80;"></span>
                        <small style="color:#d1c4f0;font-size:11px;font-family:monospace;">
                            @(dev.DeviceId.Length > 12 ? dev.DeviceId[..12] + "…" : dev.DeviceId)
                        </small>
                    </div>
                    <small style="color:#a78bfa;font-size:11px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        @(dev.PoiName ?? "Đang khám phá")
                    </small>
                </div>
            }
            @if (activeDevices.Count > 8)
            {
                <div class="text-center mt-1">
                    <small style="color:#6b7280; font-size:11px;">+@(activeDevices.Count - 8) thiết bị khác</small>
                </div>
            }
        </div>
    }
    else if (!isFirstLoad)
    {
        <div class="text-center py-3">
            <i class="bi bi-moon-stars" style="color:#4a3a7a; font-size:1.5rem;"></i>
            <p class="mb-0 mt-1" style="color:#4a3a7a; font-size:12px;">Không có thiết bị hoạt động</p>
        </div>
    }
</div>

@code {
    [Parameter] public int WindowMinutes { get; set; } = 2;
    [Parameter] public int RefreshSeconds { get; set; } = 10;

    private List<ActiveDevice> activeDevices = new();
    private int activeCount => activeDevices.Count;
    private int windowMinutes = 2;
    private int secondsAgo = 0;
    private bool isLive = false;
    private bool isFirstLoad = true;
    private bool _disposed = false;
    private System.Threading.Timer? _refreshTimer;
    private System.Threading.Timer? _tickTimer;
    private DateTime _lastRefresh = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        windowMinutes = WindowMinutes;
        await LoadAsync();
        isFirstLoad = false;

        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(RefreshSeconds), TimeSpan.FromSeconds(RefreshSeconds));

        _tickTimer = new System.Threading.Timer(async _ =>
        {
            if (_disposed) return;
            secondsAgo = (int)(DateTime.Now - _lastRefresh).TotalSeconds;
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task LoadAsync()
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var threshold = DateTime.Now.AddMinutes(-windowMinutes);

            var latestPerDevice = await db.TrackingLogs
                .AsNoTracking()
                .Where(t => t.CreatedAt >= threshold)
                .GroupBy(t => t.DeviceId)
                .Select(g => new
                {
                    DeviceId = g.Key,
                    PoiId = g.OrderByDescending(t => t.CreatedAt).Select(t => t.PoiId).FirstOrDefault()
                })
                .ToListAsync();

            var poiIds = latestPerDevice
                .Where(d => d.PoiId.HasValue)
                .Select(d => d.PoiId!.Value)
                .Distinct()
                .ToList();

            var poiNames = poiIds.Any()
                ? await db.Pois.AsNoTracking()
                    .Where(p => poiIds.Contains(p.PoiId))
                    .ToDictionaryAsync(p => p.PoiId, p => p.Name)
                : new Dictionary<int, string>();

            activeDevices = latestPerDevice.Select(d => new ActiveDevice
            {
                DeviceId = d.DeviceId ?? "unknown",
                PoiName = d.PoiId.HasValue ? poiNames.GetValueOrDefault(d.PoiId.Value) : null
            }).ToList();

            isLive = true;
            _lastRefresh = DateTime.Now;
            secondsAgo = 0;
        }
        catch
        {
            isLive = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_refreshTimer is not null) await _refreshTimer.DisposeAsync();
        if (_tickTimer is not null) await _tickTimer.DisposeAsync();
    }

    private class ActiveDevice
    {
        public string DeviceId { get; set; } = "";
        public string? PoiName { get; set; }
    }
}
