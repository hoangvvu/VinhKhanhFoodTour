<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFoodTour.MobileApp.ShopPage"
             Title="Gian hàng"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout Padding="15" Spacing="10">
        <Label Text="Quán ăn nổi bật" FontSize="20" FontAttributes="Bold" TextColor="#D32F2F" />

        <CollectionView x:Name="ShopsCollectionView" ItemsSource="{Binding}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout HorizontalItemSpacing="10" VerticalItemSpacing="10" Orientation="Vertical" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" CornerRadius="10" HasShadow="True" WidthRequest="170" HeightRequest="200" BorderColor="#E0E0E0">
                        <VerticalStackLayout Spacing="8">
                            <BoxView Color="#F0F0F0" CornerRadius="8" HeightRequest="80" />
                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Address}" FontSize="10" TextColor="Gray" LineBreakMode="TailTruncation" MaxLines="2" />
                            <Button Text="Xem chi tiết" FontSize="10" Padding="5" BackgroundColor="#D32F2F" TextColor="White" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>