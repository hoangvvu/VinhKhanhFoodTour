<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ══════════════════════════════════════════════
         VĨNH KHÁNH BRAND COLORS
         ══════════════════════════════════════════════ -->
    <Color x:Key="VKBg">#0F0E0E</Color>
    <Color x:Key="VKCard">#1A1818</Color>
    <Color x:Key="VKCardDeep">#141212</Color>
    <Color x:Key="VKCardLight">#222020</Color>
    <Color x:Key="VKStroke">#2E2A2A</Color>
    <Color x:Key="VKStrokeFaint">#201E1E</Color>

    <Color x:Key="VKRed">#C8372D</Color>
    <Color x:Key="VKRedDark">#8B1E1E</Color>
    <Color x:Key="VKRedSoft">#E8534A</Color>
    <Color x:Key="VKGold">#E8A020</Color>
    <Color x:Key="VKGoldDark">#B87800</Color>

    <Color x:Key="VKText">#F0EBE3</Color>
    <Color x:Key="VKTextMuted">#8A8078</Color>
    <Color x:Key="VKTextFaint">#5A5050</Color>
    <Color x:Key="VKTextDisabled">#3A3030</Color>

    <!-- System colors (kept for backward compat) -->
    <Color x:Key="Primary">#C8372D</Color>
    <Color x:Key="PrimaryDark">#8B1E1E</Color>
    <Color x:Key="PrimaryDarkText">#F0EBE3</Color>
    <Color x:Key="Secondary">#E8A020</Color>
    <Color x:Key="SecondaryDarkText">#0F0E0E</Color>
    <Color x:Key="Tertiary">#1A1818</Color>

    <!-- Required by Styles.xaml — keep these keys to avoid KeyNotFoundException -->
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#0F0E0E</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Brush variants for Border.Stroke (Brush type, not Color) -->
    <SolidColorBrush x:Key="VKStrokeBrush"      Color="#2E2A2A"/>
    <SolidColorBrush x:Key="VKStrokeFaintBrush" Color="#201E1E"/>
    <SolidColorBrush x:Key="VKRedBrush"         Color="#C8372D"/>
    <SolidColorBrush x:Key="VKGoldBrush"        Color="#E8A020"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <!-- Styles.xaml: Border.Stroke và các setter cần Brush, không phải Color thuần (Android ổn định hơn) -->
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>

</ResourceDictionary>
