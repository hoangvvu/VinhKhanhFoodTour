<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.TourPlayerPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             xmlns:dto="clr-namespace:VKFoodTour.Shared.DTOs;assembly=VKFoodTour.Shared"
             xmlns:controls="clr-namespace:VKFoodTour.Mobile.Controls"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:DataType="vm:TourPlayerViewModel"
             BackgroundColor="{StaticResource VKBg}"
             Title="{Binding UiTourTitle}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- HEADER -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource VKCard}"
                Padding="16,14" Margin="16,52,16,0"
                Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1">
            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
            <VerticalStackLayout Spacing="6">
                <Label Text="{Binding StatusMessage}"
                       TextColor="{StaticResource VKText}"
                       FontSize="14" FontAttributes="Bold"
                       HorizontalTextAlignment="Center"/>
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="10"
                                       IsVisible="{Binding IsTourActive}">
                    <Border BackgroundColor="{StaticResource VKRed}"
                            Padding="10,4" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Label TextColor="White" FontSize="11" FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding CompletedStalls}"/>
                                    <Span Text="/"/>
                                    <Span Text="{Binding TotalStalls}"/>
                                    <Span Text=" quán"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </Border>
                    <Label Text="·" TextColor="{StaticResource VKTextFaint}" FontSize="14"/>
                    <Label Text="{Binding RemainingDuration, StringFormat='Còn {0}'}"
                           TextColor="{StaticResource VKTextMuted}" FontSize="12"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- CONTENT -->
        <ScrollView Grid.Row="1" Padding="16,12,16,0">
            <VerticalStackLayout Spacing="12">

                <!-- Now Playing -->
                <Border IsVisible="{Binding IsPlaying}" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#C8372D" Offset="0"/>
                            <GradientStop Color="#8B1E1E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="88, *" ColumnSpacing="0">
                        <Border Grid.Column="0" WidthRequest="80" HeightRequest="80"
                                StrokeThickness="2" Stroke="#60FFFFFF">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Grid>
                                <BoxView Color="#4A0A0A"
                                         IsVisible="{Binding NowPlayingImage, Converter={StaticResource NullToBoolConverter}}"/>
                                <Label Text="🍜" FontSize="30"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       IsVisible="{Binding NowPlayingImage, Converter={StaticResource NullToBoolConverter}}"/>
                                <Image Source="{Binding NowPlayingImage}" Aspect="AspectFill"
                                       IsVisible="{Binding NowPlayingImage, Converter={StaticResource NotNullToBoolConverter}}"/>
                            </Grid>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center"
                                             Padding="14,0,0,0" Spacing="4">
                            <Label Text="{Binding UiNowPlaying}"
                                   FontSize="10" TextColor="#CCFFFFFF"
                                   CharacterSpacing="1.5" FontAttributes="Bold"/>
                            <Label Text="{Binding NowPlayingName}"
                                   FontSize="20" FontFamily="BebasNeue"
                                   TextColor="White" LineBreakMode="TailTruncation"
                                   CharacterSpacing="0.3"/>
                            <Label Text="{Binding NowPlayingAddress}"
                                   FontSize="12" TextColor="#AAFFFFFF"
                                   LineBreakMode="TailTruncation"/>
                            <HorizontalStackLayout Spacing="5" Margin="0,2,0,0">
                                <Label Text="📍" FontSize="11"/>
                                <Label Text="{Binding NowPlayingDistance}"
                                       FontSize="12" TextColor="#DDFFFFFF"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Queue -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding IsTourActive}">
                    <Label FontSize="17" FontFamily="BebasNeue"
                           TextColor="{StaticResource VKText}"
                           CharacterSpacing="0.5" Margin="0,4,0,0">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding UiRemaining}"/>
                                <Span Text=" ("/>
                                <Span Text="{Binding RemainingCount}"/>
                                <Span Text=")"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <VerticalStackLayout Spacing="0"
                                         BindableLayout.ItemsSource="{Binding QueueItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="dto:AudioQueueItemDto">
                                <Border BackgroundColor="{StaticResource VKCard}"
                                        Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1"
                                        Padding="12" Margin="0,0,0,8">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="52, *, Auto" ColumnSpacing="12">
                                        <Border Grid.Column="0" WidthRequest="50" HeightRequest="50"
                                                StrokeThickness="0">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Grid>
                                                <BoxView Color="{StaticResource VKCardDeep}"/>
                                                <Label Text="🍜" FontSize="20"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Grid>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                            <Label Text="{Binding PoiName}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource VKText}"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding Address}"
                                                   FontSize="11" TextColor="{StaticResource VKTextMuted}"
                                                   LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center"
                                                             HorizontalOptions="End" Spacing="2">
                                            <Label Text="{Binding DistanceMeters, StringFormat='{0:F0}m'}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="{StaticResource VKGold}"/>
                                            <Label Text="{Binding DurationSeconds, StringFormat='~{0}s'}"
                                                   FontSize="10" TextColor="{StaticResource VKTextFaint}"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Empty State -->
                <VerticalStackLayout Spacing="16" HorizontalOptions="Fill"
                                     IsVisible="{Binding IsTourActive, Converter={StaticResource InvertedBoolConverter}}"
                                     Margin="0,32,0,0">
                    <Label Text="🎙️" FontSize="72" HorizontalOptions="Center"/>
                    <Label Text="Quét mã QR để bắt đầu tour"
                           FontSize="18" FontFamily="BebasNeue"
                           TextColor="{StaticResource VKText}"
                           HorizontalOptions="Center" CharacterSpacing="0.5"/>
                    <Label Text="Audio sẽ phát theo thứ tự từ quán gần nhất"
                           FontSize="13" TextColor="{StaticResource VKTextMuted}"
                           HorizontalOptions="Center"/>

                    <Border StrokeThickness="2" Stroke="{StaticResource VKRedBrush}"
                            IsVisible="{Binding ShowCameraScanner}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <zxing:CameraBarcodeReaderView x:Name="BarcodeReader"
                                                       HeightRequest="260"
                                                       IsDetecting="True"
                                                       IsTorchOn="False"
                                                       BarcodesDetected="OnBarcodesDetected"/>
                    </Border>

                    <Border IsVisible="{Binding ShowManualEntry}"
                            BackgroundColor="{StaticResource VKCard}"
                            Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="16">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Nhập mã QR thủ công"
                                   TextColor="{StaticResource VKTextMuted}"
                                   FontSize="12" CharacterSpacing="1"/>
                            <Border BackgroundColor="{StaticResource VKCardDeep}"
                                    Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Entry Text="{Binding ManualCode}"
                                       Placeholder="VINH-KHANH-TOUR"
                                       TextColor="{StaticResource VKText}"
                                       PlaceholderColor="{StaticResource VKTextFaint}"
                                       BackgroundColor="Transparent"/>
                            </Border>
                            <Button Text="Bắt đầu tour"
                                    Command="{Binding ResolveManualCommand}"
                                    BackgroundColor="{StaticResource VKRed}"
                                    TextColor="White" FontAttributes="Bold"
                                    CornerRadius="12" HeightRequest="46"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- BOTTOM CONTROLS -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource VKCard}"
                Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1"
                Padding="16,12" Margin="16,8,16,16"
                IsVisible="{Binding IsTourActive}">
            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
            <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="{Binding IsPaused, Converter={StaticResource PauseResumeTextConverter}}"
                        Command="{Binding PauseResumeCommand}"
                        BackgroundColor="{StaticResource VKCardLight}"
                        TextColor="{StaticResource VKText}"
                        FontSize="14" FontAttributes="Bold"
                        HeightRequest="50" CornerRadius="25"/>
                <Button Grid.Column="1"
                        Text="⏭"
                        Command="{Binding SkipCommand}"
                        IsEnabled="{Binding CanSkip}"
                        BackgroundColor="{StaticResource VKRed}"
                        TextColor="White" FontSize="18"
                        WidthRequest="58" HeightRequest="50" CornerRadius="25"/>
                <Button Grid.Column="2"
                        Text="⏹"
                        Command="{Binding StopTourCommand}"
                        BackgroundColor="{StaticResource VKCardLight}"
                        TextColor="{StaticResource VKTextMuted}"
                        FontSize="18"
                        WidthRequest="58" HeightRequest="50" CornerRadius="25"/>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Grid Grid.RowSpan="3" BackgroundColor="#C0000000" IsVisible="{Binding IsLoading}">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <ActivityIndicator IsRunning="True"
                                   Color="{StaticResource VKRed}"
                                   HeightRequest="48" WidthRequest="48"/>
                <Label Text="Đang tải tour..."
                       TextColor="White" FontSize="14" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
