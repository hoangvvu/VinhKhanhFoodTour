<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             xmlns:models="clr-namespace:VKFoodTour.Mobile.Models"
             xmlns:controls="clr-namespace:VKFoodTour.Mobile.Controls"
             xmlns:dto="clr-namespace:VKFoodTour.Shared.DTOs;assembly=VKFoodTour.Shared"
             x:DataType="vm:HomeViewModel"
             BackgroundColor="{StaticResource VKBg}"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource VKBg}">
        <VerticalStackLayout Spacing="0">

            <!-- HEADER -->
            <Grid Padding="20,52,20,20" ColumnDefinitions="*, Auto"
                  BackgroundColor="{StaticResource VKBg}">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="{Binding UiGreeting}"
                           FontSize="12" TextColor="{StaticResource VKTextMuted}"
                           CharacterSpacing="1.5" FontAttributes="Bold"/>
                    <Label Text="{Binding UiTitle}"
                           FontSize="28" FontFamily="BebasNeue"
                           TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                </VerticalStackLayout>
                <Border Grid.Column="1" WidthRequest="44" HeightRequest="44"
                        BackgroundColor="{StaticResource VKCard}"
                        Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1">
                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                    <Label Text="{Binding LangFlagEmoji}"
                           HorizontalOptions="Center" VerticalOptions="Center" FontSize="20"/>
                </Border>
            </Grid>

            <!-- NOW PLAYING BANNER -->
            <Border Margin="20,0,20,24"
                    BackgroundColor="{StaticResource VKRed}" StrokeThickness="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto, *" Padding="16" ColumnSpacing="14">
                    <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                            BackgroundColor="#80000000" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                        <Label Text="🎙️" FontSize="22"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="{Binding UiAutoNarration}"
                               FontSize="10" TextColor="White" Opacity="0.7"
                               CharacterSpacing="1" FontAttributes="Bold"/>
                        <Label Text="{Binding NowPlayingText}"
                               TextColor="White" FontSize="14" FontAttributes="Bold"
                               MaxLines="2" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- YÊU THÍCH -->
            <VerticalStackLayout Spacing="12" IsVisible="{Binding HasFavoritePois}" Margin="0,0,0,24">
                <Grid Padding="20,0" ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           Text="{Binding UiFavoritesSection}"
                           FontSize="20" FontFamily="BebasNeue"
                           TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                </Grid>
                <CollectionView ItemsSource="{Binding FavoritePois}" HeightRequest="210">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.HeaderTemplate>
                        <DataTemplate>
                            <BoxView WidthRequest="20" Color="Transparent"/>
                        </DataTemplate>
                    </CollectionView.HeaderTemplate>
                    <CollectionView.FooterTemplate>
                        <DataTemplate>
                            <BoxView WidthRequest="20" Color="Transparent"/>
                        </DataTemplate>
                    </CollectionView.FooterTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Poi">
                            <Border WidthRequest="155"
                                    BackgroundColor="{StaticResource VKCard}"
                                    Stroke="{StaticResource VKStrokeBrush}"
                                    StrokeThickness="1" Padding="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenStallCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="120, *">
                                    <controls:NetworkImageView Grid.Row="0"
                                                               Url="{Binding CoverImageUrl}"
                                                               Placeholder="{Binding CoverEmoji}"
                                                               HeightRequest="120"/>
                                    <Button Grid.Row="0"
                                            Text="{Binding FavoriteIcon}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleFavoriteCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#88000000"
                                            TextColor="White" FontSize="14"
                                            Padding="0" CornerRadius="14"
                                            HorizontalOptions="End" VerticalOptions="Start"
                                            Margin="0,8,8,0"
                                            WidthRequest="32" HeightRequest="32"/>
                                    <VerticalStackLayout Grid.Row="1" Padding="10,8">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource VKText}"
                                               FontFamily="BebasNeue" FontSize="15"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Address}"
                                               TextColor="{StaticResource VKTextFaint}"
                                               FontSize="10" MaxLines="1"
                                               LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- NỔI BẬT -->
            <VerticalStackLayout Spacing="12" Margin="0,0,0,24">
                <Grid Padding="20,0" ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0"
                           Text="{Binding UiFeaturedSection}"
                           FontSize="20" FontFamily="BebasNeue"
                           TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                </Grid>
                <CollectionView ItemsSource="{Binding Pois}" HeightRequest="230">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.HeaderTemplate>
                        <DataTemplate>
                            <BoxView WidthRequest="20" Color="Transparent"/>
                        </DataTemplate>
                    </CollectionView.HeaderTemplate>
                    <CollectionView.FooterTemplate>
                        <DataTemplate>
                            <BoxView WidthRequest="20" Color="Transparent"/>
                        </DataTemplate>
                    </CollectionView.FooterTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Poi">
                            <Border WidthRequest="165"
                                    BackgroundColor="{StaticResource VKCard}"
                                    Stroke="{StaticResource VKStrokeBrush}"
                                    StrokeThickness="1" Padding="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenStallCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="140, *">
                                    <Grid Grid.Row="0">
                                        <controls:NetworkImageView
                                            Url="{Binding CoverImageUrl}"
                                            Placeholder="{Binding CoverEmoji}"
                                            HeightRequest="140"/>
                                        <Button Text="{Binding FavoriteIcon}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleFavoriteCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#88000000"
                                                TextColor="White" FontSize="14"
                                                Padding="0" CornerRadius="14"
                                                HorizontalOptions="End" VerticalOptions="Start"
                                                Margin="0,8,8,0"
                                                WidthRequest="32" HeightRequest="32"/>
                                    </Grid>
                                    <VerticalStackLayout Grid.Row="1" Padding="10,8,10,10" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource VKText}"
                                               FontFamily="BebasNeue" FontSize="16"
                                               LineBreakMode="TailTruncation"/>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="{Binding Rating, StringFormat='⭐ {0:0.0}'}"
                                                   TextColor="{StaticResource VKGold}" FontSize="11"/>
                                            <Label Text="{Binding ReviewCount, StringFormat='({0})'}"
                                                   TextColor="{StaticResource VKTextFaint}" FontSize="10"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- ĐÁNH GIÁ GẦN ĐÂY -->
            <VerticalStackLayout Spacing="12" Padding="20,0,20,32">
                <Label Text="{Binding UiRecentReviews}"
                       FontSize="20" FontFamily="BebasNeue"
                       TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                <!-- BindableLayout avoids CollectionView (RecyclerView) inside ScrollView on Android — common JavaProxyThrowable source -->
                <VerticalStackLayout Spacing="10"
                                     BindableLayout.ItemsSource="{Binding RecentReviews}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="dto:ReviewListItemDto">
                            <Border BackgroundColor="{StaticResource VKCard}"
                                    Stroke="{StaticResource VKStrokeBrush}"
                                    StrokeThickness="1" Padding="14" Margin="0,0,0,10">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding PoiName}"
                                               FontFamily="BebasNeue" FontSize="17"
                                               TextColor="{StaticResource VKGold}"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding CreatedAt, StringFormat='{0:dd/MM}'}"
                                               FontSize="11"
                                               TextColor="{StaticResource VKTextFaint}"/>
                                    </Grid>
                                    <Label Text="{Binding Rating, StringFormat='⭐ {0}/5'}"
                                           FontSize="12" TextColor="{StaticResource VKText}"/>
                                    <Label Text="{Binding Comment}"
                                           TextColor="{StaticResource VKTextMuted}"
                                           FontSize="13" LineBreakMode="WordWrap" MaxLines="3"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
