<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:models="clr-namespace:VKFoodTour.Mobile.Models"
             x:DataType="vm:HomeViewModel"
             BackgroundColor="#0F0E0E"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="XIN CHÀO! 👋" FontSize="14" TextColor="#8A8078" FontFamily="DMSansMedium"/>
                    <Label Text="KHÁM PHÁ VĨNH KHÁNH" FontSize="26" TextColor="#F0EBE3" FontFamily="BebasNeue"/>
                </VerticalStackLayout>

                <Border Grid.Column="1" BackgroundColor="#1A1818" Stroke="#2E2A2A" HeightRequest="45" WidthRequest="45">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22.5"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding CurrentLang, Converter={StaticResource LangToFlagConverter}}" 
                           HorizontalOptions="Center" VerticalOptions="Center" FontSize="20"/>
                </Border>
            </Grid>

            <Border HeightRequest="200" StrokeThickness="0" BackgroundColor="#1A1818">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Grid>
                    <maps:Map x:Name="miniMap" IsScrollEnabled="False" IsZoomEnabled="False" />
                    <BoxView Color="Transparent">
                        <BoxView.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenFullMapCommand}"/>
                        </BoxView.GestureRecognizers>
                    </BoxView>
                    <Border VerticalOptions="End" 
                        HorizontalOptions="End" 
                        Margin="10" 
                        BackgroundColor="#CC000000" 
                        Padding="8,4">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="Phóng to bản đồ ↗️" FontSize="10" TextColor="White"/>
                    </Border>
                </Grid>
            </Border>

            <Border BackgroundColor="#C8372D" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" Text="🎙️" FontSize="24" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0">
                        <Label Text="THUYẾT MINH TỰ ĐỘNG" FontSize="12" TextColor="White" FontFamily="DMSansMedium" Opacity="0.9"/>
                        <Label Text="{Binding NowPlayingText, FallbackValue='Sẵn sàng phát khi bạn đến gần quán ăn...'}" 
                               TextColor="White" FontSize="13" MaxLines="2"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="GIAN HÀNG NỔI BẬT" FontSize="18" TextColor="#F0EBE3" FontFamily="BebasNeue"/>
                    <Label Grid.Column="1" Text="Xem tất cả" TextColor="#E8A020" FontSize="12" VerticalOptions="Center"/>
                </Grid>

                <CollectionView ItemsSource="{Binding Pois}" HeightRequest="180">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Poi">
                            <Border WidthRequest="150" BackgroundColor="#1A1818" Stroke="#2E2A2A">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Padding="10" Spacing="5">
                                    <Label Text="{Binding CoverEmoji}" FontSize="40" HorizontalOptions="Center" Margin="0,10"/>
                                    <Label Text="{Binding Name}" TextColor="#F0EBE3" FontFamily="BebasNeue" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Priority, StringFormat='⭐ {0} điểm'}" TextColor="#E8A020" FontSize="11" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>