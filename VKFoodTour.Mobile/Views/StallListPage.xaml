<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.StallListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             xmlns:models="clr-namespace:VKFoodTour.Mobile.Models"
             xmlns:controls="clr-namespace:VKFoodTour.Mobile.Controls"
             x:DataType="vm:StallListViewModel"
             BackgroundColor="#0F0E0E"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        <Label Grid.Row="0" 
               Text="CÁC GIAN HÀNG" 
               FontSize="32" 
               FontFamily="BebasNeue" 
               TextColor="#F0EBE3" 
               Margin="20,20,20,10" />

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding Pois}" 
                        Margin="20,0"
                        SelectionMode="Single"
                        SelectionChanged="OnStallSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Poi">
                    <Border BackgroundColor="#1A1818" 
                            Stroke="#2E2A2A" 
                            StrokeThickness="1"
                            Padding="15" 
                            Margin="0,0,0,15">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="72, *, Auto">
                            <controls:NetworkImageView Grid.Column="0"
                                                       Url="{Binding CoverImageUrl}"
                                                       Placeholder="{Binding CoverEmoji}"
                                                       WidthRequest="72"
                                                       HeightRequest="72"
                                                       VerticalOptions="Center"
                                                       Margin="0,0,12,0"/>

                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="{Binding Name}"
                                       FontSize="20"
                                       FontFamily="BebasNeue"
                                       TextColor="#F0EBE3"/>

                                <Label Text="{Binding Address}"
                                       FontSize="12"
                                       TextColor="#8A8078"
                                       LineBreakMode="TailTruncation"/>

                                <HorizontalStackLayout Spacing="5" Margin="0,5,0,0">
                                    <Label Text="Ưu tiên:"
                                           FontSize="11"
                                           TextColor="#8A8078"/>
                                    <Label Text="{Binding Priority}"
                                           FontSize="11"
                                           TextColor="#E8A020"
                                           FontFamily="OpenSansSemibold"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Button Grid.Column="2"
                                    Text="{Binding FavoriteIcon}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleFavoriteCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#2E2A2A"
                                    TextColor="#E8A020"
                                    FontSize="18"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    CornerRadius="22"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>