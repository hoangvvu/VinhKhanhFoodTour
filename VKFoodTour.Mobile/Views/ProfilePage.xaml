<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="{StaticResource VKBg}"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20,52,20,32" Spacing="20">

            <Label Text="{Binding UiTitle}"
                   FontSize="30" FontFamily="BebasNeue"
                   TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>

            <!-- AVATAR CARD -->
            <Border BackgroundColor="{StaticResource VKCard}"
                    Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="20">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <Grid ColumnDefinitions="60, *" ColumnSpacing="16">
                    <Border Grid.Column="0" WidthRequest="60" HeightRequest="60"
                            StrokeThickness="2" Stroke="{StaticResource VKRedBrush}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="30"/></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource VKRed}" Offset="0"/>
                                <GradientStop Color="{StaticResource VKRedDark}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label Text="👤" FontSize="26"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding UiTourist}"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource VKText}"/>
                        <Label Text="{Binding UiIdLabel}"
                               FontSize="12" TextColor="{StaticResource VKTextMuted}"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- STATS -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource VKCard}"
                        Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="🎧" FontSize="24"/>
                        <Label Text="{Binding ListenCount}"
                               FontSize="28" FontFamily="BebasNeue"
                               TextColor="{StaticResource VKGold}"/>
                        <Label Text="{Binding UiListened}"
                               FontSize="11" TextColor="{StaticResource VKTextMuted}"
                               CharacterSpacing="0.5"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource VKCard}"
                        Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="❤️" FontSize="24"/>
                        <Label Text="{Binding FavoriteCount}"
                               FontSize="28" FontFamily="BebasNeue"
                               TextColor="{StaticResource VKRed}"/>
                        <Label Text="{Binding UiFavorites}"
                               FontSize="11" TextColor="{StaticResource VKTextMuted}"
                               CharacterSpacing="0.5"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- NGÔN NGỮ -->
            <Border BackgroundColor="{StaticResource VKCard}"
                    Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="16">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding UiLanguageLabel}"
                           FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource VKTextMuted}" CharacterSpacing="1.5"/>
                    <Border BackgroundColor="{StaticResource VKCardDeep}"
                            Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Picker ItemsSource="{Binding LanguageOptions}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedItem="{Binding SelectedLanguageItem}"
                                TextColor="{StaticResource VKText}"
                                BackgroundColor="Transparent"
                                TitleColor="{StaticResource VKTextMuted}"/>
                    </Border>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
