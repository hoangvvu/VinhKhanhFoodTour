<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.ProfilePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="#0F0E0E">
    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">
            <Label Text="CÁ NHÂN" FontSize="32" FontFamily="BebasNeue" TextColor="#F0EBE3"/>
            <Border BackgroundColor="#1A1818" Padding="20" StrokeShape="RoundRectangle 15">
                <HorizontalStackLayout Spacing="20">
                    <Label Text="👤" FontSize="40"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Khách du lịch" FontSize="18" TextColor="#F0EBE3" FontFamily="OpenSansSemibold"/>
                        <Label Text="ID: #2026-VK" FontSize="12" TextColor="#8A8078"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>
            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Border Grid.Column="0" BackgroundColor="#1A1818" Padding="15" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout>
                        <Label Text="ĐÃ NGHE" FontSize="10" TextColor="#8A8078"/>
                        <Label Text="{Binding ListenCount}" FontSize="24" TextColor="#E8A020" FontFamily="BebasNeue"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" BackgroundColor="#1A1818" Padding="15" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout>
                        <Label Text="YÊU THÍCH" FontSize="10" TextColor="#8A8078"/>
                        <Label Text="{Binding FavoriteCount}" FontSize="24" TextColor="#C8372D" FontFamily="BebasNeue"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Button Text="Đăng xuất"
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#8B1E1E"
                    TextColor="White"
                    CornerRadius="12"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>