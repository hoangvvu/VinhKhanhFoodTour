<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.FullMapPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             x:DataType="vm:HomeViewModel"
             Title="{Binding MapPageTitle}">

    <Grid>
        <maps:Map x:Name="bigMap" 
                  IsShowingUser="True" 
                  MapType="Street" />

        <VerticalStackLayout VerticalOptions="End" HorizontalOptions="End" Margin="20" Spacing="10">
            <Button Text="🎯" WidthRequest="50" HeightRequest="50" CornerRadius="25" 
                    BackgroundColor="White" TextColor="Black" FontSize="20"
                    Clicked="OnCenterOnStreet"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>