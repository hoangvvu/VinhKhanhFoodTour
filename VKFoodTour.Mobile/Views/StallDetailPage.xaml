<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.StallDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:VKFoodTour.Shared.DTOs;assembly=VKFoodTour.Shared"
             xmlns:controls="clr-namespace:VKFoodTour.Mobile.Controls"
             xmlns:conv="clr-namespace:VKFoodTour.Mobile.Converters"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             x:DataType="vm:StallDetailViewModel"
             Title="{Binding UiPageTitle}"
             BackgroundColor="{StaticResource VKBg}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- HERO IMAGE -->
            <Grid HeightRequest="260">
                <controls:NetworkImageView Url="{Binding CoverImageUrl}"
                                           Placeholder="{Binding CoverEmoji}"
                                           HeightRequest="260"/>
                <!-- Title overlay -->
                <VerticalStackLayout VerticalOptions="End" Padding="16,0,16,16"
                                     BackgroundColor="#CC000000">
                    <Label Text="{Binding Name}"
                           FontSize="28" FontFamily="BebasNeue"
                           TextColor="White" CharacterSpacing="0.5"/>
                    <Label Text="{Binding Address}"
                           FontSize="12" TextColor="#CCFFFFFF"
                           LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
                <!-- Fav button -->
                <Button Text="{Binding FavoriteIcon}"
                        Command="{Binding ToggleFavoriteCommand}"
                        BackgroundColor="#AA1A1818"
                        TextColor="{StaticResource VKGold}"
                        FontSize="20" WidthRequest="44" HeightRequest="44"
                        CornerRadius="22"
                        HorizontalOptions="End" VerticalOptions="Start"
                        Margin="0,48,12,0"/>
            </Grid>

            <!-- DESCRIPTION -->
            <VerticalStackLayout Padding="16,16,16,8" Spacing="8">
                <Label Text="{Binding Description}"
                       TextColor="{StaticResource VKTextMuted}"
                       FontSize="14" LineBreakMode="WordWrap"/>
            </VerticalStackLayout>

            <!-- GALLERY -->
            <VerticalStackLayout Spacing="8" Margin="0,8,0,0">
                <Label Text="{Binding UiGallery}" Padding="16,0"
                       FontSize="17" FontFamily="BebasNeue"
                       TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                <CollectionView ItemsSource="{Binding GalleryImages}" HeightRequest="110">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.HeaderTemplate>
                        <DataTemplate>
                            <BoxView WidthRequest="16" Color="Transparent"/>
                        </DataTemplate>
                    </CollectionView.HeaderTemplate>
                    <CollectionView.FooterTemplate>
                        <DataTemplate>
                            <BoxView WidthRequest="16" Color="Transparent"/>
                        </DataTemplate>
                    </CollectionView.FooterTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:ImageItemDto">
                            <Border StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <controls:NetworkImageView Url="{Binding Url}"
                                                           WidthRequest="110" HeightRequest="100"/>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <!-- THỰC ĐƠN -->
            <VerticalStackLayout Spacing="10" Margin="16,16,16,0">
                <Label Text="{Binding UiMenu}"
                       FontSize="17" FontFamily="BebasNeue"
                       TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding MenuItems}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="dto:MenuItemDto">
                            <Border Padding="0" Margin="0,0,0,10"
                                    Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1"
                                    BackgroundColor="{StaticResource VKCard}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Grid ColumnDefinitions="90, *">
                                    <controls:NetworkImageView Grid.Column="0"
                                                               Url="{Binding ImageUrl}"
                                                               WidthRequest="90" HeightRequest="85"/>
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="12,10" Spacing="4"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource VKText}"
                                               FontSize="14" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Description}"
                                               FontSize="11" TextColor="{StaticResource VKTextMuted}"
                                               MaxLines="2" LineBreakMode="WordWrap"/>
                                        <Label Text="{Binding Price, StringFormat='{0:N0} ₫'}"
                                               TextColor="{StaticResource VKGold}"
                                               FontSize="14" FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>



            <!-- ĐÁNH GIÁ -->
            <VerticalStackLayout Spacing="10" Margin="16,16,16,0">
                <Label Text="{Binding UiReviews}"
                       FontSize="17" FontFamily="BebasNeue"
                       TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding PoiReviews}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="dto:ReviewListItemDto">
                            <Border BackgroundColor="{StaticResource VKCard}"
                                    Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1"
                                    Padding="14,12" Margin="0,0,0,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <VerticalStackLayout Spacing="5">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Rating, StringFormat='⭐ {0}/5'}"
                                               TextColor="{StaticResource VKGold}"
                                               FontAttributes="Bold" FontSize="13"/>
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy}'}"
                                               FontSize="11" TextColor="{StaticResource VKTextFaint}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Comment}"
                                           TextColor="{StaticResource VKText}"
                                           FontSize="13" LineBreakMode="WordWrap"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- GỬI ĐÁNH GIÁ -->
            <Border Margin="16,16,16,32"
                    BackgroundColor="{StaticResource VKCard}"
                    Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="16">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding UiAddReview}"
                           FontSize="17" FontFamily="BebasNeue"
                           TextColor="{StaticResource VKText}" CharacterSpacing="0.5"/>
                    <Label Text="{Binding ReviewStatus}"
                           FontSize="12" TextColor="{StaticResource VKTextMuted}"/>
                    <Label Text="{Binding RatingLabel}"
                           TextColor="{StaticResource VKGold}" FontSize="14" FontAttributes="Bold"/>
                    <Slider Minimum="1" Maximum="5" Value="{Binding NewRating}"
                            MinimumTrackColor="{StaticResource VKRed}"
                            MaximumTrackColor="{StaticResource VKStroke}"
                            ThumbColor="{StaticResource VKRed}"/>
                    <Border BackgroundColor="{StaticResource VKCardDeep}"
                            Stroke="{StaticResource VKStrokeBrush}" StrokeThickness="1" Padding="2">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Editor Placeholder="{Binding UiReviewPlaceholder}"
                                Text="{Binding NewComment}"
                                TextColor="{StaticResource VKText}"
                                PlaceholderColor="{StaticResource VKTextFaint}"
                                HeightRequest="80" BackgroundColor="Transparent"/>
                    </Border>
                    <Button Text="{Binding UiSubmitReview}"
                            Command="{Binding SubmitReviewCommand}"
                            BackgroundColor="{StaticResource VKRed}"
                            TextColor="White" FontAttributes="Bold"
                            CornerRadius="12" HeightRequest="48"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
