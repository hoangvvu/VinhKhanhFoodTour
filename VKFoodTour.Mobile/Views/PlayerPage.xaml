<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="VKFoodTour.Mobile.Views.PlayerPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VKFoodTour.Mobile.ViewModels"
             x:DataType="vm:PlayerViewModel"
             BackgroundColor="#0F0E0E">
    <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">
        <Border WidthRequest="220" HeightRequest="220" StrokeShape="RoundRectangle 110" BackgroundColor="#1A1818" Stroke="#C8372D">
            <Label Text="🎧" FontSize="80" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>
        <Label Text="{Binding NowPlayingName}" FontSize="28" FontFamily="BebasNeue" TextColor="#E8A020" HorizontalOptions="Center"/>
        <Label Text="{Binding NowPlayingText}" FontSize="14" TextColor="#F0EBE3" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
        <Button Text="DỪNG PHÁT" Command="{Binding StopCommand}" BackgroundColor="#C8372D" CornerRadius="25" HeightRequest="50"/>
    </VerticalStackLayout>
</ContentPage>