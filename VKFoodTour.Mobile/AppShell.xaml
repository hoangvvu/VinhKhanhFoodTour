<Shell x:Class="VKFoodTour.Mobile.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:VKFoodTour.Mobile.Views"
       Shell.NavBarIsVisible="False"
       Shell.TabBarBackgroundColor="#0F0E0E"
       Shell.TabBarForegroundColor="#E8A020"
       Shell.TabBarUnselectedColor="#5A5050">

    <TabBar>
        <!-- Không dùng Icon=*.png: nếu file không có trong Resources/Images, Android Shell hay crash khi vẽ TabBar (JavaProxyThrowable). Thêm lại khi đã có asset trong bundle. -->
        <Tab x:Name="TabHome" Title="Khám phá">
            <ShellContent ContentTemplate="{DataTemplate pages:HomePage}" Route="home" />
        </Tab>
        <Tab x:Name="TabTour" Title="🎙️ Tour">
            <ShellContent ContentTemplate="{DataTemplate pages:TourPlayerPage}" Route="tour" />
        </Tab>
        <Tab x:Name="TabMap" Title="Bản đồ">
            <ShellContent ContentTemplate="{DataTemplate pages:FullMapPage}" Route="fullmap" />
        </Tab>
        <Tab x:Name="TabStalls" Title="Gian hàng">
            <ShellContent ContentTemplate="{DataTemplate pages:StallListPage}" Route="stalls" />
        </Tab>
        <Tab x:Name="TabProfile" Title="Hồ sơ">
            <ShellContent ContentTemplate="{DataTemplate pages:ProfilePage}" Route="profile" />
        </Tab>
    </TabBar>
</Shell>
