<Shell x:Class="VKFoodTour.Mobile.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:VKFoodTour.Mobile.Views"
       Shell.NavBarIsVisible="False">

    <TabBar>
        <Tab Title="Khám phá" Icon="icon_map.png">
            <ShellContent ContentTemplate="{DataTemplate pages:HomePage}" Route="home" />
        </Tab>
        <Tab Title="Bản đồ" Icon="icon_map_big.png">
            <ShellContent ContentTemplate="{DataTemplate pages:FullMapPage}" Route="fullmap" />
        </Tab>
        <Tab Title="Gian hàng" Icon="icon_stall.png">
            <ShellContent ContentTemplate="{DataTemplate pages:StallListPage}" Route="stalls" />
        </Tab>
        <Tab Title="Quét QR">
            <ShellContent ContentTemplate="{DataTemplate pages:QrScanPage}" Route="qrscan" />
        </Tab>

        <Tab Title="Hồ sơ" Icon="icon_profile.png">
            <ShellContent ContentTemplate="{DataTemplate pages:ProfilePage}" Route="profile" />
        </Tab>
    </TabBar>
</Shell>